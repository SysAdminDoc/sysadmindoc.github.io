{
  "name": "sysadmindoc-portfolio",
  "type": "module",
  "version": "0.16.12",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "npm run data:validate && npm run assets:audit && astro build && npm run search:index",
    "check": "npm run data:validate && npm run assets:audit && astro check",
    "preview": "astro preview",
    "astro": "astro",
    "fetch-stars": "node scripts/fetch-stars.mjs",
    "capture-screenshots": "node scripts/capture-screenshots.mjs",
    "data:validate": "node scripts/validate-project-data.mjs",
    "data:summary": "node scripts/summarize-generated-data.mjs",
    "assets:audit": "node scripts/audit-assets.mjs",
    "audit:perf": "node scripts/audit-performance.mjs",
    "audit:prod": "npm audit --omit=dev --audit-level=high",
    "search:index": "pagefind --site dist --glob \"**/*.html\"",
    "catalog:audit": "node scripts/audit-catalog.mjs"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.2.1",
    "@resvg/resvg-js": "^2.6.2",
    "astro": "^6.3.3",
    "marked": "^18.0.3",
    "sanitize-html": "^2.17.4",
    "satori": "^0.26.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@types/sanitize-html": "^2.16.1",
    "lightningcss": "^1.32.0",
    "pagefind": "^1.5.2",
    "typescript": "^5.7.2"
  }
}
