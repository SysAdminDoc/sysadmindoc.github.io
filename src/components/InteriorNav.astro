---
type ActiveRoute = 'releases' | 'now';
type ContextTone = 'blue' | 'green' | 'amber' | 'slate';

export interface Props {
  active?: ActiveRoute;
  contextLabel?: string;
  contextHref?: string;
  contextTone?: ContextTone;
}

const {
  active,
  contextLabel,
  contextHref,
  contextTone = 'slate',
} = Astro.props;

const isActive = (key: ActiveRoute) => active === key;
const contextClass = `nav-context nav-context-${contextTone}`;
---
<nav id="nav" aria-label="Main navigation">
  <div class="ni">
    <a href="/" class="nl">matt<span>@</span>sysadmin<span>:~$</span></a>
    <div class="nk" id="navLinks">
      <a href="/#greatest-hits">Hits</a>
      <a href="/#featured">Projects</a>
      <a href="/#live">Live</a>
      <a href="/#catalog">Catalog</a>
      <a href="/releases/" class={isActive('releases') ? 'active' : undefined} aria-current={isActive('releases') ? 'page' : undefined}>Releases</a>
      <a href="/now/" class={isActive('now') ? 'active' : undefined} aria-current={isActive('now') ? 'page' : undefined}>Now</a>
    </div>
    <div class="nav-actions">
      {contextLabel && (
        contextHref ? (
          <a href={contextHref} class={contextClass}>
            <span class="nav-context-eyebrow">Viewing</span>
            <span class="nav-context-value">{contextLabel}</span>
          </a>
        ) : (
          <span class={contextClass} aria-label={`Current view: ${contextLabel}`}>
            <span class="nav-context-eyebrow">Viewing</span>
            <span class="nav-context-value">{contextLabel}</span>
          </span>
        )
      )}
      <button type="button" class="theme-toggle" id="themeToggle" aria-label="Switch to light theme" title="Switch to light theme"><svg viewBox="0 0 24 24"><path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"/></svg></button>
      <button type="button" class="nav-search" id="cmdkToggle" aria-label="Open command palette (Ctrl or Cmd + K)" aria-controls="cmdk" aria-expanded="false" aria-haspopup="dialog" title="Search (Ctrl/Cmd + K)">
        <svg viewBox="0 0 24 24" stroke-width="2" fill="none" stroke="currentColor" stroke-linecap="round"><circle cx="11" cy="11" r="7"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <span class="nav-search-label">Search</span>
        <span class="nav-search-kbd" aria-hidden="true">Ctrl K</span>
      </button>
      <a href="/" class="ng" aria-label="Home">← Home</a>
      <button type="button" class="mt" id="mobileToggle" aria-label="Toggle navigation menu" aria-controls="navLinks" aria-expanded="false"><svg viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg></button>
    </div>
  </div>
</nav>
