---
import { catalog } from '../data/projects';

// Count repos per category
const counts: Record<string, number> = {};
for (const c of catalog) counts[c.category] = (counts[c.category] ?? 0) + 1;

const labels: Record<string, string> = {
  ps: 'PowerShell', py: 'Python', web: 'Web Apps', ext: 'Extensions',
  kt: 'Android', sec: 'Security', media: 'Media', cs: 'Desktop',
  guide: 'Guides', fork: 'Forks', other: 'Other',
};

const entries = Object.entries(counts)
  .sort((a, b) => b[1] - a[1]);
const lead = entries[0];
const runnerUps = entries.slice(1, 3).map(([key]) => labels[key] ?? key);
const leadLabel = lead ? labels[lead[0]] ?? lead[0] : '';
const quickPicks = entries.slice(0, 3).map(([key, count]) => ({
  key,
  count,
  label: labels[key] ?? key,
}));
const totalRepos = catalog.length;

const max = Math.max(...entries.map(([, n]) => n));
const min = Math.min(...entries.map(([, n]) => n));
const scale = (n: number) => {
  if (max === min) return 1;
  return 0.6 + (0.9 * (n - min)) / (max - min); // 0.6 → 1.5 em
};
---
<section id="volume" aria-label="Repository volume by category">
  <div class="si">
    <div class="sh rv">
      <div class="sl">// Volume</div>
      <h2 class="st">Where the work lives</h2>
      <p class="sd">The archive clusters around a few heavy lanes. Open any category to jump straight into a filtered catalog view.</p>
    </div>
    <div class="tag-cloud-frame rv">
      {lead && (
        <div class="tag-cloud-summary">
          <span class="tag-cloud-summary-label">Repository footprint</span>
          <div class="tag-cloud-summary-copy">
            <p>
              <strong>{leadLabel}</strong> anchors the archive with <strong>{lead[1]}</strong> repositories
              {runnerUps.length ? `, with ${runnerUps.join(' and ')} close behind.` : '.'}
            </p>
            {quickPicks.length > 0 && (
              <div class="tag-cloud-actions" aria-label="Jump to top categories">
                {quickPicks.map((pick) => (
                  <a href={`/?cat=${pick.key}#catalog`} class="tag-cloud-action">
                    <span>{pick.label}</span>
                    <span>{pick.count}</span>
                  </a>
                ))}
              </div>
            )}
          </div>
          <div class="tag-cloud-summary-metric" aria-hidden="true">
            <span class="tag-cloud-summary-value">{totalRepos}</span>
            <span class="tag-cloud-summary-caption">repos in the public archive</span>
          </div>
        </div>
      )}
      <div class="tag-cloud">
        {entries.map(([key, n]) => (
          <a
            href={`/?cat=${key}#catalog`}
            class="tag-cloud-tag"
            data-cat={key}
            style={`font-size:${scale(n)}em`}
            aria-label={`${labels[key] ?? key}: ${n} repositories`}
          >
            <span class={`cdo ${key}`}></span>
            <span class="tag-cloud-label">{labels[key] ?? key}</span>
            <span class="tag-cloud-count">{n}</span>
          </a>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .tag-cloud-frame{
    max-width:1100px;
    margin:0 auto;
    padding:28px;
    border-radius:28px;
    border:1px solid rgba(255,255,255,.08);
    background:linear-gradient(180deg, rgba(255,255,255,.04), rgba(255,255,255,.02));
    box-shadow:0 18px 42px rgba(0,0,0,.18);
  }
  .tag-cloud-summary{
    display:grid;
    grid-template-columns:160px minmax(0,1fr) auto;
    gap:18px;
    align-items:start;
    margin-bottom:22px;
    padding-bottom:18px;
    border-bottom:1px solid rgba(255,255,255,.08);
  }
  .tag-cloud-summary-label{
    font-family:var(--mono);
    font-size:11px;
    letter-spacing:.16em;
    text-transform:uppercase;
    color:var(--org);
    padding-top:4px;
  }
  .tag-cloud-summary p{
    margin:0;
    color:var(--t2);
    font-size:16px;
    line-height:1.75;
    max-width:52ch;
  }
  .tag-cloud-summary-copy{
    display:grid;
    gap:14px;
  }
  .tag-cloud-summary strong{color:var(--t1)}
  .tag-cloud-summary-metric{
    display:grid;
    gap:4px;
    justify-items:end;
    text-align:right;
    min-width:138px;
  }
  .tag-cloud-summary-value{
    font-family:var(--mono);
    font-size:clamp(26px,4vw,40px);
    line-height:1;
    color:var(--t1);
  }
  .tag-cloud-summary-caption{
    font-family:var(--mono);
    font-size:11px;
    letter-spacing:.12em;
    text-transform:uppercase;
    color:var(--t3);
  }
  .tag-cloud-actions{
    display:flex;
    flex-wrap:wrap;
    gap:10px;
  }
  .tag-cloud-action{
    display:inline-flex;
    align-items:center;
    gap:10px;
    padding:9px 12px;
    border-radius:999px;
    border:1px solid rgba(255,255,255,.08);
    background:rgba(255,255,255,.03);
    color:var(--t2);
    text-decoration:none;
    font-family:var(--mono);
    font-size:12px;
    transition:color .2s ease-out,background-color .2s ease-out,border-color .2s ease-out,box-shadow .2s ease-out,transform .2s ease-out;
  }
  .tag-cloud-action span:last-child{
    color:var(--t1);
    padding:2px 7px;
    border-radius:999px;
    background:rgba(255,255,255,.05);
  }
  .tag-cloud-action:hover{
    color:var(--t1);
    border-color:rgba(255,255,255,.16);
    background:var(--glass-hover);
    transform:translateY(-1px);
  }
  .tag-cloud-action:focus-visible{outline:2px solid var(--grn);outline-offset:3px}
  .tag-cloud{display:flex;flex-wrap:wrap;gap:14px 18px;justify-content:flex-start;align-items:baseline;max-width:none;margin:0;padding:0}
  .tag-cloud-tag{
    display:inline-flex;align-items:center;gap:8px;
    color:var(--t2);text-decoration:none;
    padding:10px 14px;border-radius:999px;border:1px solid rgba(255,255,255,.08);
    background:rgba(255,255,255,.03);
    line-height:1;
    transition:color .2s ease-out,background-color .2s ease-out,border-color .2s ease-out,box-shadow .2s ease-out,transform .2s ease-out;
  }
  .tag-cloud-tag:hover{color:var(--t1);border-color:rgba(255,255,255,.16);background:var(--glass-hover);transform:translateY(-2px)}
  .tag-cloud-tag:focus-visible{outline:2px solid var(--grn);outline-offset:3px}
  .tag-cloud-label{font-family:var(--mono);font-weight:600}
  .tag-cloud-count{font-family:var(--mono);font-size:.7em;color:var(--t3);padding:2px 7px;background:var(--bg3);border-radius:999px;line-height:1.4}
  .tag-cloud-tag:hover .tag-cloud-count{color:var(--t1);background:var(--glass-border)}
  @media(max-width:900px){
    .tag-cloud-summary{grid-template-columns:1fr}
    .tag-cloud-summary-metric{justify-items:start;text-align:left;min-width:0}
  }
  @media(max-width:640px){
    .tag-cloud-frame{padding:20px}
    .tag-cloud-summary{grid-template-columns:1fr;gap:10px}
    .tag-cloud-summary-metric{justify-items:start;text-align:left;min-width:0}
    .tag-cloud-summary p{font-size:15px}
  }
</style>
