---
import type { LiveApp } from '../data/types';
import { existsSync } from 'node:fs';
import { dirname, join } from 'node:path';
import { fileURLToPath } from 'node:url';

export interface Props {
  app: LiveApp;
}
const { app } = Astro.props;
const publicDir = join(dirname(fileURLToPath(import.meta.url)), '..', '..', 'public');
const screenshotPath = join(publicDir, 'screenshots', `${app.slug}.jpg`);
const hasScreenshot = existsSync(screenshotPath);
const descText = String(app.desc ?? '')
  .replace(/<[^>]+>/g, '')
  .replace(/&amp;/g, '&')
  .replace(/&mdash;|&ndash;/g, '-')
  .replace(/&nbsp;/g, ' ')
  .replace(/\s+/g, ' ')
  .trim();
let liveHost = app.url;
try {
  liveHost = new URL(app.url).hostname.replace(/^www\./, '');
} catch {}
---
<a
  href={app.url}
  target="_blank"
  rel="noopener"
  class="lc2 card-enter"
  aria-label={`${app.name}. ${descText}. Opens ${liveHost} in a new tab.`}
>
  {hasScreenshot ? (
    <div class="lc2-thumb lc2-thumb-static" aria-hidden="true">
      <img src={`/screenshots/${app.slug}.jpg`} alt="" loading="lazy" decoding="async" width="1280" height="800" />
      <span class="lc2-preview-label">Captured preview</span>
    </div>
  ) : (
    <div class="lc2-thumb thumb-fallback lc2-thumb-static" aria-hidden="true">
      <span class="lc2-preview-label">Preview pending</span>
    </div>
  )}
  <div class="lct">
    <div class="lcn">{app.name}</div>
    <span class="lb2">LIVE</span>
  </div>
  <div class="lcd" set:html={app.desc}></div>
  <div class="lc2-meta-row" aria-hidden="true">
    <span>No install</span>
    <span>No sign-in</span>
  </div>
  <div class="lc2-foot" aria-hidden="true">
    <span class="lc2-origin">{liveHost}</span>
    <span class="lc2-cta">Open in browser</span>
  </div>
</a>
