---
interface Props {
  days: string[];
}

const { days } = Astro.props;

// Build a lookup: date string -> push count
const dayCounts = new Map<string, number>();
for (const d of days) {
  dayCounts.set(d, (dayCounts.get(d) ?? 0) + 1);
}

// Compute the 52-week grid ending today (Sun-start weeks like GitHub)
const today = new Date();
const todayUtc = new Date(Date.UTC(today.getUTCFullYear(), today.getUTCMonth(), today.getUTCDate()));

// Find the Saturday of the current week (end of grid)
const todayDow = todayUtc.getUTCDay(); // 0=Sun
const endDate = new Date(todayUtc);
endDate.setUTCDate(endDate.getUTCDate() + (6 - todayDow));

// Start date: 52 weeks before end (52*7 = 364 days before endDate, then +1 to get the Sunday)
const startDate = new Date(endDate);
startDate.setUTCDate(startDate.getUTCDate() - (52 * 7 - 1));

const weeks: { date: string; count: number; dow: number; future: boolean }[][] = [];
let currentWeek: typeof weeks[0] = [];
const cursor = new Date(startDate);

while (cursor <= endDate) {
  const key = `${cursor.getUTCFullYear()}-${String(cursor.getUTCMonth() + 1).padStart(2, '0')}-${String(cursor.getUTCDate()).padStart(2, '0')}`;
  const count = dayCounts.get(key) ?? 0;
  const dow = cursor.getUTCDay();
  const future = cursor > todayUtc;
  currentWeek.push({ date: key, count, dow, future });
  if (dow === 6) {
    weeks.push(currentWeek);
    currentWeek = [];
  }
  cursor.setUTCDate(cursor.getUTCDate() + 1);
}
if (currentWeek.length > 0) weeks.push(currentWeek);

// SVG dimensions
const cellSize = 12;
const cellGap = 3;
const cellStep = cellSize + cellGap;
const labelWidth = 28;
const topPad = 20; // for month labels
const svgWidth = labelWidth + weeks.length * cellStep;
const svgHeight = topPad + 7 * cellStep;

// Month labels: find first occurrence of each month
const monthLabels: { text: string; x: number }[] = [];
let lastMonth = -1;
const monthNames = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
for (let wi = 0; wi < weeks.length; wi++) {
  const firstDay = weeks[wi][0];
  if (!firstDay) continue;
  const month = parseInt(firstDay.date.split('-')[1], 10) - 1;
  if (month !== lastMonth) {
    monthLabels.push({ text: monthNames[month], x: labelWidth + wi * cellStep });
    lastMonth = month;
  }
}

// Day-of-week labels
const dayLabels = [
  { text: 'Mon', y: topPad + 1 * cellStep + cellSize - 2 },
  { text: 'Wed', y: topPad + 3 * cellStep + cellSize - 2 },
  { text: 'Fri', y: topPad + 5 * cellStep + cellSize - 2 },
];

// Intensity levels: 0 = empty, 1 = low, 2 = mid, 3+ = high
function intensityClass(count: number, future: boolean): string {
  if (future) return 'hm-empty';
  if (count === 0) return 'hm-0';
  if (count === 1) return 'hm-1';
  if (count === 2) return 'hm-2';
  return 'hm-3';
}

const totalActivity = days.length;
---

{days.length > 0 && (
  <div class="heatmap-wrap">
    <div class="heatmap-head">
      <span class="heatmap-label">{totalActivity} pushes in the last year</span>
    </div>
    <div class="heatmap-scroll">
      <svg
        class="heatmap-svg"
        width={svgWidth}
        height={svgHeight}
        viewBox={`0 0 ${svgWidth} ${svgHeight}`}
        role="img"
        aria-label={`Contribution heatmap: ${totalActivity} pushes in the last 52 weeks`}
      >
        {/* Month labels */}
        {monthLabels.map((m) => (
          <text x={m.x} y={12} class="hm-month">{m.text}</text>
        ))}
        {/* Day-of-week labels */}
        {dayLabels.map((d) => (
          <text x={0} y={d.y} class="hm-day">{d.text}</text>
        ))}
        {/* Cells */}
        {weeks.map((week, wi) =>
          week.map((day) => (
            <rect
              x={labelWidth + wi * cellStep}
              y={topPad + day.dow * cellStep}
              width={cellSize}
              height={cellSize}
              rx={2}
              ry={2}
              class={intensityClass(day.count, day.future)}
            >
              {!day.future && day.count > 0 && (
                <title>{`${day.date}: ${day.count} push${day.count > 1 ? 'es' : ''}`}</title>
              )}
            </rect>
          ))
        )}
      </svg>
    </div>
    <div class="heatmap-legend">
      <span class="heatmap-legend-label">Less</span>
      <span class="hm-swatch hm-0"></span>
      <span class="hm-swatch hm-1"></span>
      <span class="hm-swatch hm-2"></span>
      <span class="hm-swatch hm-3"></span>
      <span class="heatmap-legend-label">More</span>
    </div>
  </div>
)}
