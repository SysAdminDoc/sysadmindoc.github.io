---
// Wavy animated divider used between sections
---
<div class="dv">
  <svg viewBox="0 0 1200 40" preserveAspectRatio="none">
    <path class="wave-path" d="M0 20 Q150 5,300 20 T600 20 T900 20 T1200 20">
      <animate attributeName="d" dur="6s" repeatCount="indefinite" values="M0 20 Q150 5,300 20 T600 20 T900 20 T1200 20;M0 20 Q150 35,300 20 T600 20 T900 20 T1200 20;M0 20 Q150 5,300 20 T600 20 T900 20 T1200 20" />
    </path>
    <path class="wave-glow" stroke="url(#waveGrad)" d="M0 20 Q150 5,300 20 T600 20 T900 20 T1200 20">
      <animate attributeName="d" dur="6s" repeatCount="indefinite" values="M0 20 Q150 5,300 20 T600 20 T900 20 T1200 20;M0 20 Q150 35,300 20 T600 20 T900 20 T1200 20;M0 20 Q150 5,300 20 T600 20 T900 20 T1200 20" />
    </path>
  </svg>
</div>
