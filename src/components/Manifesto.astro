---
import { manifesto } from '../data/curated';
---
<section id="manifesto" aria-label="Building principles">
  <div class="si">
    <div class="sh rv">
      <div class="sl">// Rules</div>
      <h2 class="st">Every project, same seven rules</h2>
    </div>
    <ol class="manifesto">
      {manifesto.map((r, i) => (
        <li class="manifesto-item card-enter">
          <span class="manifesto-num">{String(i + 1).padStart(2, '0')}</span>
          <span class="manifesto-word">{r.word}</span>
          <span class="manifesto-rule">{r.rule}</span>
        </li>
      ))}
    </ol>
  </div>
</section>

<style>
  .manifesto{
    list-style:none;
    padding:0;
    margin:0 auto;
    max-width:1180px;
    border-top:1px solid rgba(255,255,255,.08);
    border-bottom:1px solid rgba(255,255,255,.08);
  }
  .manifesto-item{
    display:grid;
    grid-template-columns:56px minmax(130px,180px) minmax(0,1fr);
    gap:18px;
    align-items:baseline;
    padding:22px 0;
    border-bottom:1px solid rgba(255,255,255,.06);
    transition:transform .25s ease-out;
  }
  .manifesto-item:last-child{border-bottom:0}
  .manifesto-item:hover{transform:translateX(4px)}
  .manifesto-num{
    font-family:var(--mono);
    font-size:12px;
    color:var(--t3);
    letter-spacing:.14em;
    padding-top:4px;
  }
  .manifesto-word{
    font-family:var(--mono);
    font-weight:700;
    color:var(--org);
    font-size:12px;
    letter-spacing:.16em;
    text-transform:uppercase;
  }
  .manifesto-rule{
    color:var(--t1);
    font-size:16px;
    line-height:1.8;
    max-width:42ch;
  }
  @media(max-width:640px){
    .manifesto-item{
      grid-template-columns:42px 1fr;
      gap:10px 14px;
      padding:18px 0;
    }
    .manifesto-word,.manifesto-rule{grid-column:2}
    .manifesto-rule{font-size:15px}
  }
</style>
