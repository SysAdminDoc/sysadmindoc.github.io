---
import type { CatalogEntry } from '../data/types';
import { categoryLabels } from '../data/categories';
import { githubRepoUrl } from '../data/github';
import StarSvg from './StarSvg.astro';

export interface Props {
  entry: CatalogEntry;
  stars?: number;
  pushedAt?: string;
  updatedAt?: string;
  isNew?: boolean;
  isRecent?: boolean;
  hasDownload?: boolean;
  index?: number;
  rank?: number;
  rankScore?: number;
  rankLabel?: string;
  rankDisplayLabel?: string;
}
const {
  entry,
  stars,
  pushedAt,
  updatedAt,
  isNew = false,
  isRecent = false,
  hasDownload = false,
  index = 0,
  rank,
  rankScore,
  rankLabel = '',
  rankDisplayLabel = '',
} = Astro.props;
// Relative age → short badge string. Only show if data is present.
function relAge(iso?: string): string | null {
  if (!iso) return null;
  const ms = Date.now() - new Date(iso).getTime();
  const days = Math.floor(ms / 86400000);
  if (days <= 0) return 'today';
  if (days === 1) return '1d';
  if (days < 30) return `${days}d`;
  const months = Math.floor(days / 30);
  if (months < 12) return `${months}mo`;
  const years = Math.floor(days / 365);
  return `${years}y`;
}
function freshnessClass(iso?: string): string {
  if (!iso) return '';
  const days = (Date.now() - new Date(iso).getTime()) / 86400000;
  if (days < 14) return 'age-hot';
  if (days < 90) return 'age-warm';
  if (days < 365) return 'age-cool';
  return 'age-stale';
}
const age = relAge(pushedAt);
const ageClass = freshnessClass(pushedAt);
const pushedDateLabel = pushedAt
  ? new Intl.DateTimeFormat('en-US', { month: 'short', day: 'numeric', year: 'numeric', timeZone: 'UTC' }).format(new Date(pushedAt))
  : '';
const categoryLabel = categoryLabels[entry.category] ?? entry.category;
const descText = String(entry.desc ?? '').replace(/<[^>]+>/g, '').trim();
const rankDescriptionId = rankDisplayLabel
  ? `rank-${entry.repo.replace(/[^A-Za-z0-9_-]/g, '-')}`
  : undefined;
const ariaParts = [
  entry.name,
  categoryLabel,
  'opens the GitHub repository in a new tab',
  entry.live ? 'live build available' : null,
  pushedDateLabel ? `last updated ${pushedDateLabel}` : null,
  descText || null,
].filter(Boolean);
---
<a
  href={githubRepoUrl(entry.repo)}
  target="_blank"
  rel="noopener"
  class="ca"
  aria-label={ariaParts.join('. ')}
  aria-describedby={rankDescriptionId}
  data-f={entry.category}
  data-repo={entry.repo}
  data-name={entry.name}
  data-terms={`${entry.repo} ${entry.category} ${categoryLabel} ${entry.topics?.join(' ') ?? ''} ${entry.primaryAction?.label ?? ''} ${entry.live ? ' live browser' : ''} ${isNew ? ' new fresh' : ''} ${isRecent ? ' recently updated current' : ''} ${hasDownload ? ' download release has-download' : ''}`}
  data-stars={stars ?? 0}
  data-updated={updatedAt ?? pushedAt ?? ''}
  data-new={isNew ? 'true' : 'false'}
  data-recent={isRecent ? 'true' : 'false'}
  data-has-download={hasDownload ? 'true' : 'false'}
  data-index={index}
  data-rank={rankScore?.toFixed(4) ?? '0'}
  data-rank-position={rank ?? index + 1}
>
  <span class={`cdo ${entry.category}`}></span>
  <span class="ca-copy">
    <span class="cna">
      <span class="cna-label">{entry.name}</span>
      <span class="ca-kind">{categoryLabel}</span>
    </span>
    <span class="cds" set:html={entry.desc}></span>
    {rankDisplayLabel && (
      <span class="ca-rank" id={rankDescriptionId} title={rankLabel || rankDisplayLabel}>
        {rankDisplayLabel}
      </span>
    )}
  </span>
  <span class="ca-side">
    {age && pushedAt && (
      <time
        class={`ca-age ${ageClass}`}
        datetime={pushedAt}
        data-rel-short={pushedAt}
        title={pushedDateLabel ? `Last pushed ${pushedDateLabel}` : ''}
      >
        {age}
      </time>
    )}
    {(stars ?? 0) > 0 && (
      <span class="ca-stars" data-repo={entry.repo}>
        <StarSvg />
        <span class="live-star">{stars}</span>
      </span>
    )}
    {isNew && <span class="lb2 ca-chip ca-chip-new">NEW</span>}
    {hasDownload && <span class="lb2 ca-chip ca-chip-download">DOWNLOAD</span>}
    {entry.live && <span class="lb2">LIVE</span>}
  </span>
</a>
