---
import { greatestHits } from '../data/curated';
import { githubRepoUrl } from '../data/github';
import StarSvg from './StarSvg.astro';

let stars: Record<string, number> = {};
try {
  const mod = await import('../data/_stars.json');
  stars = (mod.default ?? mod) as Record<string, number>;
} catch {}
---
<section id="greatest-hits" aria-label="Greatest hits">
  <div class="si">
    <div class="sh rv">
      <div class="sl">01 / Portfolio</div>
      <h2 class="st">Selected work</h2>
      <p class="sd">{greatestHits.length} projects that best show the range.</p>
    </div>
    <div class="gh-grid">
      {greatestHits.map((hit, i) => {
        return (
        <a href={githubRepoUrl(hit.repo)} target="_blank" rel="noopener" class={`gh-card card-enter${i === 0 ? ' gh-card-primary' : ''}`} data-repo={hit.repo}>
          <div class="gh-head">
            <span class="gh-rank">{String(i + 1).padStart(2, '0')}</span>
            <span class="gh-tag">{hit.tag}</span>
            {stars[hit.repo] ? (
              <span class="gh-stars"><StarSvg /> {stars[hit.repo]}</span>
            ) : null}
          </div>
          <h3 class="gh-name">{hit.name}</h3>
          <p class="gh-why">{hit.why}</p>
          <div class="gh-foot">
            <span class="gh-foot-cta">View repository</span>
          </div>
        </a>
        );
      })}
    </div>
  </div>
</section>

<style>
  .gh-grid{
    display:grid;
    grid-template-columns:repeat(12,minmax(0,1fr));
    gap:16px;
    max-width:1400px;
    margin:0 auto;
  }
  .gh-card{
    grid-column:span 4;
    display:flex;
    flex-direction:column;
    gap:16px;
    min-height:248px;
    padding:26px;
    border:1px solid var(--border-soft);
    border-radius:var(--radius-md);
    background:var(--surface-1);
    text-decoration:none;
    position:relative;
    overflow:hidden;
    box-shadow:var(--shadow-xs);
    transition:transform var(--dur-base) var(--ease-out),box-shadow var(--dur-base) var(--ease-out),border-color var(--dur-base) var(--ease-out),background var(--dur-base) var(--ease-out);
  }
  .gh-card::before{
    content:'';
    position:absolute;
    inset:0 auto 0 0;
    width:3px;
    background:var(--blue);
    opacity:0;
    transition:opacity var(--dur-base) var(--ease-out);
  }
  .gh-card:hover{
    border-color:var(--border-strong);
    transform:translateY(-3px);
    box-shadow:var(--shadow-md);
  }
  .gh-card:hover::before,.gh-card:focus-visible::before{opacity:1}
  .gh-card:focus-visible{outline:2px solid var(--focus-outline);outline-offset:3px}
  .gh-card-primary{
    grid-column:span 12;
    display:grid;
    grid-template-columns:minmax(0,1.1fr) minmax(320px,.9fr) auto;
    grid-template-areas:
      'head why foot'
      'name why foot';
    align-items:center;
    gap:12px 48px;
    min-height:210px;
    padding:34px 38px;
    border-color:var(--border-strong);
    background:var(--surface-strong);
    box-shadow:var(--shadow-sm);
  }
  .gh-card-primary::before{opacity:1;background:var(--org)}
  .gh-head{display:flex;align-items:center;gap:10px;flex-wrap:wrap}
  .gh-rank{font-family:var(--mono);font-size:11px;letter-spacing:.14em;color:var(--org);font-weight:700;text-transform:uppercase}
  .gh-tag{font-family:var(--mono);font-size:12px;color:var(--t3);padding:0;border:0;border-radius:0;letter-spacing:.06em;text-transform:uppercase;background:transparent}
  .gh-stars{display:inline-flex;align-items:center;gap:4px;font-family:var(--mono);font-size:12px;color:var(--yel)}
  .gh-stars svg{width:12px;height:12px;fill:currentColor}
  .gh-name{font-family:var(--mono);font-size:20px;font-weight:650;color:var(--t1);overflow-wrap:anywhere;word-break:normal;line-height:1.2;max-width:24ch;letter-spacing:-.025em}
  .gh-why{color:var(--t2);font-size:15px;line-height:1.7;margin:0;max-width:46ch}
  .gh-foot{
    margin-top:auto;
    padding-top:16px;
    display:flex;
    align-items:center;
    justify-content:flex-start;
    gap:14px;
    border-top:1px solid var(--border-soft);
    font-family:var(--mono);
    font-size:11px;
    letter-spacing:.08em;
    text-transform:uppercase;
  }
  .gh-foot-cta{
    color:var(--t1);
    display:inline-flex;
    align-items:center;
    gap:8px;
  }
  .gh-foot-cta::after{
    content:'→';
    color:var(--blue);
    transition:transform .2s ease-out;
  }
  .gh-card:hover .gh-foot-cta::after,
  .gh-card:focus-visible .gh-foot-cta::after{transform:translateX(3px)}
  .gh-card-primary .gh-head{grid-area:head}
  .gh-card-primary .gh-name{grid-area:name;font-size:clamp(27px,3vw,40px);max-width:25ch;letter-spacing:-.045em}
  .gh-card-primary .gh-why{grid-area:why;font-size:16px;max-width:48ch}
  .gh-card-primary .gh-foot{grid-area:foot;margin:0;padding:0 0 0 30px;justify-content:flex-end;border:0;border-left:1px solid var(--border-soft);align-self:stretch}
  @media(max-width:980px){
    .gh-card{grid-column:span 6}
    .gh-card-primary{grid-column:span 12;grid-template-columns:1fr auto;grid-template-areas:'head foot' 'name foot' 'why foot'}
  }
  @media(max-width:760px){
    .gh-card-primary{
      grid-template-columns:1fr;
      grid-template-areas:'head' 'name' 'why' 'foot';
      gap:14px;
    }
    .gh-card-primary .gh-foot{justify-content:flex-start;padding:16px 0 0;border:0;border-top:1px solid var(--border-soft)}
  }
  @media(max-width:640px){
    .gh-grid{grid-template-columns:1fr}
    .gh-card,.gh-card-primary{grid-column:auto;min-height:auto;padding:22px}
    .gh-card-primary .gh-name{font-size:26px}
    .gh-head{gap:8px}
    .gh-foot{align-items:flex-start;flex-direction:column}
  }
</style>
