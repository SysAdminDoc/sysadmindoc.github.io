---
import { greatestHits } from '../data/curated';
import { projectProof } from '../data/proof';
import StarSvg from './StarSvg.astro';

let stars: Record<string, number> = {};
try {
  const mod = await import('../data/_stars.json');
  stars = (mod.default ?? mod) as Record<string, number>;
} catch {}
---
<section id="greatest-hits" aria-label="Greatest hits">
  <div class="si">
    <div class="sh rv">
      <div class="sl">// Selected work</div>
      <h2 class="st">Selected work</h2>
      <p class="sd">{greatestHits.length} projects that best show the range.</p>
    </div>
    <div class="gh-grid">
      {greatestHits.map((hit, i) => {
        const hasCaseStudy = !!projectProof[hit.repo]?.caseStudy;
        return (
        <a href={`/projects/${hit.repo}/`} class={`gh-card card-enter${i === 0 ? ' gh-card-primary' : ''}`} data-repo={hit.repo}>
          <div class="gh-head">
            <span class="gh-rank">★ {String(i + 1).padStart(2, '0')}</span>
            <span class="gh-tag">{hit.tag}</span>
            {stars[hit.repo] ? (
              <span class="gh-stars"><StarSvg /> {stars[hit.repo]}</span>
            ) : null}
          </div>
          <h3 class="gh-name">{hit.name}</h3>
          <p class="gh-why">{hit.why}</p>
          <div class="gh-foot">
            <span class="gh-foot-cta">{hasCaseStudy ? 'Read the case study' : 'Open the build story'}</span>
          </div>
        </a>
        );
      })}
    </div>
  </div>
</section>

<style>
  .gh-grid{
    display:grid;
    grid-template-columns:repeat(12,minmax(0,1fr));
    gap:0 28px;
    max-width:1200px;
    margin:0 auto;
  }
  .gh-card{
    grid-column:span 4;
    display:flex;
    flex-direction:column;
    justify-content:flex-end;
    gap:14px;
    min-height:220px;
    padding:22px 0;
    border:0;
    border-top:1px solid var(--border-soft);
    border-radius:0;
    background:transparent;
    text-decoration:none;
    position:relative;
    overflow:visible;
    box-shadow:none;
    transition:transform .4s cubic-bezier(.16,1,.3,1),box-shadow .4s cubic-bezier(.16,1,.3,1),border-color .25s ease,background .4s cubic-bezier(.16,1,.3,1);
  }
  .gh-card::before{
    display:none;
  }
  .gh-card::after{
    display:none;
  }
  .gh-card:hover{border-color:var(--border-strong);transform:none;box-shadow:none}
  .gh-card:focus-visible{outline:2px solid var(--grn);outline-offset:3px}
  .gh-card-primary{
    grid-column:span 12;
    min-height:240px;
    padding:28px 0;
    background:transparent;
    box-shadow:none;
  }
  .gh-head{display:flex;align-items:center;gap:10px;flex-wrap:wrap}
  .gh-rank{font-family:var(--mono);font-size:11px;letter-spacing:.14em;color:var(--org);font-weight:700}
  .gh-tag{font-family:var(--mono);font-size:12px;color:var(--t3);padding:0;border:0;border-radius:0;letter-spacing:.06em;text-transform:uppercase;background:transparent}
  .gh-stars{margin-left:auto;display:inline-flex;align-items:center;gap:4px;font-family:var(--mono);font-size:12px;color:var(--yel)}
  .gh-stars svg{width:12px;height:12px;fill:currentColor}
  .gh-name{font-family:var(--mono);font-size:20px;font-weight:600;color:var(--t1);word-break:break-word;line-height:1.15;max-width:18ch}
  .gh-why{color:var(--t2);font-size:15px;line-height:1.7;margin:0;max-width:42ch}
  .gh-foot{
    margin-top:auto;
    padding-top:8px;
    display:flex;
    align-items:center;
    justify-content:flex-end;
    gap:14px;
    border-top:0;
    font-family:var(--mono);
    font-size:12px;
    letter-spacing:.08em;
    text-transform:uppercase;
  }
  .gh-foot-cta{
    color:var(--t1);
    display:inline-flex;
    align-items:center;
    gap:8px;
  }
  .gh-foot-cta::after{
    content:'→';
    color:var(--blue);
    transition:transform .2s ease-out;
  }
  .gh-card:hover .gh-foot-cta::after,
  .gh-card:focus-visible .gh-foot-cta::after{transform:translateX(3px)}
  .gh-card-primary .gh-name{font-size:clamp(30px,4.4vw,42px);max-width:12ch;letter-spacing:-.05em}
  .gh-card-primary .gh-why{font-size:16px;max-width:58ch}
  @media(max-width:980px){
    .gh-card{grid-column:span 6}
    .gh-card-primary{grid-column:span 12}
  }
  @media(max-width:640px){
    .gh-grid{grid-template-columns:1fr}
    .gh-card,.gh-card-primary{grid-column:auto;min-height:auto;padding:22px}
    .gh-card-primary .gh-name{font-size:28px}
    .gh-head{gap:8px}
    .gh-foot{align-items:flex-start;flex-direction:column}
  }
</style>
