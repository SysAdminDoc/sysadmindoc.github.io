---
import { greatestHits } from '../data/curated';
import { catalog } from '../data/projects';
import StarSvg from './StarSvg.astro';

let stars: Record<string, number> = {};
try {
  const mod = await import('../data/_stars.json');
  stars = (mod.default ?? mod) as Record<string, number>;
} catch {}
---
<section id="greatest-hits" aria-label="Greatest hits">
  <div class="si">
    <div class="sh rv">
      <div class="sl">// Greatest Hits</div>
      <h2 class="st">The ones that matter most</h2>
      <p class="sd">{greatestHits.length} out of {catalog.length}. The through-line of my work — why each exists, not what it does.</p>
    </div>
    <div class="gh-grid">
      {greatestHits.map((hit, i) => (
        <a href={`/projects/${hit.repo}/`} class={`gh-card card-enter${i === 0 ? ' gh-card-primary' : ''}`} data-repo={hit.repo}>
          <div class="gh-head">
            <span class="gh-rank">★ {String(i + 1).padStart(2, '0')}</span>
            <span class="gh-tag">{hit.tag}</span>
            {stars[hit.repo] ? (
              <span class="gh-stars"><StarSvg /> {stars[hit.repo]}</span>
            ) : null}
          </div>
          <h3 class="gh-name">{hit.name}</h3>
          <p class="gh-why">{hit.why}</p>
          <div class="gh-foot">
            <span class="gh-foot-label">{i === 0 ? 'Lead case study' : 'Project brief'}</span>
            <span class="gh-foot-cta">{i === 0 ? 'Open flagship project' : 'Open the build story'}</span>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .gh-grid{
    display:grid;
    grid-template-columns:repeat(12,minmax(0,1fr));
    gap:18px;
    max-width:1200px;
    margin:0 auto;
  }
  .gh-card{
    grid-column:span 4;
    display:flex;
    flex-direction:column;
    justify-content:flex-end;
    gap:14px;
    min-height:250px;
    padding:28px;
    border:1px solid rgba(255,255,255,.08);
    border-radius:24px;
    background:linear-gradient(180deg, rgba(255,255,255,.045), rgba(255,255,255,.02));
    text-decoration:none;
    position:relative;
    overflow:hidden;
    box-shadow:0 18px 42px rgba(0,0,0,.18);
    transition:border-color .3s ease-out,transform .3s ease-out,box-shadow .3s ease-out,background .3s ease-out;
  }
  .gh-card::before{
    content:'';
    position:absolute;
    inset:0;
    pointer-events:none;
    background:
      radial-gradient(circle at top right, rgba(124,184,255,.22), transparent 34%),
      radial-gradient(circle at bottom left, rgba(198,156,255,.14), transparent 30%);
    opacity:.9;
  }
  .gh-card::after{
    content:'';
    position:absolute;
    inset:1px;
    border-radius:22px;
    border:1px solid rgba(255,255,255,.04);
    pointer-events:none;
  }
  .gh-card:hover{border-color:rgba(255,255,255,.14);transform:translateY(-5px);box-shadow:0 26px 58px rgba(0,0,0,.25)}
  .gh-card:focus-visible{outline:2px solid var(--grn);outline-offset:3px;box-shadow:0 0 0 4px rgba(74,222,128,.15)}
  .gh-card-primary{
    grid-column:span 12;
    min-height:340px;
    padding:36px;
  }
  .gh-head{display:flex;align-items:center;gap:10px;flex-wrap:wrap}
  .gh-rank{font-family:var(--mono);font-size:11px;letter-spacing:.14em;color:var(--org);font-weight:700}
  .gh-tag{font-family:var(--mono);font-size:10px;color:var(--t2);padding:5px 10px;border:1px solid rgba(255,255,255,.08);border-radius:999px;letter-spacing:.08em;text-transform:uppercase;background:rgba(255,255,255,.03)}
  .gh-stars{margin-left:auto;display:inline-flex;align-items:center;gap:4px;font-family:var(--mono);font-size:12px;color:var(--yel)}
  .gh-stars svg{width:12px;height:12px;fill:currentColor}
  .gh-name{font-family:var(--mono);font-size:20px;font-weight:600;color:var(--t1);word-break:break-word;line-height:1.15;max-width:18ch}
  .gh-why{color:var(--t2);font-size:15px;line-height:1.7;margin:0;max-width:42ch}
  .gh-foot{
    margin-top:auto;
    padding-top:18px;
    display:flex;
    align-items:center;
    justify-content:space-between;
    gap:14px;
    border-top:1px solid rgba(255,255,255,.08);
    font-family:var(--mono);
    font-size:11px;
    letter-spacing:.08em;
    text-transform:uppercase;
  }
  .gh-foot-label{color:var(--t3)}
  .gh-foot-cta{
    color:var(--t1);
    display:inline-flex;
    align-items:center;
    gap:8px;
  }
  .gh-foot-cta::after{
    content:'→';
    color:var(--blue);
    transition:transform .2s ease-out;
  }
  .gh-card:hover .gh-foot-cta::after,
  .gh-card:focus-visible .gh-foot-cta::after{transform:translateX(3px)}
  .gh-card-primary .gh-name{font-size:clamp(30px,4.4vw,42px);max-width:12ch;letter-spacing:-.05em}
  .gh-card-primary .gh-why{font-size:16px;max-width:58ch}
  @media(max-width:980px){
    .gh-card{grid-column:span 6}
    .gh-card-primary{grid-column:span 12}
  }
  @media(max-width:640px){
    .gh-grid{grid-template-columns:1fr}
    .gh-card,.gh-card-primary{grid-column:auto;min-height:auto;padding:22px}
    .gh-card-primary .gh-name{font-size:28px}
    .gh-head{gap:8px}
    .gh-foot{align-items:flex-start;flex-direction:column}
  }
</style>
