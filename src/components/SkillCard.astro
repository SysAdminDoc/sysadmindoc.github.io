---
import type { Skill } from '../data/types';
export interface Props { skill: Skill; }
const { skill } = Astro.props;

// Map skill name → per-language landing page slug (only those with pages)
const langMap: Record<string, string> = {
  'PowerShell': 'powershell',
  'Python': 'python',
  'JavaScript': 'javascript',
  'Kotlin': 'kotlin',
  'C#': 'cs',
};
const fallbackHrefMap: Record<string, string> = {
  'C#': '/?cat=cs#catalog',
  'C++': '/?cat=cs#catalog',
  'HTML / CSS': '/?cat=web#catalog',
  pfSense: '/?cat=sec#catalog',
};
const slug = langMap[skill.name];
const href = slug ? `/lang/${slug}/` : fallbackHrefMap[skill.name];
const Tag = href ? 'a' : 'div';
const extra = href ? { href } : {};
const footLabel = slug ? 'Open track →' : href ? 'Open matches →' : 'Reference only';
const metricText = skill.metric ? `${skill.metric.label} - ${skill.metric.percent}% of catalog` : null;
const skillTone = skill.color.startsWith('--') ? skill.color.slice(2) : 'blue';
---
<Tag class="skc card-enter" {...extra}>
  <div class={`sk-ring sk-tone-${skillTone}`} data-ring-target={skill.ringTarget} aria-label={metricText ?? undefined}>
    <svg viewBox="0 0 76 76">
      <circle class="ring-bg" cx="38" cy="38" r="32.5" />
      <circle class="ring-fg" cx="38" cy="38" r="32.5" stroke={`var(${skill.color})`} />
    </svg>
    <div class="sk-ring-label" set:html={skill.code}></div>
  </div>
  <div class="skn">{skill.name}</div>
  <div class="sks">{skill.sub}</div>
  {metricText && <div class="skc-stat">{metricText}</div>}
  <div class="skc-foot">
    <span class="skc-meta">{slug ? 'Guided track' : 'Filtered archive'}</span>
    <div class={`skc-more${href ? '' : ' static'}`}>{footLabel}</div>
  </div>
</Tag>

<style>
  a.skc{text-decoration:none;color:inherit}
  .skc-foot{
    margin-top:14px;
    padding-top:12px;
    border-top:1px solid var(--border-soft);
    display:flex;
    align-items:center;
    justify-content:space-between;
    gap:10px;
    font-family:var(--mono);
    font-size:10px;
    letter-spacing:.06em;
    text-transform:uppercase;
  }
  .skc-meta{color:var(--t3)}
  .skc-stat{
    margin-top:8px;
    color:var(--t3);
    font-family:var(--mono);
    font-size:11px;
    line-height:1.4;
  }
  .skc-more{color:var(--t1);transition:color .2s ease-out,transform .2s ease-out}
  .skc-more.static{color:var(--t3)}
  .sk-tone-blue .sk-ring-label{color:var(--blue)}
  .sk-tone-grn .sk-ring-label{color:var(--grn)}
  .sk-tone-yel .sk-ring-label{color:var(--yel)}
  .sk-tone-teal .sk-ring-label{color:var(--teal)}
  .sk-tone-pur .sk-ring-label{color:var(--pur)}
  .sk-tone-red .sk-ring-label{color:var(--red)}
  .sk-tone-org .sk-ring-label{color:var(--org)}
  a.skc:hover .skc-more,
  a.skc:focus-visible .skc-more{color:var(--grn);transform:translateX(2px)}
</style>
