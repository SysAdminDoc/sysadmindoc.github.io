---
import crypto from 'node:crypto';
import globalCssUrl from '../styles/global.css?url';
import criticalCss from '../styles/critical.css?raw';
import type { CmdkSection } from '../data/cmdk';

export interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogImageAlt?: string;
  cmdkSections?: readonly CmdkSection[];
}

const defaultCmdkSections: CmdkSection[] = [
  { label: 'Home', href: '/', desc: 'Return to the portfolio overview and first-run poster view.', badge: 'HOME' },
  { label: 'Highlights', href: '/#greatest-hits', desc: 'Start with the shortest path through the strongest work.', badge: 'START' },
  { label: 'Catalog', href: '/#catalog', desc: 'Browse every public project with filters, search, and freshness signals.', badge: 'ARCHIVE' },
  { label: 'Full-Text Search', href: '/search/', desc: 'Search rendered project pages, README excerpts, routes, and project metadata.', badge: 'PAGE' },
  { label: 'Live Apps', href: '/#live', desc: 'Jump straight into browser-ready builds with no setup wall.', badge: 'LIVE' },
  { label: 'Releases', href: '/releases/', desc: 'See what is shipping across the most active projects.', badge: 'PAGE' },
  { label: 'Timeline', href: '/timeline/', desc: 'Review yearly momentum across releases and project pushes.', badge: 'PAGE' },
  { label: 'Archive Decisions', href: '/archive/', desc: 'Read why retired, held, or superseded project surfaces moved out of view.', badge: 'PAGE' },
  { label: 'Now', href: '/now/', desc: 'Open the current focus page and short-range work queue.', badge: 'PAGE' },
  { label: 'Uses', href: '/uses/', desc: 'Development environment, tools, and design conventions.', badge: 'PAGE' },
  { label: 'Resume', href: '/resume/', desc: 'Printable career summary with skills and experience.', badge: 'PAGE' },
  { label: 'Healthcare IT', href: '/healthcare-it/', desc: 'Operational context, imaging systems, and production-first tooling.', badge: 'TRACK' },
];
const {
  title = 'Matt Parker — Senior Technical Support Manager & Builder',
  description = 'Portfolio of Matt Parker — 15+ years in enterprise IT, six years in medical imaging (DICOM/PACS), plus open-source projects across PowerShell, Python, JavaScript, Kotlin, C#, and C++.',
  ogImage = '/og.png',
  ogImageAlt = description,
  cmdkSections = defaultCmdkSections,
} = Astro.props;
const ogImageUrl = new URL(ogImage, Astro.site).toString();

const canonical = new URL(Astro.url.pathname, Astro.site).toString();
const isHome = Astro.url.pathname === '/';
const bodyClass = isHome ? 'route-home' : 'route-interior';
const noJsRevealCss = '.rv,.card-enter{opacity:1!important;transform:none!important}';

function sha256Csp(value: string) {
  return `sha256-${crypto.createHash('sha256').update(value).digest('base64')}`;
}

const styleElemSrc = ["'self'", `'${sha256Csp(criticalCss)}'`, `'${sha256Csp(noJsRevealCss)}'`].join(' ');
const contentSecurityPolicy = `default-src 'self'; script-src 'self'; style-src 'self'; style-src-elem ${styleElemSrc}; style-src-attr 'none'; font-src 'self'; img-src 'self' data: https://avatars.githubusercontent.com https://opengraph.githubassets.com https://img.youtube.com https://raw.githubusercontent.com; connect-src 'self' https://api.github.com; frame-src https://www.youtube-nocookie.com; object-src 'none'; base-uri 'self'; form-action 'self'`;

// One connected knowledge graph: a stable Person @id referenced by WebSite
// (publisher) and, on the homepage, a ProfilePage. Page-level schemas
// (BreadcrumbList, CollectionPage) reference the same @ids.
const personId = 'https://sysadmindoc.github.io/#matt-parker';
const jsonLdGraph: Record<string, unknown>[] = [
  {
    '@type': 'WebSite',
    '@id': 'https://sysadmindoc.github.io/#website',
    url: 'https://sysadmindoc.github.io',
    name: 'Matt Parker Portfolio',
    description: 'Open-source projects spanning PowerShell, Python, JavaScript, Kotlin, C#, and C++.',
    publisher: { '@id': personId },
  },
  {
    '@type': 'Person',
    '@id': personId,
    name: 'Matt Parker',
    url: 'https://github.com/SysAdminDoc',
    jobTitle: 'Senior Technical Support Manager',
    worksFor: { '@type': 'Organization', name: 'Maven Imaging' },
    address: { '@type': 'PostalAddress', addressLocality: 'Sarasota', addressRegion: 'FL', addressCountry: 'US' },
    knowsAbout: ['PowerShell','Python','JavaScript','Kotlin','C#','C++','Systems Administration','Medical Imaging','DICOM','PACS','Active Directory','Hyper-V','Cisco Networking','HIPAA'],
    sameAs: ['https://github.com/SysAdminDoc','https://www.linkedin.com/in/matthewryanparker'],
  },
];
if (isHome) {
  jsonLdGraph.push({
    '@type': 'ProfilePage',
    '@id': 'https://sysadmindoc.github.io/#profile',
    url: 'https://sysadmindoc.github.io/',
    name: title,
    mainEntity: { '@id': personId },
    about: { '@id': personId },
  });
}
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="color-scheme" content="dark light" />
  <meta name="theme-color" content="#050913" />
  <meta name="mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-title" content="SysAdminDoc" />
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
  <meta http-equiv="Content-Security-Policy" content={contentSecurityPolicy} />
  <meta name="referrer" content="strict-origin-when-cross-origin" />
  <meta name="generator" content={Astro.generator} />

  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonical} />
  <meta property="og:site_name" content="Matt Parker Portfolio" />
  <meta property="og:image" content={ogImageUrl} />
  <meta property="og:image:type" content="image/png" />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:alt" content={ogImageAlt} />

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:image" content={ogImageUrl} />
  <meta name="twitter:image:alt" content={ogImageAlt} />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />

  <link rel="canonical" href={canonical} />
  <link rel="preload" href="/fonts/outfit-latin.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="preload" href="/fonts/jetbrains-mono-latin.woff2" as="font" type="font/woff2" crossorigin />
  <style is:inline set:html={criticalCss}></style>
  <link rel="preload" href={globalCssUrl} as="style" />
  <link rel="stylesheet" href={globalCssUrl} media="print" data-async-style />
  <script src="/scripts/head-init.js" is:inline></script>
  <script src="/scripts/theme-toggle.js" is:inline></script>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" type="image/png" sizes="192x192" href="/icon-192.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  <link rel="alternate" type="application/rss+xml" title="Matt Parker — recent projects" href="/rss.xml" />
  <link rel="alternate" type="application/rss+xml" title="Matt Parker — releases" href="/releases.xml" />
  <link rel="alternate" type="application/atom+xml" title="Matt Parker — projects (Atom)" href="/atom.xml" />
  <link rel="alternate" type="application/feed+json" title="Matt Parker — projects (JSON Feed)" href="/feed.json" />
  <link rel="alternate" type="application/json" title="Matt Parker — project index" href="/projects.json" />
  <link rel="alternate" type="application/json" title="Matt Parker — release index" href="/releases.json" />
  <link rel="preconnect" href="https://api.github.com" crossorigin />
  <link rel="dns-prefetch" href="https://api.github.com" />
  <link rel="dns-prefetch" href="https://img.youtube.com" />
  <link rel="dns-prefetch" href="https://opengraph.githubassets.com" />
  <link rel="manifest" href="/manifest.json" />
  {/* Fonts self-hosted in public/fonts/ and declared in critical.css + global.css */}
  <noscript>
    <link rel="stylesheet" href={globalCssUrl} />
    <style is:inline set:html={noJsRevealCss}></style>
  </noscript>

</head>
<body class={bodyClass}>
  {/* JSON-LD lives at the top of <body> (valid, and avoids any content landing
      between </head> and <body>, which breaks the Pagefind HTML parser). */}
  <script is:inline type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@graph': jsonLdGraph,
  })} />
  <slot />
  <dialog class="cmdk-backdrop" id="cmdk" aria-label="Command palette" aria-modal="true">
    <div class="cmdk">
      <div class="cmdk-input-row">
        <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <input class="cmdk-input" id="cmdkInput" type="search" name="command-search" placeholder="Search projects, pages, categories, or sections..." autocomplete="off" spellcheck="false" inputmode="search" enterkeyhint="search" aria-label="Search projects, pages, categories, and sections" aria-describedby="cmdkMeta" role="combobox" aria-autocomplete="list" aria-haspopup="listbox" aria-controls="cmdkList" aria-expanded="false" />
      </div>
      <div class="cmdk-meta" id="cmdkMeta" role="status" aria-live="polite">Start with the strongest work, a key route, or the full archive.</div>
      <div class="cmdk-list" id="cmdkList" role="listbox" aria-label="Command results"></div>
      <div class="cmdk-footer" aria-hidden="true">
        <span>Choose a result to open it.</span>
        <span>Projects, pages, categories, and sections are indexed.</span>
      </div>
    </div>
  </dialog>
  {/* Page-specific command-palette sections are inert JSON; the large project +
      quick-link dataset is served once as a cached /cmdk-data.js (loaded next).
      The controller itself is lazy-loaded by cmdk-loader.js on first activation. */}
  <script is:inline type="application/json" id="cmdk-sections-data" set:html={JSON.stringify(cmdkSections)} />
  <script src="/cmdk-data.js" is:inline></script>
  <script src="/scripts/shared.js" is:inline></script>
  <script src="/scripts/cmdk-loader.js" is:inline></script>
  <script src="/scripts/relative-time.js" is:inline></script>
  <script src="/scripts/mobile-nav.js" is:inline></script>
  <script src="/scripts/scroll-reveal.js" is:inline></script>
  {/* main.js is homepage-only and depends on shared.js globals
      (prefersReducedMotion/escapeHTML) + __PORTFOLIO_DATA, so it MUST load last,
      after shared.js + cmdk-data.js. Loading it from the page slot ran it first
      and threw a ReferenceError that killed all homepage interactivity. */}
  {isHome && <script src="/scripts/main.js" is:inline></script>}
</body>
</html>
