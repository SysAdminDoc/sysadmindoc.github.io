---
import '../styles/global.css';
import { catalog, featured, liveApps } from '../data/projects';
import { categoryLabels } from '../data/categories';

type CmdkSection = {
  label: string;
  href: string;
  desc?: string;
  badge?: string;
};

type CmdkProject = {
  slug: string;
  name: string;
  desc: string;
  type: 'featured' | 'live' | 'catalog';
  url: string;
  category?: string;
  categoryLabel?: string;
  searchTerms?: string[];
};

export interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogImageAlt?: string;
  cmdkSections?: readonly CmdkSection[];
}

const normalizeCmdkDesc = (value: string) => value.replace(/&[a-z]+;/gi, ' ');
const cmdkProjectMap = new Map<string, CmdkProject>();
function upsertCmdkProject(slug: string, next: CmdkProject) {
  const existing = cmdkProjectMap.get(slug);
  const searchTerms = Array.from(
    new Set([...(existing?.searchTerms ?? []), ...(next.searchTerms ?? [])].filter(Boolean)),
  );
  cmdkProjectMap.set(slug, {
    ...existing,
    ...next,
    category: next.category ?? existing?.category,
    categoryLabel: next.categoryLabel ?? existing?.categoryLabel,
    searchTerms: searchTerms.length ? searchTerms : undefined,
  });
}
for (const project of catalog) {
  upsertCmdkProject(project.repo, {
    slug: project.repo,
    name: project.name,
    desc: normalizeCmdkDesc(project.desc),
    type: 'catalog',
    url: `/projects/${project.repo}/`,
    category: project.category,
    categoryLabel: categoryLabels[project.category] ?? project.category,
    searchTerms: [project.category, categoryLabels[project.category] ?? project.category],
  });
}
for (const app of liveApps) {
  upsertCmdkProject(app.slug, {
    slug: app.slug,
    name: app.name,
    desc: normalizeCmdkDesc(app.desc),
    type: 'live',
    url: `/projects/${app.slug}/`,
    searchTerms: ['Live Apps', 'Live App', 'Browser'],
  });
}
for (const project of featured) {
  upsertCmdkProject(project.repo, {
    slug: project.repo,
    name: project.name,
    desc: normalizeCmdkDesc(project.desc),
    type: 'featured',
    url: `/projects/${project.repo}/`,
    searchTerms: project.tags,
  });
}
const cmdkProjects = Array.from(cmdkProjectMap.values());
const defaultCmdkSections: CmdkSection[] = [
  { label: 'Home', href: '/', desc: 'Return to the portfolio overview and first-run poster view.', badge: 'HOME' },
  { label: 'Highlights', href: '/#greatest-hits', desc: 'Start with the shortest path through the strongest work.', badge: 'START' },
  { label: 'Catalog', href: '/#catalog', desc: 'Browse every public project with filters, search, and freshness signals.', badge: 'ARCHIVE' },
  { label: 'Full-Text Search', href: '/search/', desc: 'Search rendered project pages, README excerpts, routes, and project metadata.', badge: 'PAGE' },
  { label: 'Live Apps', href: '/#live', desc: 'Jump straight into browser-ready builds with no setup wall.', badge: 'LIVE' },
  { label: 'Releases', href: '/releases/', desc: 'See what is shipping across the most active projects.', badge: 'PAGE' },
  { label: 'Timeline', href: '/timeline/', desc: 'Review yearly momentum across releases, project pushes, and changelog highlights.', badge: 'PAGE' },
  { label: 'Archive Decisions', href: '/archive/', desc: 'Read why retired, held, or superseded project surfaces moved out of view.', badge: 'PAGE' },
  { label: 'Now', href: '/now/', desc: 'Open the current focus page and short-range work queue.', badge: 'PAGE' },
  { label: 'Uses', href: '/uses/', desc: 'Development environment, tools, and design conventions.', badge: 'PAGE' },
  { label: 'Resume', href: '/resume/', desc: 'Printable career summary with skills and experience.', badge: 'PAGE' },
  { label: 'Healthcare IT', href: '/healthcare-it/', desc: 'Operational context, imaging systems, and production-first tooling.', badge: 'TRACK' },
];
const cmdkQuickLinks = [
  {
    label: 'Full-Text Search',
    url: '/search/',
    desc: 'Search rendered project pages, README excerpts, language tracks, release history, and archive decisions.',
    badge: 'PAGE',
    tone: 'green',
    searchTerms: ['pagefind', 'full text', 'readme search', 'site search'],
  },
  {
    label: 'Releases',
    url: '/releases/',
    desc: 'Chronological release stream across the most active projects in the archive.',
    badge: 'PAGE',
    tone: 'blue',
    searchTerms: ['shipping', 'updates', 'release stream'],
  },
  {
    label: 'Timeline',
    url: '/timeline/',
    desc: 'Year-in-review view generated from releases, repository movement, and changelog entries.',
    badge: 'PAGE',
    tone: 'blue',
    searchTerms: ['year in review', 'history', 'momentum', 'timeline'],
  },
  {
    label: 'Archive Decisions',
    url: '/archive/',
    desc: 'Public-safe anti-portfolio notes for retired, moved, held, or superseded project surfaces.',
    badge: 'PAGE',
    tone: 'amber',
    searchTerms: ['archive', 'retired projects', 'anti portfolio', 'removed projects'],
  },
  {
    label: 'Now',
    url: '/now/',
    desc: 'Current build queue, focus areas, and the latest signals from the portfolio.',
    badge: 'PAGE',
    tone: 'green',
    searchTerms: ['current focus', 'working on now'],
  },
  {
    label: 'Uses',
    url: '/uses/',
    desc: 'Development environment, tools, languages, frameworks, and design conventions.',
    badge: 'PAGE',
    tone: 'blue',
    searchTerms: ['setup', 'tools', 'stack', 'environment', 'uses.tech'],
  },
  {
    label: 'Resume',
    url: '/resume/',
    desc: 'Printable career summary with skills, experience, and technology stacks.',
    badge: 'PAGE',
    tone: 'blue',
    searchTerms: ['cv', 'career', 'hire', 'experience', 'printable'],
  },
  {
    label: 'Healthcare IT Track',
    url: '/healthcare-it/',
    desc: 'Operational context, imaging systems, and the environment that shaped the work.',
    badge: 'TRACK',
    tone: 'amber',
    searchTerms: ['clinical', 'medical imaging', 'healthcare'],
  },
  {
    label: 'GitHub Workspace',
    url: 'https://github.com/SysAdminDoc',
    desc: 'Browse the source, issues, and project history directly in GitHub.',
    badge: 'SOURCE',
    tone: 'slate',
    external: true,
    searchTerms: ['source', 'github', 'issues'],
  },
] as const;

const {
  title = 'Matt Parker — Senior Technical Support Manager & Builder',
  description = 'Portfolio of Matt Parker — 15+ years in enterprise IT, six years in medical imaging (DICOM/PACS), plus open-source projects across PowerShell, Python, JavaScript, Kotlin, C#, and C++.',
  ogImage = '/og.png',
  ogImageAlt = description,
  cmdkSections = defaultCmdkSections,
} = Astro.props;
const ogImageUrl = new URL(ogImage, Astro.site).toString();

const canonical = new URL(Astro.url.pathname, Astro.site).toString();
const bodyClass = Astro.url.pathname === '/' ? 'route-home' : 'route-interior';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="color-scheme" content="dark light" />
  <meta name="theme-color" content="#050913" />
  <meta http-equiv="Content-Security-Policy" content="default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; font-src 'self'; img-src 'self' data: https://avatars.githubusercontent.com https://opengraph.githubassets.com https://i.scdn.co https://img.youtube.com https://raw.githubusercontent.com; connect-src 'self' https://api.github.com; frame-src https://www.youtube-nocookie.com; object-src 'none'; base-uri 'self'" />
  <meta name="generator" content={Astro.generator} />

  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonical} />
  <meta property="og:site_name" content="Matt Parker Portfolio" />
  <meta property="og:image" content={ogImageUrl} />
  <meta property="og:image:type" content="image/png" />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:alt" content={ogImageAlt} />

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:image" content={ogImageUrl} />
  <meta name="twitter:image:alt" content={ogImageAlt} />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />

  <link rel="canonical" href={canonical} />
  <link rel="preload" href="/fonts/outfit-latin.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="preload" href="/fonts/jetbrains-mono-latin.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" type="image/png" sizes="192x192" href="/icon-192.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  <link rel="alternate" type="application/rss+xml" title="Matt Parker — recent projects" href="/rss.xml" />
  <link rel="alternate" type="application/json" title="Matt Parker — project index" href="/projects.json" />
  <link rel="alternate" type="application/json" title="Matt Parker — release index" href="/releases.json" />
  <link rel="preconnect" href="https://api.github.com" crossorigin />
  <link rel="preconnect" href="https://i.scdn.co" crossorigin />
  <link rel="dns-prefetch" href="https://api.github.com" />
  <link rel="dns-prefetch" href="https://i.scdn.co" />
  <link rel="dns-prefetch" href="https://img.youtube.com" />
  <link rel="dns-prefetch" href="https://www.youtube.com" />
  <link rel="dns-prefetch" href="https://opengraph.githubassets.com" />
  <link rel="manifest" href="/manifest.json" />
  {/* Fonts self-hosted in public/fonts/ — @font-face rules in global.css */}
  <noscript><style>.rv,.card-enter{opacity:1!important;transform:none!important}</style></noscript>

  {/* Theme init must run BEFORE first paint to avoid FOUC. Inline, sync, tiny. */}
  <script is:inline>try{var t=localStorage.getItem('theme-pref');var isLight=t==='light';document.documentElement.dataset.theme=isLight?'light':'dark';var m=document.querySelector('meta[name="theme-color"]');if(m)m.setAttribute('content',isLight?'#f5f1e8':'#050913')}catch(e){document.documentElement.dataset.theme='dark'}</script>

  <script is:inline type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@graph': [
      { '@type': 'WebSite', url: 'https://sysadmindoc.github.io', name: 'Matt Parker Portfolio', description: 'Open-source projects spanning PowerShell, Python, JavaScript, Kotlin, C#, and C++.' },
      { '@type': 'Person', name: 'Matt Parker', url: 'https://github.com/SysAdminDoc', jobTitle: 'Senior Technical Support Manager', worksFor: { '@type': 'Organization', name: 'Maven Imaging' }, address: { '@type': 'PostalAddress', addressLocality: 'Sarasota', addressRegion: 'FL', addressCountry: 'US' }, knowsAbout: ['PowerShell','Python','JavaScript','Kotlin','C#','C++','Systems Administration','Medical Imaging','DICOM','PACS','Active Directory','Hyper-V','Cisco Networking','HIPAA'], sameAs: ['https://github.com/SysAdminDoc','https://www.linkedin.com/in/matthewryanparker'] }
    ]
  })} />
</head>
<body class={bodyClass}>
  <slot />
  <dialog class="cmdk-backdrop" id="cmdk" aria-label="Command palette">
    <div class="cmdk">
      <div class="cmdk-input-row">
        <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <input class="cmdk-input" id="cmdkInput" type="search" name="command-search" placeholder="Jump to a project, page, category, or section…" autocomplete="off" spellcheck="false" inputmode="search" enterkeyhint="search" aria-label="Search projects, pages, categories, and sections" aria-describedby="cmdkMeta" role="combobox" aria-autocomplete="list" aria-haspopup="listbox" aria-controls="cmdkList" aria-expanded="false" />
        <span class="cmdk-kbd">Esc</span>
      </div>
      <div class="cmdk-meta" id="cmdkMeta" role="status" aria-live="polite">Start with the strongest work, a key route, or the full archive.</div>
      <div class="cmdk-list" id="cmdkList" role="listbox" aria-label="Command results"></div>
      <div class="cmdk-footer" aria-hidden="true">
        <span><kbd>Enter</kbd> Open</span>
        <span><kbd>↑</kbd><kbd>↓</kbd> Move</span>
        <span><kbd>Esc</kbd> Close</span>
      </div>
    </div>
  </dialog>
  <script is:inline define:vars={{ allProjects: cmdkProjects, quickLinks: cmdkQuickLinks, sections: cmdkSections }}>
    window.__PORTFOLIO_DATA = { allProjects, quickLinks, sections };
  </script>
  <script src="/scripts/shared.js" is:inline></script>
  <script src="/scripts/cmdk.js" is:inline></script>
  <script src="/scripts/theme.js" is:inline></script>
</body>
</html>
