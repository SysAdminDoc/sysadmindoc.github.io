---
import Base from '../layouts/Base.astro';
import Divider from '../components/Divider.astro';
import InteriorNav from '../components/InteriorNav.astro';
import SectionJumpNav from '../components/SectionJumpNav.astro';
import StarSvg from '../components/StarSvg.astro';
import { healthcareIT } from '../data/curated';
import { interiorOgPageBySlug } from '../data/interior-og-pages';
import { formatReviewedDate, pageFreshnessBySlug, reviewedWebPageJsonLd } from '../data/page-freshness';
import { catalog, featured, liveApps } from '../data/portfolio';
import { githubRepoUrl } from '../data/github';

const title = 'Healthcare IT — Matt Parker';
const pageOg = interiorOgPageBySlug['healthcare-it'];
const pageFreshness = pageFreshnessBySlug['healthcare-it'];
const reviewedLabel = formatReviewedDate(pageFreshness.lastReviewed);
const siteUrl = Astro.site?.toString().replace(/\/$/, '') || 'https://sysadmindoc.github.io';
const pageJsonLd = reviewedWebPageJsonLd({
  siteUrl,
  route: pageFreshness.route,
  title,
  description: pageOg.description,
  lastReviewed: pageFreshness.lastReviewed,
  schemaTypes: pageFreshness.schemaTypes,
});
let stars: Record<string, number> = {};
try { const mod = await import('../data/_stars.json'); stars = (mod.default ?? mod) as Record<string, number>; } catch {}

const repos = healthcareIT.repos.map((slug) => {
  const f = featured.find((p) => p.repo === slug);
  const c = catalog.find((x) => x.repo === slug);
  const l = liveApps.find((a) => a.slug === slug);
  return {
    slug,
    name: f?.name ?? c?.name ?? l?.name ?? slug,
    desc: f?.desc ?? c?.desc ?? l?.desc ?? 'Project details live on GitHub.',
    stars: stars[slug] ?? 0,
    lane: 'Healthcare IT',
    liveUrl: l?.url,
    repositoryUrl: githubRepoUrl(slug),
  };
});
const hasRepos = repos.length > 0;
const cmdkSections = hasRepos
  ? [
      { label: 'Overview', href: '#track-overview', desc: 'Healthcare support summary, headline metrics, and route actions.', badge: 'TRACK' },
      { label: 'Projects', href: '#support-projects', desc: 'Healthcare IT projects shaped by migration, support, and operations workflows.', badge: 'ARCHIVE' },
      { label: 'Why This Track Exists', href: '#track-context', desc: 'The operating context and product philosophy behind this lane.', badge: 'CONTEXT' },
    ]
  : [
      { label: 'Overview', href: '#track-overview', desc: 'Healthcare support summary, headline metrics, and route actions.', badge: 'TRACK' },
      { label: 'Why This Track Exists', href: '#track-context', desc: 'The operating context and product philosophy behind this lane.', badge: 'CONTEXT' },
    ];
---
<Base
  title={title}
  description={pageOg.description}
  ogImage={pageOg.ogImage}
  ogImageAlt={pageOg.ogImageAlt}
  cmdkSections={cmdkSections}
>
  <script is:inline type="application/ld+json" set:html={pageJsonLd} />
  <a href="#main" class="skip-link">Skip to content</a>
  <InteriorNav active="healthcare" contextLabel="Healthcare IT track" contextTone="amber" />

  <main id="main" class="hcit-page" data-pagefind-body data-pagefind-filter="Scope:Healthcare IT">
    <span aria-hidden="true" data-pagefind-ignore data-pagefind-meta="route_type:Healthcare IT"></span>
    <span aria-hidden="true" data-pagefind-ignore data-pagefind-meta="type:Healthcare IT"></span>
    <span aria-hidden="true" data-pagefind-ignore data-pagefind-meta="category:Portfolio"></span>
    <div class="si page-shell" id="track-overview">
      <div class="sh rv">
        <div class="sl">// Track</div>
        <h1 class="st hcit-title">Healthcare IT</h1>
        <p class="sd hcit-intro">{healthcareIT.intro}</p>
        <p class="page-updated"><span>Last updated</span><time datetime={pageFreshness.lastReviewed}>{reviewedLabel}</time></p>
      </div>

      <div class="hcit-stats page-stat-grid rv">
        <div class="hcit-stat page-stat">
          <div class="hcit-stat-num page-stat-value">Support</div>
          <div class="hcit-stat-label page-stat-label">Customer systems</div>
          <div class="page-stat-copy">Troubleshooting, workflow checks, migration coordination, and customer cutover validation.</div>
        </div>
        <div class="hcit-stat page-stat">
          <div class="hcit-stat-num page-stat-value">Endpoints</div>
          <div class="hcit-stat-label page-stat-label">Workstation support</div>
          <div class="page-stat-copy">Troubleshooting for customer workstations, networking, licensing, and vendor applications.</div>
        </div>
        <div class="hcit-stat page-stat">
          <div class="hcit-stat-num page-stat-value">Hosted</div>
          <div class="hcit-stat-label page-stat-label">Account access</div>
          <div class="page-stat-copy">Customer support for account access, hosted workflows, transition issues, and recovery communication.</div>
        </div>
      </div>
      <div class="hcit-actions page-actions rv">
        <a href="/resume/" class="btn bp">Open resume</a>
        <a href="/#connect" class="btn bg2">Contact</a>
      </div>
      <SectionJumpNav items={cmdkSections} />
    </div>
    <Divider />

    {!hasRepos && (
      <>
        <div class="si" id="support-projects">
          <h2 class="hcit-h2">Projects in this track</h2>
          <div class="hcit-why rv">
            <p>Most healthcare support work is <strong>operational and customer-specific</strong>: migration notes, workstation troubleshooting, account recovery, workflow validation, and communication during service-impacting issues.</p>
            <p>The useful public summary is the role context above and the <a href="/resume/" class="page-inline-link">resume</a>, not customer-specific implementation detail.</p>
          </div>
        </div>
        <Divider />
      </>
    )}
    {hasRepos && (
      <>
        <div class="si" id="support-projects">
          <h2 class="hcit-h2">Projects in this track</h2>
          <div class="hcit-grid">
            {repos.map((r) => (
              <article class="hcit-card card-enter">
                <div class="hcit-card-head">
                  <span class="hcit-card-tag">{r.lane}</span>
                  {r.stars > 0 && <span class="hcit-card-stars"><StarSvg /> {r.stars}</span>}
                </div>
                <h3 class="hcit-card-name"><a href={r.repositoryUrl} target="_blank" rel="noopener" class="hcit-card-link">{r.name}</a></h3>
                <p class="hcit-card-desc" set:html={r.desc}></p>
                <div class="hcit-card-actions">
                  <a href={r.repositoryUrl} target="_blank" rel="noopener" class="hcit-card-cta">Open repository →</a>
                  {r.liveUrl && <a href={r.liveUrl} target="_blank" rel="noopener" class="hcit-card-live">Open live demo →</a>}
                </div>
              </article>
            ))}
          </div>
        </div>
        <Divider />
      </>
    )}

    <div class="si" id="track-context">
      <h2 class="hcit-h2">Why this track exists</h2>
      <div class="hcit-why rv">
        <p>Healthcare IT rewards steady operations more than novelty. Customer access, workstation reliability, hosted services, vendor coordination, and recovery communication all matter because they sit close to daily operations.</p>
        <p>The practical work is diagnosis, documentation, recovery planning, vendor coordination, and clear communication when support workflows are interrupted.</p>
        <p>For healthcare IT support or systems work, <a href="/#connect" class="page-inline-link">use the contact links</a>.</p>
      </div>
    </div>
  </main>

  <footer>
    <div class="fi page-footer-shell">
      <div class="footer-brand">
        <div class="ft"><a href="/" class="footer-backlink">← Back to portfolio</a></div>
        <p class="footer-summary">These tools sit inside a wider portfolio of operational software, browser products, and systems-first utility work shaped by real environments.</p>
      </div>
      <nav class="fl" aria-label="Footer navigation"><a href="/rss.xml">RSS</a><a href="https://github.com/SysAdminDoc" target="_blank" rel="noopener">GitHub</a></nav>
    </div>
  </footer>
</Base>

<style is:global>
  .hcit-page{min-height:calc(100vh - 200px)}
  .hcit-title{font-size:clamp(44px,6vw,72px)!important;background:linear-gradient(120deg,var(--t1),var(--grn));-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent}
  .hcit-intro{font-size:18px!important;max-width:720px}
  .hcit-stats{margin-top:32px;max-width:1080px}
  .hcit-stat{min-height:100%}
  .hcit-stat-num{color:var(--grn);text-shadow:0 0 20px var(--grn-glow)}
  .hcit-actions{margin-top:22px}
  .hcit-h2{font-family:var(--mono);font-size:14px;text-transform:uppercase;letter-spacing:.15em;color:var(--t3);margin-bottom:28px;max-width:900px;margin-left:auto;margin-right:auto}
  .hcit-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(340px,1fr));gap:16px;max-width:1100px;margin:0 auto}
  .hcit-card{display:flex;flex-direction:column;gap:10px;padding:26px;border:1px solid var(--border-soft);border-radius:12px;background:var(--surface-1);color:var(--t1);box-shadow:var(--shadow-soft);transition:border-color .25s,transform .25s,box-shadow .25s,background-color .25s}
  .hcit-card:hover{border-color:rgba(74,222,128,.22);transform:translateY(-3px);box-shadow:0 18px 36px rgba(0,0,0,.22)}
  .hcit-card:focus-visible{outline:2px solid var(--grn);outline-offset:4px}
  .hcit-card-head{display:flex;align-items:center;justify-content:space-between}
  .hcit-card-tag{font-family:var(--mono);font-size:10px;letter-spacing:.1em;color:var(--grn);padding:3px 8px;border:1px solid rgba(74,222,128,.3);border-radius:4px}
  .hcit-card-stars{font-family:var(--mono);font-size:12px;color:var(--yel);display:inline-flex;align-items:center;gap:4px}
  .hcit-card-stars svg{width:12px;height:12px;fill:currentColor}
  .hcit-card-name{font-family:var(--mono);font-size:18px;font-weight:600;margin:0}
  .hcit-card-link{color:var(--t1);text-decoration:none}
  .hcit-card-link:hover{color:var(--grn)}
  .hcit-card-desc{color:var(--t2);font-size:14px;line-height:1.6;margin:0;flex:1}
  .hcit-card-actions{display:flex;gap:14px;align-items:center;flex-wrap:wrap;font-family:var(--mono);font-size:13px;margin-top:4px}
  .hcit-card-cta{color:var(--grn);text-decoration:none}
  .hcit-card-live{color:var(--blue);text-decoration:none}
  .hcit-card-live:hover{text-decoration:underline}
  .hcit-card-link:focus-visible,.hcit-card-cta:focus-visible,.hcit-card-live:focus-visible{outline:2px solid var(--grn);outline-offset:3px;border-radius:6px}
  .hcit-why{max-width:760px;margin:0 auto;color:var(--t2);font-size:17px;line-height:1.75}
  .hcit-why p{margin-bottom:18px}
  .hcit-why strong{color:var(--t1);font-weight:600}
</style>
