---
import Base from '../layouts/Base.astro';
import InteriorNav from '../components/InteriorNav.astro';
import SectionJumpNav from '../components/SectionJumpNav.astro';
import { interiorOgPageBySlug } from '../data/interior-og-pages';
import { pageFreshnessBySlug, reviewedWebPageJsonLd } from '../data/page-freshness';

const title = 'Search - Matt Parker';
const pageOg = interiorOgPageBySlug.search;
const pageFreshness = pageFreshnessBySlug.search;
const siteUrl = Astro.site?.toString().replace(/\/$/, '') || 'https://sysadmindoc.github.io';
const pageJsonLd = reviewedWebPageJsonLd({
  siteUrl,
  route: pageFreshness.route,
  title,
  description: pageOg.description,
  lastReviewed: pageFreshness.lastReviewed,
  schemaTypes: pageFreshness.schemaTypes,
});
const cmdkSections = [
  { label: 'Search', href: '#site-search', desc: 'Full-text Pagefind search with Category filtering across rendered portfolio pages and README excerpts.', badge: 'PAGEFIND' },
  { label: 'Fallbacks', href: '#search-fallbacks', desc: 'No-JS links into the catalog, timeline, release stream, and archive decisions.', badge: 'LINKS' },
];
const pagefindResultTemplate = String.raw`<li class="pf-result portfolio-result">
  <div class="pf-result-card portfolio-result-card">
    {{#if and(options.show_images, meta.image)}}
    <img class="pf-result-image portfolio-result-image" src="{{ meta.image | resolveUrl(meta.url | default(url)) }}" alt="{{ meta.image_alt | default(meta.title) }}" loading="lazy" decoding="async">
    {{/if}}
    <div class="pf-result-content portfolio-result-content">
      <div class="portfolio-result-meta">
        {{#if meta.route_type}}<span>{{ meta.route_type }}</span>{{/if}}
        {{#if meta.category}}<span>{{ meta.category }}</span>{{/if}}
        {{#if meta.updated}}<span>{{ meta.updated }}</span>{{/if}}
      </div>
      <p class="pf-result-title">
        <a class="pf-result-link" href="{{ meta.url | default(url) | safeUrl }}">{{ meta.title }}</a>
      </p>
      {{#if excerpt}}
      <p class="pf-result-excerpt">{{+ excerpt +}}</p>
      {{/if}}
    </div>
  </div>
  {{#if sub_results}}
  <ul class="pf-heading-chips">
    {{#each sub_results as sub}}
    <li class="pf-heading-chip">
      <a class="pf-heading-link" href="{{ sub.url | safeUrl }}">{{ sub.title }}</a>
      <p class="pf-heading-excerpt">{{+ sub.excerpt +}}</p>
    </li>
    {{/each}}
  </ul>
  {{/if}}
</li>`;
const pagefindPlaceholderTemplate = String.raw`<li class="pf-result portfolio-result" aria-hidden="true">
  <div class="pf-result-card portfolio-result-card">
    <div class="pf-skeleton pf-skeleton-image portfolio-result-image"></div>
    <div class="pf-result-content portfolio-result-content">
      <div class="portfolio-result-meta">
        <span class="pf-skeleton"></span>
        <span class="pf-skeleton"></span>
      </div>
      <p class="pf-result-title pf-skeleton pf-skeleton-title"></p>
      <p class="pf-result-excerpt pf-skeleton pf-skeleton-excerpt"></p>
    </div>
  </div>
</li>`;
---
<Base title={title} description={pageOg.description} ogImage={pageOg.ogImage} ogImageAlt={pageOg.ogImageAlt} cmdkSections={cmdkSections}>
  <script is:inline type="application/ld+json" set:html={pageJsonLd} />
  <link href="/pagefind/pagefind-component-ui.css" rel="stylesheet" />
  <script src="/pagefind/pagefind-component-ui.js" type="module" is:inline></script>
  <a href="#main" class="skip-link">Skip to content</a>
  <InteriorNav active="search" contextLabel="Search" contextTone="green" />

  <main id="main" class="search-page" data-pagefind-body>
    <div class="si page-shell" id="site-search">
      <div class="sh rv">
        <div class="sl">// Search</div>
        <h1 class="st search-title">Search the public portfolio</h1>
        <p class="sd">
          Full-text static search across rendered project pages, README excerpts, language tracks, release history, timeline entries, archive decisions, and the current-focus page.
        </p>
      </div>

      <div class="search-overview page-stat-grid rv">
        <div class="page-stat">
          <div class="page-stat-value">Static</div>
          <div class="page-stat-label">No Backend</div>
          <div class="page-stat-copy">Pagefind indexes the built HTML after Astro and ships a static bundle with the site.</div>
        </div>
        <div class="page-stat">
          <div class="page-stat-value">Category</div>
          <div class="page-stat-label">Content Indexed</div>
          <div class="page-stat-copy">Project detail pages expose Category facets, so broad searches can be narrowed without leaving the static search page.</div>
        </div>
        <div class="page-stat">
          <div class="page-stat-value">Ctrl K</div>
          <div class="page-stat-label">Still Available</div>
          <div class="page-stat-copy">The command palette remains the fastest keyboard route for known project names and site sections.</div>
        </div>
      </div>

      <div class="search-shell rv">
        <div id="pagefindSearch" class="portfolio-pagefind" aria-label="Full-text site search">
          <pagefind-config bundle-path="/pagefind/" excerpt-length="24" preload faceted></pagefind-config>
          <div class="search-input-row">
            <pagefind-input placeholder="Search projects, README excerpts, releases, timeline entries..." autofocus></pagefind-input>
          </div>
          <div class="search-result-layout">
            <aside class="search-filter-panel" aria-label="Search filters">
              <div class="search-filter-kicker">Filter</div>
              <pagefind-filter-pane open="category" sort="alphabetical" auto-open-threshold="20"></pagefind-filter-pane>
            </aside>
            <div class="search-results-panel">
              <pagefind-summary default-message="Type a term to search indexed public pages."></pagefind-summary>
              <pagefind-results show-images max-sub-results="4">
                <script is:inline type="text/pagefind-template" set:html={pagefindResultTemplate}></script>
                <script is:inline type="text/pagefind-template" data-template="placeholder" set:html={pagefindPlaceholderTemplate}></script>
              </pagefind-results>
            </div>
          </div>
          <pagefind-keyboard-hints></pagefind-keyboard-hints>
        </div>
        <p class="search-loading" id="pagefindLoading">Loading the static search index...</p>
        <noscript>
          <div class="search-noscript page-empty">
            <strong>JavaScript is required for full-text search.</strong> The fallback links below still work without scripts.
          </div>
        </noscript>
      </div>

      <SectionJumpNav items={cmdkSections} />
    </div>

    <section class="si search-fallbacks" id="search-fallbacks" aria-labelledby="search-fallbacks-title">
      <div class="search-section-head">
        <h2 id="search-fallbacks-title">No-JS Fallbacks</h2>
        <p>These routes stay plain links so the site remains navigable even when the full-text bundle is unavailable.</p>
      </div>
      <div class="search-fallback-grid">
        <a href="/#catalog">
          <span>Catalog</span>
          <small>Filter every public project by category and built-in project search.</small>
        </a>
        <a href="/timeline/">
          <span>Timeline</span>
          <small>Review project movement by year, platform, category, and language.</small>
        </a>
        <a href="/releases/">
          <span>Releases</span>
          <small>Browse the chronological release stream from generated GitHub metadata.</small>
        </a>
        <a href="/archive/">
          <span>Archive Decisions</span>
          <small>Understand retired, moved, held, or superseded project surfaces.</small>
        </a>
      </div>
    </section>
  </main>

  <footer>
    <div class="fi page-footer-shell">
      <div class="footer-brand">
        <div class="ft"><a href="/" class="footer-backlink">Back to portfolio</a></div>
        <p class="footer-summary">Use full-text search when you remember a feature, README phrase, language, or category. Use Ctrl/Cmd+K when you already know the destination.</p>
      </div>
      <nav class="fl" aria-label="Footer navigation"><a href="/#catalog">Catalog</a><a href="/timeline/">Timeline</a></nav>
    </div>
  </footer>

  <script src="/scripts/search-page.js" is:inline></script>
</Base>

<style is:global>
  .search-page{min-height:calc(100vh - 200px)}
  .search-page .page-shell{grid-template-columns:minmax(0,1fr)}
  .search-page .page-shell > *{min-width:0;max-width:100%}
  .search-title{font-size:clamp(34px,4.8vw,56px)!important}
  .search-overview{margin-top:32px}
  .search-shell{width:100%;min-width:0;max-width:100%;margin-top:28px;padding:22px;border:1px solid var(--border-soft);border-radius:8px;background:var(--surface-1);box-shadow:var(--shadow-soft);overflow:hidden}
  .search-loading{margin:14px 0 0;color:var(--t3);font-size:14px;line-height:1.6}
  .search-noscript{margin-top:18px}
  .portfolio-pagefind{--pf-text:var(--t1);--pf-text-secondary:var(--t2);--pf-text-muted:var(--t3);--pf-background:var(--surface-1);--pf-skeleton:var(--surface-2);--pf-border:var(--border-soft);--pf-border-focus:var(--grn);--pf-hover:var(--surface-2);--pf-mark:var(--t1);--pf-outline-focus:var(--focus-ring);--pf-outline-width:3px;--pf-outline-offset:0;--pf-font:var(--sans);--pf-input-height:52px;--pf-input-font-size:16px;--pf-summary-font-size:13px;--pf-result-title-font-size:15px;--pf-result-excerpt-font-size:14px;--pf-filter-font-size:13px;--pf-border-radius:8px;--pf-results-gap:10px;display:grid;grid-template-columns:minmax(0,1fr);gap:14px;min-width:0;max-width:100%}
  .portfolio-pagefind pagefind-input,.portfolio-pagefind pagefind-summary,.portfolio-pagefind pagefind-results,.portfolio-pagefind pagefind-filter-pane,.portfolio-pagefind pagefind-keyboard-hints{display:block;min-width:0;max-width:100%}
  .search-input-row{min-width:0}
  .search-result-layout{display:grid;grid-template-columns:minmax(180px,236px) minmax(0,1fr);gap:18px;align-items:start;min-width:0}
  .search-filter-panel{display:grid;gap:8px;min-width:0}
  .search-filter-kicker{font-family:var(--mono);font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:var(--t3)}
  .search-results-panel{display:grid;gap:10px;min-width:0}
  .portfolio-pagefind .pf-filter-pane{box-shadow:none}
  .portfolio-pagefind .pf-result-link{color:var(--t1);text-decoration:none}
  .portfolio-pagefind .pf-result-link:hover{color:var(--grn)}
  .portfolio-pagefind .pf-result-card{box-shadow:none}
  .portfolio-pagefind .portfolio-result-card{align-items:flex-start;gap:14px}
  .portfolio-pagefind .portfolio-result-image{flex:0 0 92px;width:92px;height:58px;border:1px solid var(--border-soft);border-radius:8px;background:var(--surface-2);object-fit:cover}
  .portfolio-pagefind .portfolio-result-content{min-width:0}
  .portfolio-pagefind .portfolio-result-meta{display:flex;flex-wrap:wrap;gap:6px;margin:0 0 8px;min-height:18px}
  .portfolio-pagefind .portfolio-result-meta span{display:inline-flex;align-items:center;min-height:18px;padding:3px 7px;border:1px solid var(--border-soft);border-radius:4px;background:rgba(255,255,255,.025);color:var(--t3);font-family:var(--mono);font-size:10px;line-height:1;letter-spacing:.08em;text-transform:uppercase}
  .portfolio-pagefind .portfolio-result-meta .pf-skeleton{width:62px;border:0}
  .portfolio-pagefind mark{background:var(--grnd);color:var(--t1);border-radius:3px;padding:0 .12em}
  .search-fallbacks{margin-top:58px}
  .search-section-head{display:flex;align-items:end;justify-content:space-between;gap:24px;margin-bottom:20px;padding-bottom:14px;border-bottom:1px solid var(--border-soft)}
  .search-section-head h2{font-family:var(--mono);font-size:13px;text-transform:uppercase;letter-spacing:.16em;color:var(--t1);margin:0}
  .search-section-head p{color:var(--t3);font-size:14px;line-height:1.6;max-width:52ch;margin:0}
  .search-fallback-grid{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:12px}
  .search-fallback-grid a{display:grid;gap:8px;min-height:124px;padding:18px;border:1px solid var(--border-soft);border-radius:8px;background:var(--surface-1);color:var(--t1);text-decoration:none;box-shadow:var(--shadow-soft)}
  .search-fallback-grid a:hover,.search-fallback-grid a:focus-visible{border-color:var(--grn);box-shadow:0 0 0 3px var(--focus-ring)}
  .search-fallback-grid span{font-family:var(--mono);font-size:13px;text-transform:uppercase;letter-spacing:.1em}
  .search-fallback-grid small{color:var(--t3);font-size:13px;line-height:1.55}
  @media(max-width:980px){.search-fallback-grid{grid-template-columns:repeat(2,minmax(0,1fr))}}
  @media(max-width:640px){
    .search-shell{padding:16px}
    .search-result-layout{grid-template-columns:1fr}
    .portfolio-pagefind .portfolio-result-card{gap:12px}
    .portfolio-pagefind .portfolio-result-image{flex-basis:74px;width:74px;height:52px}
    .portfolio-pagefind .portfolio-result-meta{gap:5px}
    .portfolio-pagefind .portfolio-result-meta span{font-size:9px}
    .search-section-head{align-items:start;flex-direction:column}
    .search-fallback-grid{grid-template-columns:1fr}
  }
</style>
