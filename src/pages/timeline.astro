---
import Base from '../layouts/Base.astro';
import InteriorNav from '../components/InteriorNav.astro';
import { interiorOgPageBySlug } from '../data/interior-og-pages';
import { pageFreshnessBySlug, reviewedWebPageJsonLd } from '../data/page-freshness';
import { catalog } from '../data/portfolio';
import { categoryLabels } from '../data/categories';
import { githubRepoUrl } from '../data/github';
import type { Lang } from '../data/types';

type ReleaseRecord = {
  repo: string;
  tag: string;
  name: string;
  publishedAt: string;
  url: string;
  bodyFirst: string;
};

type RepoMeta = {
  stars?: number;
  pushedAt?: string;
  updatedAt?: string;
  language?: string | null;
};

type TimelineEvent = {
  id: string;
  type: 'release' | 'project';
  typeLabel: string;
  title: string;
  desc: string;
  href: string;
  external: boolean;
  date: string;
  year: string;
  sortTime: number;
  project?: string;
  platformId: string;
  platformLabel: string;
  categoryId: string;
  categoryLabel: string;
  languageId: string;
  languageLabel: string;
};

let releases: ReleaseRecord[] = [];
try {
  const mod = await import('../data/_releases.json');
  releases = (mod.default ?? mod) as ReleaseRecord[];
} catch {}

let meta: Record<string, RepoMeta> = {};
try {
  const mod = await import('../data/_meta.json');
  meta = (mod.default ?? mod) as Record<string, RepoMeta>;
} catch {}

const slugId = (value: string) =>
  value
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, '-')
    .replace(/^-+|-+$/g, '') || 'other';

const cleanText = (value: string) =>
  value
    .replace(/<[^>]+>/g, '')
    .replace(/&mdash;/g, '-')
    .replace(/&amp;/g, '&')
    .replace(/&rarr;/g, '->')
    .replace(/\s+/g, ' ')
    .trim();

const projectByRepo = new Map(catalog.map((entry) => [entry.repo, entry]));

const platformForCategory = (category?: Lang, language?: string | null) => {
  if (category === 'kt') return { id: 'android', label: 'Android' };
  if (category === 'web') return { id: 'web', label: 'Web Apps' };
  if (category === 'ext') return { id: 'browser', label: 'Browser Extensions' };
  if (category === 'ps' || category === 'cs' || category === 'cpp') return { id: 'windows', label: 'Windows/Desktop' };
  if (category === 'py') return { id: 'python', label: 'Python Tools' };
  if (category === 'sec') return { id: 'security', label: 'Security/Network' };
  if (category === 'media') return { id: 'media', label: 'Media/AI' };
  if (category === 'guide') return { id: 'guides', label: 'Guides' };
  if (language === 'HTML' || language === 'JavaScript') return { id: 'web', label: 'Web Apps' };
  return { id: 'other', label: 'Other' };
};

const releaseEvents: TimelineEvent[] = releases
  .map((release, index) => {
    const project = projectByRepo.get(release.repo);
    const repoMeta = meta[release.repo] ?? {};
    const category = project?.category ?? 'other';
    const platform = platformForCategory(category, repoMeta.language);
    const date = release.publishedAt;
    const languageLabel = repoMeta.language ?? categoryLabels[category] ?? 'Unknown';
    return {
      id: `release-${release.repo}-${release.tag}-${index}`,
      type: 'release' as const,
      typeLabel: 'Release',
      title: `${project?.name ?? release.repo} ${release.tag}`,
      desc: cleanText(release.bodyFirst || release.name || 'GitHub release published for this project.'),
      href: release.url,
      external: true,
      date,
      year: date.slice(0, 4),
      sortTime: new Date(date).getTime(),
      project: release.repo,
      platformId: platform.id,
      platformLabel: platform.label,
      categoryId: category,
      categoryLabel: categoryLabels[category] ?? category,
      languageId: slugId(languageLabel),
      languageLabel,
    };
  })
  .filter((event) => Number.isFinite(event.sortTime));

const projectEvents: TimelineEvent[] = catalog
  .map((project) => {
    const repoMeta = meta[project.repo] ?? {};
    const date = repoMeta.pushedAt ?? repoMeta.updatedAt;
    if (!date) return null;
    const platform = platformForCategory(project.category, repoMeta.language);
    const languageLabel = repoMeta.language ?? categoryLabels[project.category] ?? project.category;
    const sortTime = new Date(date).getTime();
    if (!Number.isFinite(sortTime)) return null;
    return {
      id: `project-${project.repo}`,
      type: 'project' as const,
      typeLabel: 'Project Update',
      title: project.name,
      desc: cleanText(project.desc),
      href: githubRepoUrl(project.repo),
      external: true,
      date,
      year: date.slice(0, 4),
      sortTime,
      project: project.repo,
      platformId: platform.id,
      platformLabel: platform.label,
      categoryId: project.category,
      categoryLabel: categoryLabels[project.category] ?? project.category,
      languageId: slugId(languageLabel),
      languageLabel,
    };
  })
  .filter(Boolean) as TimelineEvent[];

const events = [...releaseEvents, ...projectEvents].sort((a, b) => b.sortTime - a.sortTime);

const uniqueOptions = (field: 'year' | 'platform' | 'category' | 'language') => {
  const map = new Map<string, string>();
  for (const event of events) {
    if (field === 'year') map.set(event.year, event.year);
    if (field === 'platform') map.set(event.platformId, event.platformLabel);
    if (field === 'category') map.set(event.categoryId, event.categoryLabel);
    if (field === 'language') map.set(event.languageId, event.languageLabel);
  }
  return Array.from(map, ([id, label]) => ({ id, label })).sort((a, b) => {
    if (field === 'year') return b.label.localeCompare(a.label);
    return a.label.localeCompare(b.label);
  });
};

const yearOptions = uniqueOptions('year');
const platformOptions = uniqueOptions('platform');
const categoryOptions = uniqueOptions('category');
const languageOptions = uniqueOptions('language');

const byYear = new Map<string, TimelineEvent[]>();
for (const event of events) {
  const bucket = byYear.get(event.year) ?? [];
  bucket.push(event);
  byYear.set(event.year, bucket);
}

const yearSummaries = Array.from(byYear, ([year, yearEvents]) => {
  const categoryCounts = new Map<string, number>();
  const projectSet = new Set<string>();
  for (const event of yearEvents) {
    categoryCounts.set(event.categoryLabel, (categoryCounts.get(event.categoryLabel) ?? 0) + 1);
    if (event.project) projectSet.add(event.project);
  }
  const topCategories = Array.from(categoryCounts, ([label, count]) => ({ label, count }))
    .sort((a, b) => b.count - a.count)
    .slice(0, 3);
  return {
    year,
    releases: yearEvents.filter((event) => event.type === 'release').length,
    projectUpdates: yearEvents.filter((event) => event.type === 'project').length,
    projects: projectSet.size,
    topCategories,
  };
}).sort((a, b) => b.year.localeCompare(a.year));

const latestYear = yearSummaries[0]?.year ?? new Date().getUTCFullYear().toString();
const activeProjects = new Set(events.map((event) => event.project).filter(Boolean)).size;
const dateFormatter = new Intl.DateTimeFormat('en-US', { month: 'short', day: 'numeric', year: 'numeric', timeZone: 'UTC' });
const cmdkSections = [
  { label: 'Overview', href: '#timeline-overview', desc: 'Year-level momentum, release counts, active projects, and source mix.', badge: 'TIMELINE' },
  { label: 'Year Review', href: '#year-review', desc: 'Roll-up cards generated from release and project metadata evidence.', badge: 'YEARS' },
  { label: 'Events', href: '#timeline-events', desc: 'Filterable project timeline by year, platform, category, and language.', badge: 'FILTERS' },
] as const;
const title = 'Timeline — Matt Parker';
const pageOg = interiorOgPageBySlug.timeline;
const pageFreshness = pageFreshnessBySlug.timeline;
const siteUrl = Astro.site?.toString().replace(/\/$/, '') || 'https://sysadmindoc.github.io';
const pageJsonLd = reviewedWebPageJsonLd({
  siteUrl,
  route: pageFreshness.route,
  title,
  description: pageOg.description,
  lastReviewed: pageFreshness.lastReviewed,
  schemaTypes: pageFreshness.schemaTypes,
});
---
<Base title={title} description={pageOg.description} ogImage={pageOg.ogImage} ogImageAlt={pageOg.ogImageAlt} cmdkSections={cmdkSections}>
  <script is:inline type="application/ld+json" set:html={pageJsonLd} />
  <a href="#main" class="skip-link">Skip to content</a>
  <InteriorNav active="timeline" contextLabel="Timeline" contextTone="blue" />

  <main id="main" class="timeline-page" data-pagefind-body data-pagefind-filter="Scope:Timeline">
    <span aria-hidden="true" data-pagefind-ignore data-pagefind-meta="route_type:Timeline"></span>
    <span aria-hidden="true" data-pagefind-ignore data-pagefind-meta="type:Timeline"></span>
    <span aria-hidden="true" data-pagefind-ignore data-pagefind-meta="category:Portfolio"></span>
    <div class="si page-shell" id="timeline-overview">
      <div class="sh rv">
        <div class="sl">// Timeline</div>
        <h1 class="st timeline-title">Year-in-review for the public archive</h1>
        <p class="sd">
          A generated view of what shipped, what moved, and where the work clustered.
          It combines GitHub release cache entries and latest project push metadata from the generated portfolio snapshot.
        </p>
      </div>

      <div class="timeline-overview page-stat-grid rv">
        <div class="page-stat">
          <div class="page-stat-value">{latestYear}</div>
          <div class="page-stat-label">Latest Year</div>
          <div class="page-stat-copy">Newest generated year currently represented by releases or project push metadata.</div>
        </div>
        <div class="page-stat">
          <div class="page-stat-value">{releaseEvents.length}</div>
          <div class="page-stat-label">Releases</div>
          <div class="page-stat-copy">Tagged GitHub releases available in the generated cache.</div>
        </div>
        <div class="page-stat">
          <div class="page-stat-value">{activeProjects}</div>
          <div class="page-stat-label">Active Projects</div>
          <div class="page-stat-copy">Projects with release or push evidence in this build-time snapshot.</div>
        </div>
      </div>

      <div class="timeline-actions page-actions rv">
        <a href="/releases/" class="btn bp">Open release stream</a>
        <a href="/#catalog" class="btn bg2">Open project catalog</a>
        <a href="https://github.com/SysAdminDoc" target="_blank" rel="noopener" class="page-action-link">Open GitHub workspace</a>
      </div>

      <section class="timeline-years" id="year-review" aria-labelledby="year-review-title">
        <div class="timeline-section-head">
          <h2 id="year-review-title">Review By Year</h2>
          <p>Each card is generated from current build evidence rather than a hand-maintained narrative.</p>
        </div>
        <div class="timeline-year-grid">
          {yearSummaries.map((summary) => (
            <article class="timeline-year-card">
              <div class="timeline-year">{summary.year}</div>
              <div class="timeline-year-stats">
                <span><strong>{summary.releases}</strong> releases</span>
                <span><strong>{summary.projectUpdates}</strong> project updates</span>
              </div>
              <p>{summary.projects} public projects show activity or release evidence this year.</p>
              {summary.topCategories.length > 0 && (
                <div class="timeline-chip-row" aria-label={`Top ${summary.year} lanes`}>
                  {summary.topCategories.map((category) => (
                    <span>{category.label} {category.count}</span>
                  ))}
                </div>
              )}
            </article>
          ))}
        </div>
      </section>

      <section class="timeline-events-wrap" id="timeline-events" aria-labelledby="timeline-events-title">
        <div class="timeline-section-head">
          <h2 id="timeline-events-title">Filterable Timeline</h2>
          <p>Use the filters to move from the full archive view into a platform, language, category, or year lane.</p>
        </div>

        <search aria-label="Filter the project timeline">
        <form class="timeline-controls" id="timelineFilters">
          <label>
            <span>Year</span>
            <select id="timelineYear" name="year" disabled={events.length === 0}>
              <option value="all">All years</option>
              {yearOptions.map((option) => <option value={option.id}>{option.label}</option>)}
            </select>
          </label>
          <label>
            <span>Platform</span>
            <select id="timelinePlatform" name="platform" disabled={events.length === 0}>
              <option value="all">All platforms</option>
              {platformOptions.map((option) => <option value={option.id}>{option.label}</option>)}
            </select>
          </label>
          <label>
            <span>Category</span>
            <select id="timelineCategory" name="category" disabled={events.length === 0}>
              <option value="all">All categories</option>
              {categoryOptions.map((option) => <option value={option.id}>{option.label}</option>)}
            </select>
          </label>
          <label>
            <span>Language</span>
            <select id="timelineLanguage" name="language" disabled={events.length === 0}>
              <option value="all">All languages</option>
              {languageOptions.map((option) => <option value={option.id}>{option.label}</option>)}
            </select>
          </label>
          <button type="button" class="timeline-reset" id="timelineReset" disabled>Reset filters</button>
        </form>
        </search>
        <p class="timeline-status" id="timelineStatus" role="status" aria-live="polite">
          {events.length === 0 ? 'No timeline activity is available yet.' : `${events.length} timeline events shown.`}
        </p>
        <div class="page-empty timeline-empty" id="timelineEmpty" hidden={events.length > 0}>
          <strong>{events.length === 0 ? 'No timeline activity yet.' : 'No timeline events match these filters.'}</strong>
          <span>{events.length === 0 ? 'Project and release activity will appear here as it is published.' : 'Reset the filters or broaden one selection to return to the full activity stream.'}</span>
        </div>

        <ol class="timeline-list" id="timelineList" data-initial-count="50">
          {events.map((event, index) => (
            <li
              class="timeline-event"
              data-timeline-event
              data-year={event.year}
              data-platform={event.platformId}
              data-category={event.categoryId}
              data-language={event.languageId}
              hidden={index >= 50 ? true : undefined}
              data-beyond-fold={index >= 50 ? '' : undefined}
            >
              <div class={`timeline-marker timeline-marker-${event.type}`}></div>
              <article class="timeline-event-card">
                <div class="timeline-event-meta">
                  <span class={`timeline-type timeline-type-${event.type}`}>{event.typeLabel}</span>
                  <time datetime={event.date}>{dateFormatter.format(new Date(event.date))}</time>
                </div>
                <h3>
                  <a href={event.href} target={event.external ? '_blank' : undefined} rel={event.external ? 'noopener' : undefined}>{event.title}</a>
                </h3>
                <p>{event.desc}</p>
                <div class="timeline-chip-row">
                  <span>{event.platformLabel}</span>
                  <span>{event.categoryLabel}</span>
                  <span>{event.languageLabel}</span>
                </div>
              </article>
            </li>
          ))}
        </ol>
        {events.length > 50 && (
          <div class="timeline-show-more" id="timelineShowMore">
            <button type="button" class="btn bg2" id="timelineShowMoreBtn" aria-expanded="false" aria-controls="timelineList">
              Show {events.length - 50} more events
            </button>
          </div>
        )}
      </section>
    </div>
  </main>

  <footer>
    <div class="fi page-footer-shell">
      <div class="footer-brand">
        <div class="ft"><a href="/" class="footer-backlink">← Back to portfolio</a></div>
        <p class="footer-summary">The timeline is the wide-angle view. GitHub repositories and releases carry the source-level detail.</p>
      </div>
      <nav class="fl" aria-label="Footer navigation"><a href="/releases/">Releases</a><a href="https://github.com/SysAdminDoc" target="_blank" rel="noopener">GitHub</a></nav>
    </div>
  </footer>

  <script src="/scripts/timeline.js" is:inline></script>
</Base>
