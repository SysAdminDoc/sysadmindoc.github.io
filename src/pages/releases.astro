---
import Base from '../layouts/Base.astro';
import InteriorNav from '../components/InteriorNav.astro';
import SectionJumpNav from '../components/SectionJumpNav.astro';
import { featured, liveApps, catalog } from '../data/projects';

let releases: { repo: string; tag: string; name: string; publishedAt: string; url: string; bodyFirst: string }[] = [];
try {
  const mod = await import('../data/_releases.json');
  releases = (mod.default ?? mod) as typeof releases;
} catch {}

let stats: { fetchedAt?: string | null } = {};
try { const m = await import('../data/_stats.json'); stats = m.default ?? m; } catch {}

const detailRepos = new Set([
  ...featured.map((project) => project.repo),
  ...liveApps.map((app) => app.slug),
  ...catalog.map((entry) => entry.repo),
]);
const projectNameMap = new Map<string, string>();
featured.forEach((project) => projectNameMap.set(project.repo, project.name));
liveApps.forEach((app) => projectNameMap.set(app.slug, app.name));
catalog.forEach((entry) => projectNameMap.set(entry.repo, entry.name));
const releasesWithLinks = releases.map((release) => {
  const hasDetailPage = detailRepos.has(release.repo);
  return {
    ...release,
    detailUrl: hasDetailPage ? `/projects/${release.repo}/` : `https://github.com/SysAdminDoc/${release.repo}`,
    hasDetailPage,
    projectName: projectNameMap.get(release.repo) ?? release.repo,
  };
});

// Group by year-month for a chronological feel
const byMonth: Record<string, typeof releasesWithLinks> = {};
for (const r of releasesWithLinks) {
  const key = r.publishedAt.slice(0, 7); // YYYY-MM
  (byMonth[key] = byMonth[key] || []).push(r);
}
const monthKeys = Object.keys(byMonth).sort((a, b) => b.localeCompare(a));
const monthLabelFormatter = new Intl.DateTimeFormat('en-US', { month: 'long', year: 'numeric', timeZone: 'UTC' });
const releaseDayFormatter = new Intl.DateTimeFormat('en-US', { month: 'short', day: 'numeric', timeZone: 'UTC' });
const compactUtcDate = new Intl.DateTimeFormat('en-US', { month: 'short', day: 'numeric', year: 'numeric', timeZone: 'UTC' });
const monthLabel = (k: string) => monthLabelFormatter.format(new Date(`${k}-01T00:00:00Z`));
const trackedRepos = new Set(releases.map((release) => release.repo)).size;
const latestMonth = monthKeys[0] ? monthLabel(monthKeys[0]) : null;
const cmdkSections = [
  { label: 'Overview', href: '#release-overview', desc: 'Release counts, tracked-project stats, and entry points into the archive.', badge: 'PAGE' },
  { label: 'Timeline', href: '#release-timeline', desc: 'Chronological release history grouped by month across active projects.', badge: 'TIMELINE' },
];
const footerShortcuts = [
  { href: '/#greatest-hits', label: 'Highlights', meta: 'Start with the shortlist of projects that best explain the portfolio.' },
  { href: '/now/', label: 'Current Focus', meta: 'See what is getting active polish and engineering time right now.' },
  { href: '/#catalog', label: 'Full Archive', meta: 'Step out of the timeline view and browse the full project catalog.' },
] as const;
---
<Base title="Releases — Matt Parker" description="Chronological stream of releases across the active public archive." cmdkSections={cmdkSections}>
  <a href="#main" class="skip-link">Skip to content</a>
  <InteriorNav active="releases" contextLabel="Release stream" contextTone="blue" />

  <main id="main" class="rel-page">
    <div class="si page-shell" id="release-overview">
      <div class="sh rv">
        <div class="sl">// Releases</div>
        <h1 class="st rel-title">Shipping history across the portfolio</h1>
        <p class="sd">
          Release notes pulled from GitHub across the most active projects in the public archive.
          {releases.length > 0 && <> <strong>{releases.length}</strong> releases indexed.</>}
          {stats.fetchedAt && <> Last refresh <time datetime={stats.fetchedAt} data-rel={stats.fetchedAt}>{compactUtcDate.format(new Date(stats.fetchedAt))}</time>.</>}
        </p>
      </div>

      {releases.length > 0 && (
        <div class="rel-overview page-stat-grid rv">
          <div class="rel-overview-card page-stat">
            <div class="rel-overview-value page-stat-value">{releases.length}</div>
            <div class="rel-overview-label page-stat-label">Releases Indexed</div>
            <div class="rel-overview-copy page-stat-copy">Cached from the most recently active projects.</div>
          </div>
          <div class="rel-overview-card page-stat">
            <div class="rel-overview-value page-stat-value">{trackedRepos}</div>
            <div class="rel-overview-label page-stat-label">Projects Tracked</div>
            <div class="rel-overview-copy page-stat-copy">Unique projects with release history visible in this stream.</div>
          </div>
          <div class="rel-overview-card page-stat">
            <div class="rel-overview-value page-stat-value">{latestMonth ?? 'Not yet synced'}</div>
            <div class="rel-overview-label page-stat-label">Latest Month</div>
            <div class="rel-overview-copy page-stat-copy">{latestMonth ? 'Most recent month represented in the timeline.' : 'The timeline will populate after the next data refresh.'}</div>
          </div>
        </div>
      )}
      <div class="rel-actions page-actions rv">
        <a href="/rss.xml" class="btn bp">Open RSS Feed</a>
        <a href="/#catalog" class="btn bg2">Open full archive</a>
        <a href="https://github.com/SysAdminDoc" target="_blank" rel="noopener" class="rel-action-link page-action-link">Open GitHub workspace</a>
      </div>
      <SectionJumpNav items={cmdkSections} />

      <div id="release-timeline">
        {releases.length === 0 && (
          <div class="rel-empty page-empty">
            <strong>Release history has not been cached yet.</strong> This timeline fills itself in after the next data refresh, so the archive stays useful without hand-curated changelogs.
          </div>
        )}

        {monthKeys.map((key) => (
          <section class="rel-month rv">
            <div class="rel-month-shell">
              <div class="rel-month-head">
                <h2 class="rel-month-label">{monthLabel(key)}</h2>
                <div class="rel-month-count">{byMonth[key].length} release{byMonth[key].length !== 1 ? 's' : ''}</div>
              </div>
              <ul class="rel-list">
                {byMonth[key].map((r) => (
                  <li class="rel-item">
                    <div class="rel-head">
                      <a href={r.detailUrl} target={r.hasDetailPage ? undefined : '_blank'} rel={r.hasDetailPage ? undefined : 'noopener'} class="rel-repo">
                        <span class="rel-project-name">{r.projectName}</span>
                        {r.projectName !== r.repo && <span class="rel-project-slug">{r.repo}</span>}
                      </a>
                      <a href={r.url} target="_blank" rel="noopener" class="rel-tag">{r.tag}</a>
                      <time class="rel-date" datetime={r.publishedAt}>{releaseDayFormatter.format(new Date(r.publishedAt))}</time>
                    </div>
                    {r.bodyFirst && <p class="rel-body">{r.bodyFirst}</p>}
                  </li>
                ))}
              </ul>
            </div>
          </section>
        ))}
      </div>
    </div>
  </main>

  <footer>
    <div class="fi page-footer-shell">
      <div class="footer-brand">
        <div class="ft"><a href="/" class="footer-backlink">← Back to portfolio</a></div>
        <p class="footer-summary">The release stream shows movement across the portfolio. The highlights, current-focus view, and catalog explain what each change belongs to.</p>
      </div>
      <nav class="footer-actions" aria-label="Continue exploring">
        <div class="footer-actions-head">
          <span class="footer-actions-kicker">Continue Exploring</span>
          <p class="footer-actions-copy">Use the timeline for shipping cadence, then open the routes that give stronger project context and product depth.</p>
        </div>
        <div class="footer-shortcuts">
          {footerShortcuts.map((link) => (
            <a href={link.href} class="footer-shortcut">
              <span class="footer-shortcut-label">{link.label}</span>
              <span class="footer-shortcut-meta">{link.meta}</span>
            </a>
          ))}
        </div>
        <div class="fl"><a href="/rss.xml">RSS</a><a href="https://github.com/SysAdminDoc" target="_blank" rel="noopener">GitHub</a></div>
      </nav>
    </div>
  </footer>
</Base>

<style is:global>
  .rel-page{min-height:calc(100vh - 200px)}
  .rel-title{font-size:clamp(32px,4.5vw,52px)!important}
  .rel-overview{margin-top:32px}
  .rel-actions{margin-top:22px}
  .rel-action-link{padding:0}
  .rel-empty{margin:40px 0}
  .rel-month{max-width:860px;margin:56px auto 0;position:relative;padding:0;overflow:visible}
  .rel-month::before{display:none}
  .rel-month-shell{padding:28px;border:1px solid var(--border-soft);border-radius:30px;background:var(--surface-1);box-shadow:var(--shadow-soft)}
  .rel-month-head{display:flex;align-items:center;justify-content:space-between;gap:16px;margin-bottom:20px;padding-bottom:14px;border-bottom:1px solid rgba(255,255,255,.08);flex-wrap:wrap}
  .rel-month-label{font-family:var(--mono);font-size:11px;text-transform:uppercase;letter-spacing:.2em;color:var(--t3);margin:0}
  .rel-month-count{font-family:var(--mono);font-size:11px;color:var(--t2);padding:5px 10px;border:1px solid rgba(255,255,255,.08);border-radius:999px;background:rgba(255,255,255,.03)}
  .rel-list{list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:4px}
  .rel-item{padding:18px;border:1px solid transparent;border-radius:16px;transition:background-color .2s ease,border-color .2s ease,box-shadow .2s ease,transform .2s ease}
  .rel-item:hover{background:rgba(255,255,255,.03);border-color:rgba(255,255,255,.08);box-shadow:0 14px 28px rgba(0,0,0,.14)}
  .rel-head{display:flex;align-items:baseline;gap:12px;flex-wrap:wrap}
  .rel-repo{display:inline-flex;align-items:center;gap:10px;flex-wrap:wrap;color:var(--t1);text-decoration:none}
  .rel-project-name{font-family:var(--mono);font-weight:600;font-size:15px}
  .rel-project-slug{font-family:var(--mono);font-size:11px;letter-spacing:.08em;text-transform:uppercase;color:var(--t3)}
  .rel-repo:hover{color:var(--grn)}
  .rel-tag{font-family:var(--mono);font-size:12px;color:var(--grn);padding:2px 9px;border:1px solid rgba(74,222,128,.3);border-radius:4px;text-decoration:none;background:var(--grnd)}
  .rel-tag:hover{background:rgba(74,222,128,.2)}
  .rel-date{font-family:var(--mono);font-size:12px;color:var(--t3);margin-left:auto}
  .rel-body{color:var(--t2);font-size:14px;line-height:1.6;margin:8px 0 0;padding-left:0}
  @media(max-width:640px){
    .rel-month-shell{padding:20px}
    .rel-date{margin-left:0;width:100%;order:3}
    .rel-head{gap:8px}
  }
</style>
