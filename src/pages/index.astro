---
import Base from '../layouts/Base.astro';
import Divider from '../components/Divider.astro';
import FeaturedCard from '../components/FeaturedCard.astro';
import LiveCard from '../components/LiveCard.astro';
import CatalogEntry from '../components/CatalogEntry.astro';
import SkillCard from '../components/SkillCard.astro';
import GreatestHits from '../components/GreatestHits.astro';
import TagCloud from '../components/TagCloud.astro';
import { featured, liveApps, catalog, skills } from '../data/projects';
import { fallbackRepoCount } from '../data/derived';

// Build-time: load cached star counts + aggregate stats + per-repo metadata (fetch-stars.mjs).
let stars: Record<string, number> = {};
let meta: Record<string, { stars: number; pushedAt: string; updatedAt: string; language: string | null }> = {};
let stats = {
  totalRepos: fallbackRepoCount,
  totalStars: 0,
  lastPushedAt: null as string | null,
  lastPushedRepo: null as string | null,
  streak: 0,
  latestRelease: null as { repo: string; tag: string | null; at: string } | null,
  fetchedAt: null as string | null,
};
try {
  const mod = await import('../data/_stars.json');
  stars = (mod.default ?? mod) as Record<string, number>;
} catch {}
try {
  const mod = await import('../data/_stats.json');
  stats = { ...stats, ...(mod.default ?? mod) };
} catch {}
try {
  const mod = await import('../data/_meta.json');
  meta = (mod.default ?? mod) as typeof meta;
} catch {}

let releases: { repo: string; tag: string; name: string; publishedAt: string; url: string; bodyFirst: string }[] = [];
try {
  const mod = await import('../data/_releases.json');
  releases = (mod.default ?? mod) as typeof releases;
} catch {}
const latestRelease = releases[0];

// Derive category counts from catalog data (fixes hardcoded-count gotcha)
const catCounts: Record<string, number> = {};
for (const c of catalog) catCounts[c.category] = (catCounts[c.category] ?? 0) + 1;
const catalogTotal = catalog.length;

const filterButtons = [
  { key: 'ps', label: 'PowerShell' },
  { key: 'py', label: 'Python' },
  { key: 'web', label: 'Web Apps' },
  { key: 'ext', label: 'Extensions' },
  { key: 'kt', label: 'Android' },
  { key: 'sec', label: 'Security' },
  { key: 'media', label: 'Media' },
  { key: 'cs', label: 'Desktop' },
  { key: 'guide', label: 'Guides' },
];
const filterLabelByKey = Object.fromEntries(filterButtons.map((button) => [button.key, button.label]));
const heroSignatureProjects = featured.slice(0, 3);
const heroLaunchApps = liveApps.slice(0, 4);
const heroTopCategories = Object.entries(catCounts)
  .sort(([, a], [, b]) => b - a)
  .slice(0, 3)
  .map(([key, count]) => ({
    key,
    label: filterLabelByKey[key] ?? key,
    count,
  }));
const heroDomainText = heroTopCategories.map(({ label, count }) => `${label} ${count}`).join(' / ');
const compactUtcDate = new Intl.DateTimeFormat('en-US', { month: 'short', day: 'numeric', year: 'numeric', timeZone: 'UTC' });
const heroReleaseDate = compactUtcDate;
const journeyMilestones = [
  {
    title: 'Healthcare IT & Systems Administration',
    eyebrow: 'Origin point',
    desc: 'Started in the deep end — provisioning workstations, managing networks, and keeping medical imaging systems running across healthcare facilities. Learned quickly that the only stable path through complex environments is to automate the parts you touch every day.',
    href: '/healthcare-it/',
    cta: 'Open the healthcare track',
    meta: 'Clinical systems, imaging uptime, and production-first tooling.',
    repoCount: false,
  },
  {
    title: 'PowerShell & Windows Automation',
    eyebrow: 'Workflow cleanup',
    desc: 'Built Windows tools to solve real operational friction — NVMe driver patchers, network security auditors, Start Menu organizers, bulk installers. WPF interfaces that feel like finished software instead of internal scripts.',
    href: '/lang/powershell/',
    cta: 'See the PowerShell stack',
    meta: 'Provisioning, repair, compliance, and system management.',
    repoCount: false,
  },
  {
    title: 'Python & Desktop Applications',
    eyebrow: 'Desktop expansion',
    desc: 'Moved into PyQt6 desktop apps for screenshot tooling, firewall management, image editing, PDF work, and more. The same rule held: bootstrap the dependencies, remove setup friction, and ship something people can actually launch right away.',
    href: '/lang/python/',
    cta: 'Browse the Python builds',
    meta: 'Local-first utilities, offline tools, and desktop workflows.',
    repoCount: false,
  },
  {
    title: 'Web Apps & Live Deployments',
    eyebrow: 'Instant access',
    desc: `Launched ${liveApps.length}+ browser-ready apps on GitHub Pages — weather radar, flight tracking, OSINT aggregation, search engines, and utility tools. No backend required, no signup needed, just fast links that open and work.`,
    href: '#live',
    cta: 'Launch the live apps',
    meta: 'Browser tools that start without install, sign-in, or setup.',
    repoCount: false,
  },
  {
    title: 'Full Stack & Beyond',
    eyebrow: 'Portfolio depth',
    desc: 'open source repos across six languages. Android apps in Kotlin, Chrome extensions, Tampermonkey userscripts, browser themes, and desktop software — a broad archive, but still grounded in practical use cases.',
    href: '#catalog',
    cta: 'Open the full catalog',
    meta: 'The complete archive, filters included.',
    repoCount: true,
  },
] as const;
const connectPaths = [
  {
    title: 'GitHub issue',
    handle: '@SysAdminDoc',
    href: 'https://github.com/SysAdminDoc',
    external: true,
    desc: 'Best for bug reports, scoped feature ideas, and first-contact collaboration threads tied to a real repo.',
    meta: 'Public, async, and attached to the work itself.',
    cta: 'Open GitHub',
    icon: 'github',
  },
  {
    title: 'Release stream',
    handle: '/releases',
    href: '/releases/',
    external: false,
    desc: 'See what is actively shipping, what just changed, and which parts of the portfolio are moving right now.',
    meta: 'Best if you want the current maintenance pulse first.',
    cta: 'Browse releases',
    icon: 'release',
  },
  {
    title: 'Current focus',
    handle: '/now',
    href: '/now/',
    external: false,
    desc: 'Quick snapshot of what I am building, polishing, and most likely to expand next.',
    meta: 'Best if you want to gauge timing and fit for new work.',
    cta: 'View now',
    icon: 'pulse',
  },
] as const;
const stackRoutes = [
  { href: '/lang/powershell/', label: 'PowerShell', meta: 'Automation & WPF' },
  { href: '/lang/python/', label: 'Python', meta: 'Desktop & AI tools' },
  { href: '/lang/javascript/', label: 'JavaScript', meta: 'Extensions & web' },
  { href: '/lang/kotlin/', label: 'Kotlin', meta: 'Android apps' },
  { href: '/lang/security/', label: 'Security', meta: 'Audits & network hardening' },
] as const;
const aboutSignals = [
  { label: 'Day Job', value: 'Healthcare IT', meta: 'Imaging uptime, workstation rollouts, and network stability inside real environments.' },
  { label: 'After Hours', value: 'Tooling that ships', meta: 'Turn repeated friction into something calmer, faster, and genuinely launch-ready.' },
  { label: 'Public Archive', value: `${stats.totalRepos}+ repos`, meta: 'A growing body of PowerShell, Python, JavaScript, Kotlin, and C# work.' },
] as const;
const aboutLinks = [
  { href: '/healthcare-it/', label: 'See the Healthcare Track', meta: 'The operational context, environments, and system work that shaped the portfolio.' },
  { href: '/now/', label: 'Open the Current Focus', meta: 'What is being built, refined, and most likely to expand next.' },
] as const;
const philosophyChecks = [
  'One launch path',
  'Readable defaults',
  'Open code by default',
] as const;
const philosophyPrinciples = [
  {
    title: 'Works On First Launch',
    desc: 'Download, launch, done. Tools auto-install their own dependencies and prerequisites. No setup wizards, no README scavenger hunts — if it takes more than one step to run, the build is not finished yet.',
    note: 'Onboarding should feel like opening software, not starting a project.',
    bg: 'var(--blued)',
    accent: 'var(--blue)',
    icon: 'M13 2L3 14h9l-1 8 10-12h-9l1-8z',
  },
  {
    title: "Build What's Missing",
    desc: "When the right tool does not exist, I build it. Most repos begin as a fix for personal operational friction, then grow into maintained software that solves the same problem for other people too.",
    note: 'The best backlog is the one you already trip over at work.',
    bg: 'var(--grnd)',
    accent: 'var(--grn)',
    icon: 'M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91a6 6 0 017.94-7.94l-3.76 3.76z',
  },
  {
    title: 'Always Dark',
    desc: 'Every interface ships with a premium dark theme. The goal is not decoration; it is a calmer workspace with stronger contrast, cleaner hierarchy, and less fatigue over long sessions.',
    note: 'A tool people stare at for hours should feel composed, not harsh.',
    bg: 'var(--purd)',
    accent: 'var(--pur)',
    icon: 'M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z',
  },
  {
    title: 'Open by Default',
    desc: `Everything ships in public. ${stats.totalRepos}+ repositories and growing, with transparent code, direct launches, and a bias toward tools that work for anyone in any environment.`,
    note: 'Trust comes faster when the work is inspectable and easy to try.',
    bg: 'var(--orgd)',
    accent: 'var(--org)',
    icon: 'M16 18l6-6-6-6M8 6l-6 6 6 6',
  },
] as const;
const aerialClips = [
  {id:'waOMwX39NOg', title:'Venice Beach, Florida', desc:'Morning aerial flight — June 2023'},
  {id:'xnpOENxAx-k', title:'Manasota Beach, Florida', desc:'Coastal drone footage over Manasota Key'},
  {id:'PnlsSqa8DtQ', title:'Venice Jetty', desc:'Aerial view of the Venice, Florida jetty'},
  {id:'FVroPKvYgKQ', title:'Nokomis Beach, Florida', desc:'Drone flight over Nokomis Beach'},
] as const;
const albums = [
  {id:'7xHMgXflIR9qRtjU39Q80t', art:'ab67616d00001e02e042810ddecccc2339656b49', name:'Push The Button', year:2026},
  {id:'7KlKXiga7kHUOgC8LeyKH4', art:'ab67616d00001e027c428d22537bec2ed4af94d8', name:'Game Over', year:2026},
  {id:'3NQ019Wd8fjtSCCQcK1WDH', art:'ab67616d00001e02f8ef4af6c2f7c3c8f592ebcb', name:'Saltwater in My Veins', year:2025},
  {id:'66iCBrYX5vrYn7LvPd2P5d', art:'ab67616d00001e029d375d3a3ad769fda8e2af93', name:'Unmasked', year:2025},
  {id:'39NZL7jH79wznqPBvr7Fwt', art:'ab67616d00001e026ed0117b585d98248228e17c', name:'Apocalypse', year:2025},
  {id:'2FsIqZY3LW1pTCjEb7URJk', art:'ab67616d00001e0234b30d89e374047ef7ecd730', name:'Thanks for Giving Up', year:2025},
] as const;
const earliestAlbumYear = Math.min(...albums.map((album) => album.year));
const latestAlbumYear = Math.max(...albums.map((album) => album.year));
const latestAlbumName = albums.find((album) => album.year === latestAlbumYear)?.name ?? albums[0]?.name ?? 'Latest release';
const footerShortcuts = [
  { href: '#featured', label: 'Featured', meta: 'Start with the strongest builds first.' },
  { href: '/releases/', label: 'Releases', meta: 'See what moved across the portfolio recently.' },
  { href: '/now/', label: 'Now', meta: 'Open the current build queue and focus areas.' },
] as const;
type CmdkProject = {
  slug: string;
  name: string;
  desc: string;
  type: 'featured' | 'live' | 'catalog';
  url: string;
  category?: string;
  categoryLabel?: string;
  searchTerms?: string[];
};
const cmdkProjectMap = new Map<string, CmdkProject>();
const normalizeCmdkDesc = (value: string) => value.replace(/&[a-z]+;/gi, ' ');
function upsertCmdkProject(slug: string, next: CmdkProject) {
  const existing = cmdkProjectMap.get(slug);
  const searchTerms = Array.from(
    new Set([...(existing?.searchTerms ?? []), ...(next.searchTerms ?? [])].filter(Boolean)),
  );
  cmdkProjectMap.set(slug, {
    ...existing,
    ...next,
    category: next.category ?? existing?.category,
    categoryLabel: next.categoryLabel ?? existing?.categoryLabel,
    searchTerms: searchTerms.length ? searchTerms : undefined,
  });
}
for (const project of catalog) {
  upsertCmdkProject(project.repo, {
    slug: project.repo,
    name: project.name,
    desc: normalizeCmdkDesc(project.desc),
    type: 'catalog',
    url: `/projects/${project.repo}/`,
    category: project.category,
    categoryLabel: filterLabelByKey[project.category] ?? project.category,
    searchTerms: [project.category, filterLabelByKey[project.category] ?? project.category],
  });
}
for (const app of liveApps) {
  upsertCmdkProject(app.slug, {
    slug: app.slug,
    name: app.name,
    desc: normalizeCmdkDesc(app.desc),
    type: 'live',
    url: `/projects/${app.slug}/`,
    searchTerms: ['Live Apps', 'Live App', 'Browser'],
  });
}
for (const project of featured) {
  upsertCmdkProject(project.repo, {
    slug: project.repo,
    name: project.name,
    desc: normalizeCmdkDesc(project.desc),
    type: 'featured',
    url: `/projects/${project.repo}/`,
    searchTerms: project.tags,
  });
}
const cmdkProjects = Array.from(cmdkProjectMap.values());
---
<Base>
  <a href="#main" class="skip-link">Skip to content</a>
  <div id="loader"><div class="lp">initializing portfolio<span class="lc"></span></div><div class="lbt"><div class="lb" id="loaderBar"></div></div></div>
  <canvas id="particles"></canvas>
  <div class="cc-dot" id="ccDot" aria-hidden="true"></div>
  <div class="cc-ring" id="ccRing" aria-hidden="true"></div>

  <nav id="nav" aria-label="Main navigation">
    <div class="ni">
      <a href="#hero" class="nl">matt<span>@</span>sysadmin<span>:~$</span></a>
      <div class="nk" id="navLinks">
        <a href="#greatest-hits">Hits</a>
        <a href="#featured">Projects</a>
        <a href="#live">Live</a>
        <a href="#catalog">Catalog</a>
        <a href="/releases/">Releases</a>
        <a href="/now/">Now</a>
        <a href="#about">About</a>
        <div class="nav-indicator" id="navIndicator"></div>
      </div>
      <div style="display:flex;align-items:center;gap:8px">
        <button type="button" class="theme-toggle" id="themeToggle" aria-label="Switch to light theme" title="Switch to light theme"><svg viewBox="0 0 24 24"><path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"/></svg></button>
        <button type="button" class="theme-toggle" id="cmdkToggle" aria-label="Open command palette (Ctrl or Cmd + K)" aria-controls="cmdk" aria-expanded="false" aria-haspopup="dialog" title="Search (Ctrl/Cmd + K)"><svg viewBox="0 0 24 24" stroke-width="2" fill="none" stroke="currentColor" stroke-linecap="round"><circle cx="11" cy="11" r="7"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg></button>
        <a href="https://github.com/SysAdminDoc" target="_blank" rel="noopener" class="ng" aria-label="GitHub Profile"><svg viewBox="0 0 16 16"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>GitHub</a>
        <button type="button" class="mt" id="mobileToggle" aria-label="Toggle navigation menu" aria-controls="navLinks" aria-expanded="false"><svg viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg></button>
      </div>
    </div>
  </nav>
  <div class="scroll-progress" id="scrollProgress"></div>

  <main id="main">
  <section class="hero" id="hero">
    <div class="hero-grid" aria-hidden="true"></div>
    <div class="hi">
      <div class="ht">
        <div class="hero-brandline">SysAdminDoc <span>/</span> Open Source Portfolio</div>
        <img class="hero-avatar" id="heroAvatar" src="data:image/gif;base64,R0lGODlhAQABAAAAACw=" alt="Matt Parker" width="56" height="56" decoding="async">
        <div class="htag" id="heroTag"><span class="dot"></span> Available for collaboration</div>
        <h1 class="hn">Matt <span class="a">Parker</span></h1>
        <p class="hr">Senior systems administrator building open source tools for the work I do every day.</p>
        <p class="hd">By day I keep Windows fleets, networks, and medical imaging systems running. After hours I turn the rough edges into polished utilities that launch fast, work offline, and ship finished on day one.</p>
        <p class="hero-domain-list">Operating across {heroDomainText}.</p>
        <div class="hs">
          <div class="hs-item"><div class="hsn" id="statRepos" data-live>{stats.totalRepos}</div><div class="hsl">Repositories</div></div>
          <div class="hs-item"><div class="hsn" id="statStars" data-live>{stats.totalStars}</div><div class="hsl">Stars</div></div>
          <div class="hs-item"><div class="hsn" id="statLive">{liveApps.length}</div><div class="hsl">Live Apps</div></div>
        </div>
        <div class="hero-pulse">
          <span class="pulse-dot"></span>
          {stats.streak > 0 && (
            <a href="/now/" class="pulse-item" title="90-day commit streak">
              <span class="pulse-k">streak</span>
              <span class="pulse-v">{stats.streak}d</span>
            </a>
          )}
          {latestRelease && (
            <a href={latestRelease.url} target="_blank" rel="noopener" class="pulse-item" title={`Released ${heroReleaseDate.format(new Date(latestRelease.publishedAt))}`}>
              <span class="pulse-k">latest</span>
              <span class="pulse-v">{latestRelease.repo} <span class="pulse-sub">{latestRelease.tag}</span></span>
            </a>
          )}
          {stats.lastPushedRepo && stats.lastPushedAt && (
            <a href={`https://github.com/SysAdminDoc/${stats.lastPushedRepo}`} target="_blank" rel="noopener" class="pulse-item" title={`Last push ${stats.lastPushedAt}`}>
              <span class="pulse-k">pushed</span>
              <span class="pulse-v" data-rel={stats.lastPushedAt}>{compactUtcDate.format(new Date(stats.lastPushedAt))}</span>
            </a>
          )}
        </div>
        <div class="last-active" id="lastActive" hidden role="status" aria-live="polite"><span class="la-dot"></span> <span id="lastActiveText"></span><span id="streakBadge"></span></div>
        <div class="ha">
          <a href="#featured" class="btn bp"><svg viewBox="0 0 16 16" fill="currentColor"><path d="M2 2.5A2.5 2.5 0 014.5 0h8.75a.75.75 0 01.75.75v12.5a.75.75 0 01-.75.75h-2.5a.75.75 0 110-1.5h1.75v-2h-8a1 1 0 00-.714 1.7.75.75 0 01-1.072 1.05A2.495 2.495 0 012 11.5v-9zm10.5-1h-8a1 1 0 00-1 1v6.708A2.486 2.486 0 014.5 9h8V1.5z"/></svg>Explore the Portfolio</a>
          <a href="https://github.com/SysAdminDoc" target="_blank" rel="noopener" class="btn bg2"><svg viewBox="0 0 16 16" fill="currentColor"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>GitHub Profile</a>
        </div>
      </div>
      <div class="hero-stage" aria-label="Portfolio highlights">
        <div class="hero-stage-head">
          <div>
            <div class="hero-stage-kicker">Signature builds</div>
            <h2 class="hero-stage-title">Three I keep coming back to.</h2>
          </div>
          <a href="#greatest-hits" class="hero-stage-link">See greatest hits</a>
        </div>
        <div class="hero-reel">
          {heroSignatureProjects.map((project, index) => (
            <a href={`/projects/${project.repo}/`} class="hero-reel-item">
              <span class="hero-reel-index">{String(index + 1).padStart(2, '0')}</span>
              <span class="hero-reel-copy">
                <span class="hero-reel-name">{project.name}</span>
                <span class="hero-reel-meta">{project.tags.join(' / ')}</span>
              </span>
              <span class={`hero-reel-lang ${project.lang}`}>{project.langLabel}</span>
            </a>
          ))}
        </div>
        <div class="hero-terminal-shell">
          <div class="hero-terminal-meta">
            <div class="hero-terminal-copy">
              <span class="hero-terminal-kicker">Interactive shell</span>
              <span class="hero-terminal-note">Type `help`, `ls`, or `open LibreSpot`.</span>
            </div>
            <span class="hero-terminal-badge">Try it</span>
          </div>
          <div class="term" id="heroTerm" role="region" aria-label="Interactive terminal" tabindex="0"><div class="tb"><span class="td r"></span><span class="td y"></span><span class="td g"></span><span class="tt">matt@sysadmin: ~/portfolio</span></div><div class="tbd" id="termBody"></div><div class="term-hint" id="termHint">click terminal or start typing to interact</div></div>
        </div>
        <div class="hero-flightpath">
          <span class="hero-flightpath-label">Launch instantly</span>
          <div class="hero-flightpath-items">
            {heroLaunchApps.map((app) => (
              <a href={app.url} target="_blank" rel="noopener">{app.name}</a>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <svg style="position:absolute;width:0;height:0"><defs><linearGradient id="waveGrad" x1="0%" y1="0%" x2="100%" y2="0%"><stop offset="0%" stop-color="var(--blue)" stop-opacity="0"/><stop offset="30%" stop-color="var(--blue)"/><stop offset="50%" stop-color="var(--pur)"/><stop offset="70%" stop-color="var(--teal)"/><stop offset="100%" stop-color="var(--teal)" stop-opacity="0"/></linearGradient></defs></svg>
  <div class="push-ribbon" id="pushRibbon" style="display:none"></div>
  <Divider />

  <GreatestHits />
  <Divider />

  <section id="featured"><div class="si">
    <div class="sh rv"><div class="sl">// Featured</div><h2 class="st">Top Projects</h2><p class="sd">Handpicked work where systems depth, strong UI, and practical utility all meet.</p></div>
    <div class="fg" id="featuredGrid">
      {featured.map((p) => <FeaturedCard project={p} stars={stars[p.repo]} />)}
    </div>
  </div></section>
  <Divider />

  <section id="live"><div class="si">
    <div class="sh rv"><div class="sl">// Live</div><h2 class="st">Try in Your Browser</h2><p class="sd">Fast, direct launches with no signup wall, no install friction, and no setup ceremony.</p></div>
    <div class="lg">
      {liveApps.map((a) => <LiveCard app={a} />)}
    </div>
  </div></section>
  <Divider />

  <TagCloud />
  <Divider />

  <section id="catalog"><div class="si">
    <div class="sh rv"><div class="sl">// Catalog</div><h2 class="st">All {catalogTotal} repositories</h2><p class="sd">Every public repo. Search, filter, sort. Age badges show freshness at a glance.</p></div>
    <div class="catalog-controls rv">
      <div class="search-wrap">
        <svg viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <input type="search" class="search-input" id="searchInput" name="repository-search" placeholder="Search repositories…" autocomplete="off" spellcheck="false" inputmode="search" enterkeyhint="search" aria-label="Search repositories">
      </div>
      <select class="sort-select" id="sortSelect" aria-label="Sort repositories">
        <option value="default">Default order</option>
        <option value="stars">Most stars</option>
        <option value="name">A-Z</option>
        <option value="name-desc">Z-A</option>
        <option value="recent">Recently updated</option>
      </select>
    </div>
    <div class="cf rv" id="filterBtns" role="group" aria-label="Filter by category">
      <button type="button" class="fb act" data-filter="all" data-label="All repositories">All <span class="fc" id="countAll">{catalogTotal}</span></button>
      {filterButtons.map((f) => (
        <button type="button" class="fb" data-filter={f.key} data-label={f.label}>{f.label} <span class="fc" data-cat={f.key}>{catCounts[f.key] ?? 0}</span></button>
      ))}
    </div>
    <div class="catalog-feedback rv">
      <div class="catalog-status" id="catalogStatus" role="status" aria-live="polite">Showing all {catalogTotal} repositories.</div>
      <button type="button" class="catalog-reset" id="catalogReset" hidden>Clear search & filters</button>
    </div>
    <div class="cg" id="catalogGrid">
      {catalog.map((entry, index) => <CatalogEntry entry={entry} index={index} stars={stars[entry.repo]} pushedAt={meta[entry.repo]?.pushedAt} updatedAt={meta[entry.repo]?.updatedAt ?? meta[entry.repo]?.pushedAt} />)}
    </div>
    <div class="no-results" id="noResults" role="status" aria-live="polite" hidden>
      <div class="no-results-title">No repositories match this view.</div>
      <p class="no-results-copy">Try a broader term, switch categories, or reset the catalog to get back to the full archive.</p>
      <button type="button" class="catalog-reset no-results-action" id="catalogResetEmpty">Reset the catalog</button>
    </div>
  </div></section>
  <Divider />

  <section id="skills"><div class="si">
    <div class="sh rv"><div class="sl">// Stack</div><h2 class="st">Languages &amp; Tools</h2><p class="sd">The portfolio spans a lot of repos, but the work organizes into a few strong lanes. Start with the language track that matches your problem, then use the repo mix to understand the bigger picture.</p></div>
    <div class="stack-shell rv">
      <div class="stack-overview">
        <div class="stack-kicker">Browse by lane</div>
        <p class="stack-copy">Each track groups the projects that share a workflow, platform, and maintenance rhythm. Open a lane for the strongest examples instead of paging through the full archive first.</p>
        <div class="stack-actions" aria-label="Open stack tracks">
          {stackRoutes.map((route) => (
            <a href={route.href} class="stack-action">
              <span class="stack-action-label">{route.label}</span>
              <span class="stack-action-meta">{route.meta}</span>
            </a>
          ))}
        </div>
      </div>
      <div class="lang-donut-wrap rv" id="langDonut">
        <div class="lang-donut-panel">
          <div class="lang-donut-head">
            <div class="lang-donut-kicker">Repo Mix</div>
            <p class="lang-donut-copy">Loading the language mix from GitHub so the stack view reflects the live public archive.</p>
          </div>
          <div class="lang-donut-fallback" aria-hidden="true">
            <div class="lang-donut-fallback-ring"></div>
            <div class="lang-donut-fallback-list">
              <span>PowerShell</span>
              <span>Python</span>
              <span>JavaScript</span>
              <span>Kotlin</span>
            </div>
          </div>
        </div>
      </div>
    </div>
    <div class="skg">
      {skills.map((s) => <SkillCard skill={s} />)}
    </div>
  </div></section>
  <Divider />

  <section id="about"><div class="si">
    <div class="sh rv"><div class="sl">// About</div><h2 class="st">Who I Am</h2><p class="sd">Operational systems by day, launch-ready tooling after hours, with the same bias toward calm, reliable software in both places.</p></div>
    <div class="ac">
      <div class="about-copy rv">
        <div class="about-kicker">Systems operator first. Product finisher by habit.</div>
        <p class="atp">I'm a <strong>Senior Systems Administrator</strong> by day &mdash; provisioning workstations, managing networks, and keeping medical imaging systems running for healthcare facilities.</p>
        <p class="atp">After hours, I build the tools I can't find anywhere else. What starts as a quick fix for a personal annoyance usually turns into a full-featured open source project. That pattern has produced <strong id="aboutReposText">{stats.totalRepos}+</strong> <strong>public repositories</strong> across PowerShell, Python, JavaScript, Kotlin, and C#.</p>
        <div class="about-signals" aria-label="Profile highlights">
          {aboutSignals.map((signal) => (
            <div class="about-signal">
              <span class="about-signal-label">{signal.label}</span>
              <strong class="about-signal-value">{signal.value}</strong>
              <p class="about-signal-meta">{signal.meta}</p>
            </div>
          ))}
        </div>
      </div>
      <div class="about-side rv s2">
        <div class="term about-terminal">
          <div class="tb"><span class="td r"></span><span class="td y"></span><span class="td g"></span><span class="tt">about.json</span></div>
          <div class="atb">
            <div><span class="tcm">&#123;</span></div>
            <div>&nbsp;&nbsp;<span class="tk">"role"</span><span class="tcm">:</span> <span class="ts">"Sr. Systems Administrator"</span><span class="tcm">,</span></div>
            <div>&nbsp;&nbsp;<span class="tk">"focus"</span><span class="tcm">:</span> <span class="ts">"Automation &amp; Open Source"</span><span class="tcm">,</span></div>
            <div>&nbsp;&nbsp;<span class="tk">"languages"</span><span class="tcm">:</span> <span class="tcm">[</span></div>
            <div>&nbsp;&nbsp;&nbsp;&nbsp;<span class="ts">"PowerShell"</span><span class="tcm">,</span> <span class="ts">"Python"</span><span class="tcm">,</span></div>
            <div>&nbsp;&nbsp;&nbsp;&nbsp;<span class="ts">"JavaScript"</span><span class="tcm">,</span> <span class="ts">"Kotlin"</span><span class="tcm">,</span> <span class="ts">"C#"</span><span class="tcm">,</span> <span class="ts">"C++"</span></div>
            <div>&nbsp;&nbsp;<span class="tcm">],</span></div>
            <div>&nbsp;&nbsp;<span class="tk">"philosophy"</span><span class="tcm">:</span> <span class="ts">"Works on first launch. Dark theme."</span><span class="tcm">,</span></div>
            <div>&nbsp;&nbsp;<span class="tk">"repos"</span><span class="tcm">:</span> <span class="tv" id="aboutRepos">{stats.totalRepos}</span><span class="tcm">,</span></div>
            <div>&nbsp;&nbsp;<span class="tk">"available"</span><span class="tcm">:</span> <span class="tv">true</span></div>
            <div><span class="tcm">&#125;</span></div>
          </div>
        </div>
        <div class="about-links" aria-label="About shortcuts">
          {aboutLinks.map((link) => (
            <a href={link.href} class="about-link">
              <span class="about-link-label">{link.label}</span>
              <span class="about-link-meta">{link.meta}</span>
            </a>
          ))}
        </div>
      </div>
    </div>
  </div></section>
  <Divider />

  <section id="philosophy"><div class="si">
    <div class="sh rv"><div class="sl">// Philosophy</div><h2 class="st">What Drives Me</h2><p class="sd">The principles behind every project I ship.</p></div>
    <div class="philosophy-intro rv">
      <div class="philosophy-copy-block">
        <div class="philosophy-kicker">Shipping Standard</div>
        <p class="philosophy-copy">The repo count matters less than the feeling after launch: clear intent, low setup anxiety, and enough polish that the software feels maintained before you read a line of documentation.</p>
      </div>
      <div class="philosophy-checks" aria-label="Build standards">
        {philosophyChecks.map((check) => <span>{check}</span>)}
      </div>
    </div>
    <div class="pg">
      {philosophyPrinciples.map((principle) => (
        <article class="prc card-enter" style={{ '--principle-bg': principle.bg, '--principle-accent': principle.accent }}>
          <div class="pri"><svg viewBox="0 0 24 24" stroke="var(--principle-accent)"><path d={principle.icon}></path></svg></div>
          <h3 class="prt">{principle.title}</h3>
          <p class="prd">{principle.desc}</p>
          <div class="prf">
            <span class="prf-label">Why it matters</span>
            <p class="prf-copy">{principle.note}</p>
          </div>
        </article>
      ))}
    </div>
  </div></section>
  <Divider />

  <section id="journey"><div class="si">
    <div class="sh rv"><div class="sl">// Journey</div><h2 class="st">How I Got Here</h2><p class="sd">Every project started with a problem nobody else was solving.</p></div>
    <div class="jw">
      {journeyMilestones.map((step) => (
        <a href={step.href} class="ji rv">
          <div class="jd"></div>
          <div class="jeyebrow">{step.eyebrow}</div>
          <h3 class="jt">{step.title}</h3>
          <p class="jdesc">
            {step.repoCount ? (
              <>Grew to <span id="journeyRepos">{stats.totalRepos}</span>+ {step.desc}</>
            ) : (
              step.desc
            )}
          </p>
          <div class="jfoot">
            <span class="jmeta">{step.meta}</span>
            <span class="jlink">{step.cta}</span>
          </div>
        </a>
      ))}
    </div>
  </div></section>
  <Divider />

  <section id="beyond"><div class="si">
    <div class="sh rv"><div class="sl">// Beyond Code</div><h2 class="st">When I'm Not Building</h2><p class="sd">Drone footage, original music, and everything outside the terminal.</p></div>
    <div class="beyond-overview rv">
      <a href="#beyond-video" class="beyond-card">
        <span class="beyond-card-kicker">Aerial Footage</span>
        <strong class="beyond-card-value">{aerialClips.length}</strong>
        <p class="beyond-card-copy">Florida coastline flight logs, captured as short visual resets away from the terminal.</p>
        <span class="beyond-card-cta">Jump to the videos</span>
      </a>
      <a href="#beyond-music" class="beyond-card">
        <span class="beyond-card-kicker">Slunder</span>
        <strong class="beyond-card-value">{albums.length}</strong>
        <p class="beyond-card-copy">Spotify releases built with Suno, shaping the same obsessive energy into music instead of software.</p>
        <span class="beyond-card-cta">Jump to the releases</span>
