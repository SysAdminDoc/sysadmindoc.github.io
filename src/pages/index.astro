---
import Base from '../layouts/Base.astro';
import Divider from '../components/Divider.astro';
import LiveCard from '../components/LiveCard.astro';
import CatalogEntry from '../components/CatalogEntry.astro';
import SkillCard from '../components/SkillCard.astro';
import GreatestHits from '../components/GreatestHits.astro';
import TagCloud from '../components/TagCloud.astro';
import { featured, liveApps, catalog, skills } from '../data/projects';
import { fallbackRepoCount } from '../data/derived';

// Build-time: load cached star counts + aggregate stats + per-repo metadata (fetch-stars.mjs).
let stars: Record<string, number> = {};
let meta: Record<string, { stars: number; pushedAt: string; updatedAt: string; language: string | null }> = {};
let stats = {
  totalRepos: fallbackRepoCount,
  totalStars: 0,
  lastPushedAt: null as string | null,
  lastPushedRepo: null as string | null,
  streak: 0,
  latestRelease: null as { repo: string; tag: string | null; at: string } | null,
  fetchedAt: null as string | null,
};
try {
  const mod = await import('../data/_stars.json');
  stars = (mod.default ?? mod) as Record<string, number>;
} catch {}
try {
  const mod = await import('../data/_stats.json');
  stats = { ...stats, ...(mod.default ?? mod) };
} catch {}
try {
  const mod = await import('../data/_meta.json');
  meta = (mod.default ?? mod) as typeof meta;
} catch {}

let releases: { repo: string; tag: string; name: string; publishedAt: string; url: string; bodyFirst: string }[] = [];
try {
  const mod = await import('../data/_releases.json');
  releases = (mod.default ?? mod) as typeof releases;
} catch {}
const latestRelease = releases[0];

// Derive category counts from catalog data (fixes hardcoded-count gotcha)
const catCounts: Record<string, number> = {};
for (const c of catalog) catCounts[c.category] = (catCounts[c.category] ?? 0) + 1;
const catalogTotal = catalog.length;

const filterButtons = [
  { key: 'ps', label: 'PowerShell' },
  { key: 'py', label: 'Python' },
  { key: 'web', label: 'Web Apps' },
  { key: 'ext', label: 'Extensions' },
  { key: 'kt', label: 'Android' },
  { key: 'sec', label: 'Security' },
  { key: 'media', label: 'Media' },
  { key: 'cs', label: 'Desktop' },
  { key: 'guide', label: 'Guides' },
];
const filterLabelByKey = Object.fromEntries(filterButtons.map((button) => [button.key, button.label]));
const heroSignatureProjects = featured.slice(0, 3);
const heroLaunchApps = liveApps.slice(0, 4);
const heroTopCategories = Object.entries(catCounts)
  .sort(([, a], [, b]) => b - a)
  .slice(0, 3)
  .map(([key, count]) => ({
    key,
    label: filterLabelByKey[key] ?? key,
    count,
  }));
const heroDomainText = heroTopCategories.map(({ label, count }) => `${label} ${count}`).join(' / ');
const heroSignalCategories = heroTopCategories.map(({ label }) => label).join(' / ');
const heroSignals = [
  {
    label: 'Current role',
    value: 'Sr. Tech Support Mgr',
    meta: 'Maven Imaging — PACS, DR panels, cloud migrations.',
  },
  {
    label: 'Scope',
    value: '10+ PACS migrations',
    meta: 'Medical imaging clinics across the Caribbean, East Africa, and East Asia. 15+ years in IT.',
  },
  {
    label: 'Strongest lanes',
    value: heroSignalCategories,
    meta: `Current mix: ${heroDomainText}.`,
  },
] as const;
const compactUtcDate = new Intl.DateTimeFormat('en-US', { month: 'short', day: 'numeric', year: 'numeric', timeZone: 'UTC' });
const heroReleaseDate = compactUtcDate;
const journeyMilestones = [
  {
    title: 'Healthcare IT & Systems Administration',
    eyebrow: 'Origin point',
    desc: 'Fifteen-plus years keeping Windows fleets, Cisco networks, and medical imaging systems running — from a Dayton MSP to PBS broadcast infrastructure to the PACS / DR / cloud-migration work I do now at Maven Imaging. The only stable path through complex environments is automating the parts you touch every day.',
    href: '/healthcare-it/',
    cta: 'Open the healthcare track',
    meta: 'Clinical systems, imaging uptime, and production-first tooling.',
  },
  {
    title: 'PowerShell & Windows Automation',
    eyebrow: 'Workflow cleanup',
    desc: 'Built Windows tools to solve real operational friction — NVMe driver patchers, network security auditors, Start Menu organizers, bulk installers. WPF interfaces that feel like finished software instead of internal scripts.',
    href: '/lang/powershell/',
    cta: 'See the PowerShell stack',
    meta: 'Provisioning, repair, compliance, and system management.',
  },
  {
    title: 'Python & Desktop Applications',
    eyebrow: 'Desktop expansion',
    desc: 'Moved into PyQt6 desktop apps for screenshot tooling, firewall management, image editing, PDF work, and more. The same rule held: bootstrap the dependencies, remove setup friction, and ship something people can actually launch right away.',
    href: '/lang/python/',
    cta: 'Browse the Python builds',
    meta: 'Local-first utilities, offline tools, and desktop workflows.',
  },
  {
    title: 'Web Apps & Live Deployments',
    eyebrow: 'Instant access',
    desc: `Launched ${liveApps.length}+ browser-ready apps on GitHub Pages — weather radar, flight tracking, OSINT aggregation, search engines, and utility tools. No backend required, no signup needed, just fast links that open and work.`,
    href: '#live',
    cta: 'Launch the live apps',
    meta: 'Browser tools that start without install, sign-in, or setup.',
  },
  {
    title: 'Full Stack & Beyond',
    eyebrow: 'Portfolio depth',
    desc: `${stats.totalRepos}+ public projects across six languages — Android apps in Kotlin, Chrome extensions, Tampermonkey userscripts, browser themes, desktop software, and a broad archive that still stays grounded in practical use cases.`,
    href: '#catalog',
    cta: 'Open the full catalog',
    meta: 'The complete archive, filters included.',
  },
] as const;
const connectPaths = [
  {
    title: 'GitHub workspace',
    handle: 'github.com/SysAdminDoc',
    href: 'https://github.com/SysAdminDoc',
    external: true,
    desc: 'Best for opening an issue, browsing the source, or grounding a conversation in a specific project.',
    meta: 'Public, traceable, and attached directly to the work.',
    cta: 'Open GitHub workspace',
    icon: 'github',
  },
  {
    title: 'Release stream',
    handle: '/releases',
    href: '/releases/',
    external: false,
    desc: 'See what is actively shipping, what just changed, and which parts of the portfolio are moving right now.',
    meta: 'Best if you want the current maintenance pulse first.',
    cta: 'Open release stream',
    icon: 'release',
  },
  {
    title: 'Current focus',
    handle: '/now',
    href: '/now/',
    external: false,
    desc: 'Quick snapshot of what I am building, polishing, and most likely to expand next.',
    meta: 'Best if you want to gauge timing and fit for new work.',
    cta: 'Open current focus',
    icon: 'pulse',
  },
] as const;
const stackRoutes = [
  { href: '/lang/powershell/', label: 'PowerShell', meta: 'Automation & WPF' },
  { href: '/lang/python/', label: 'Python', meta: 'Desktop & AI tools' },
  { href: '/lang/javascript/', label: 'JavaScript', meta: 'Extensions & web' },
  { href: '/lang/kotlin/', label: 'Kotlin', meta: 'Android apps' },
  { href: '/lang/security/', label: 'Security', meta: 'Audits & network hardening' },
] as const;
const aboutSignals = [
  { label: 'Day Job', value: 'Maven Imaging', meta: 'Senior Technical Support Manager — PACS migrations, DR panel deployments, cloud transitions, and international clinical support.' },
  { label: 'Reach', value: '3-continent support', meta: 'Medical imaging clinics across the Caribbean, East Africa, and East Asia — plus HIPAA-regulated clients stateside.' },
  { label: 'Public Archive', value: `${stats.totalRepos}+ projects`, meta: 'Fifteen-plus years of IT, compounded into a working body of PowerShell, Python, JavaScript, Kotlin, C#, and C++ tools.' },
] as const;
const aboutLinks = [
  { href: '/healthcare-it/', label: 'See the Healthcare Track', meta: 'The operational context, environments, and system work that shaped the portfolio.' },
  { href: '/now/', label: 'Open the Current Focus', meta: 'What is being built, refined, and most likely to expand next.' },
] as const;
const careerRoles = [
  {
    role: 'Senior Technical Support Manager',
    company: 'Maven Imaging',
    location: 'Sarasota, FL',
    period: 'Feb 2021 — Present',
    tag: 'Current',
    tone: 'current',
    summary: 'Tier II escalation lead for PACS, DR panels, and cloud migrations. Architected 10+ PACS migrations (including a 1M+ file Candelis legacy transfer when vendor tooling failed), drove a 54-account cross-vendor cloud restoration, and support clinics across the Caribbean, East Africa, and East Asia. Built the in-house tooling that makes it possible.',
    highlights: [
      'Led 10+ PACS migrations — single largest moved 1M+ files after writing a custom C-Store sender to bypass broken vendor tooling',
      'Restored 54 customer cloud accounts during a cross-vendor PatientImage / RADinfo transition',
      'Diagnosed and fixed a fleet-wide Windows 11 random-MAC licensing bug; set the shipping-PC standard to prevent recurrence',
      'Built production tooling adopted company-wide: DICOM PACS Migrator, RadAtlas, Generator Specs, WiFi Tool, acquisition-PC network scanner',
      'Produces the Maven Imaging YouTube tutorial library (VoyanceX, VXvue, Rayence, Genoray, AMRAD) and trains a major OEM\u2019s field engineers',
    ],
    stack: ['DICOM C-Store', 'Candelis ImageGrid', 'Voyance / VoyanceX', 'Patient Image Cloud', 'VXvue', 'Rayence DR', 'Hyper-V', 'UniFi VPN', 'Freshdesk'],
  },
  {
    role: 'Systems Administrator',
    company: 'ThinkTV (PBS Affiliate)',
    location: 'Dayton, OH',
    period: 'Apr 2014 — Feb 2025',
    tag: '~11 years',
    tone: 'previous',
    summary: 'Administered the full network and server stack for a regional PBS station serving Dayton and Cincinnati — physical and virtual Windows Servers, Cisco networking, SCCM, and the broadcast-automation infrastructure that had to stay on-air 24/7.',
    highlights: [
      'Led Hyper-V virtualization initiative, consolidating physical hardware',
      'Implemented SCCM from scratch to manage 100+ Win7/10 workstations',
      'Deployed Cisco ISR 4300, ASA firewalls, and Catalyst 2960/3560/SG300 switches',
      'Maintained Grass Valley K2 video servers + Harmonic encoders on the broadcast side',
    ],
    stack: ['Windows Server 2008–2016', 'Active Directory & GPO', 'Hyper-V', 'SCCM', 'PRTG', 'Cisco', 'Avaya VOIP'],
  },
  {
    role: 'IT Support Technician',
    company: 'Dayton Technology Group (MSP)',
    location: 'Dayton, OH',
    period: 'Jun 2010 — Apr 2014',
    tag: '~4 years',
    tone: 'previous',
    summary: 'Managed day-to-day operations across multiple MSP client environments — Active Directory, Group Policy, DNS/DHCP, legacy server decommissioning, and 24/7/365 network monitoring with escalation to senior admins when needed.',
    highlights: [
      'Migrated file servers + legacy apps off Windows Server 2003 R2 to 2012 R2',
      'Built network/system documentation — topology diagrams and runbooks',
      'Onboarded new users and trained them on workflows, software, and phone systems',
    ],
    stack: ['Windows Server 2003–2012 R2', 'Active Directory', 'Group Policy', 'Avaya IP Office', 'Endpoint security'],
  },
] as const;
const careerSignals = [
  { label: 'Tenure', value: '15+ years' },
  { label: 'Industries', value: 'Healthcare IT / Broadcast / MSP' },
  { label: 'Compliance', value: 'HIPAA / Gov / Academic' },
] as const;
const philosophyChecks = [
  'One launch path',
  'Readable defaults',
  'Open code by default',
] as const;
const philosophyPrinciples = [
  {
    title: 'Works On First Launch',
    desc: 'Download, launch, done. Tools auto-install their own dependencies and prerequisites. No setup wizards, no README scavenger hunts — if it takes more than one step to run, the build is not finished yet.',
    note: 'Onboarding should feel like opening software, not starting a project.',
    bg: 'var(--blued)',
    accent: 'var(--blue)',
    icon: 'M13 2L3 14h9l-1 8 10-12h-9l1-8z',
  },
  {
    title: "Build What's Missing",
    desc: "When the right tool does not exist, I build it. Most projects begin as a fix for personal operational friction, then grow into maintained software that solves the same problem for other people too.",
    note: 'The best backlog is the one you already trip over at work.',
    bg: 'var(--grnd)',
    accent: 'var(--grn)',
    icon: 'M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91a6 6 0 017.94-7.94l-3.76 3.76z',
  },
  {
    title: 'Always Dark',
    desc: 'Every interface ships with a premium dark theme. The goal is not decoration; it is a calmer workspace with stronger contrast, cleaner hierarchy, and less fatigue over long sessions.',
    note: 'A tool people stare at for hours should feel composed, not harsh.',
    bg: 'var(--purd)',
    accent: 'var(--pur)',
    icon: 'M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z',
  },
  {
    title: 'Open by Default',
    desc: `Everything ships in public. ${stats.totalRepos}+ projects and growing, with transparent code, direct launches, and a bias toward tools that work for anyone in any environment.`,
    note: 'Trust comes faster when the work is inspectable and easy to try.',
    bg: 'var(--orgd)',
    accent: 'var(--org)',
    icon: 'M16 18l6-6-6-6M8 6l-6 6 6 6',
  },
] as const;
const aerialClips = [
  {id:'waOMwX39NOg', title:'Venice Beach, Florida', desc:'Morning aerial flight — June 2023'},
  {id:'xnpOENxAx-k', title:'Manasota Beach, Florida', desc:'Coastal drone footage over Manasota Key'},
  {id:'PnlsSqa8DtQ', title:'Venice Jetty', desc:'Aerial view of the Venice, Florida jetty'},
  {id:'FVroPKvYgKQ', title:'Nokomis Beach, Florida', desc:'Drone flight over Nokomis Beach'},
] as const;
const albums = [
  {id:'7xHMgXflIR9qRtjU39Q80t', art:'ab67616d00001e02e042810ddecccc2339656b49', name:'Push The Button', year:2026},
  {id:'7KlKXiga7kHUOgC8LeyKH4', art:'ab67616d00001e027c428d22537bec2ed4af94d8', name:'Game Over', year:2026},
  {id:'3NQ019Wd8fjtSCCQcK1WDH', art:'ab67616d00001e02f8ef4af6c2f7c3c8f592ebcb', name:'Saltwater in My Veins', year:2025},
  {id:'66iCBrYX5vrYn7LvPd2P5d', art:'ab67616d00001e029d375d3a3ad769fda8e2af93', name:'Unmasked', year:2025},
  {id:'39NZL7jH79wznqPBvr7Fwt', art:'ab67616d00001e026ed0117b585d98248228e17c', name:'Apocalypse', year:2025},
  {id:'2FsIqZY3LW1pTCjEb7URJk', art:'ab67616d00001e0234b30d89e374047ef7ecd730', name:'Thanks for Giving Up', year:2025},
] as const;
const earliestAlbumYear = Math.min(...albums.map((album) => album.year));
const latestAlbumYear = Math.max(...albums.map((album) => album.year));
const latestAlbumName = albums.find((album) => album.year === latestAlbumYear)?.name ?? albums[0]?.name ?? 'Latest release';
const projectNameMap = new Map<string, string>();
featured.forEach((project) => projectNameMap.set(project.repo, project.name));
liveApps.forEach((app) => projectNameMap.set(app.slug, app.name));
catalog.forEach((entry) => projectNameMap.set(entry.repo, entry.name));
const latestReleaseName = latestRelease ? latestRelease.name ?? projectNameMap.get(latestRelease.repo) ?? latestRelease.repo : null;
const lastPushedProjectName = stats.lastPushedRepo ? projectNameMap.get(stats.lastPushedRepo) ?? stats.lastPushedRepo : null;
const cmdkSections = [
  { label: 'Highlights', href: '#greatest-hits', desc: 'Start with the shortlist of projects that best explain the portfolio.', badge: 'START' },
  { label: 'Catalog', href: '#catalog', desc: 'Every public project, filterable by language and domain.', badge: 'ARCHIVE' },
  { label: 'Live Apps', href: '#live', desc: 'Launch-ready browser apps with no setup wall.', badge: 'LIVE' },
  { label: 'Stack', href: '#skills', desc: 'Languages, tooling, and where the work clusters.', badge: 'SECTION' },
  { label: 'About', href: '#about', desc: 'Background, operating style, and what drives the work.', badge: 'SECTION' },
  { label: 'Career', href: '#career', desc: '15+ years across healthcare imaging, PBS broadcast, and managed services.', badge: 'SECTION' },
  { label: 'Philosophy', href: '#philosophy', desc: 'The product standards behind every project.', badge: 'SECTION' },
  { label: 'Journey', href: '#journey', desc: 'How the portfolio expanded across platforms.', badge: 'SECTION' },
  { label: 'Beyond Code', href: '#beyond', desc: 'Drone work, music, and the rest of the creative output.', badge: 'SECTION' },
  { label: 'Connect', href: '#connect', desc: 'Best ways to collaborate and what to bring.', badge: 'SECTION' },
] as const;
---
<Base cmdkSections={cmdkSections}>
  <a href="#main" class="skip-link">Skip to content</a>

  <nav id="nav" aria-label="Main navigation">
    <div class="ni">
      <a href="#hero" class="nl">matt<span>@</span>sysadmin<span>:~$</span></a>
      <div class="nk" id="navLinks">
        <a href="#greatest-hits">Hits</a>
        <a href="#live">Live</a>
        <a href="#catalog">Catalog</a>
        <a href="/releases/">Releases</a>
        <a href="/now/">Now</a>
        <a href="#about">About</a>
        <a href="#career">Career</a>
        <div class="nav-indicator" id="navIndicator"></div>
      </div>
      <div class="nav-actions">
        <button type="button" class="theme-toggle" id="themeToggle" aria-label="Switch to light theme" title="Switch to light theme"><svg viewBox="0 0 24 24"><path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"/></svg></button>
        <button type="button" class="nav-search" id="cmdkToggle" aria-label="Open command palette (Ctrl or Cmd + K)" aria-controls="cmdk" aria-expanded="false" aria-haspopup="dialog" title="Search (Ctrl/Cmd + K)">
          <svg viewBox="0 0 24 24" stroke-width="2" fill="none" stroke="currentColor" stroke-linecap="round"><circle cx="11" cy="11" r="7"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          <span class="nav-search-label">Search</span>
          <span class="nav-search-kbd" aria-hidden="true">Ctrl K</span>
        </button>
        <a href="https://github.com/SysAdminDoc" target="_blank" rel="noopener" class="ng" aria-label="GitHub Profile"><svg viewBox="0 0 16 16"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>GitHub</a>
        <button type="button" class="mt" id="mobileToggle" aria-label="Toggle navigation menu" aria-controls="navLinks" aria-expanded="false"><svg viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg></button>
      </div>
    </div>
  </nav>
  <div class="scroll-progress" id="scrollProgress"></div>

  <main id="main">
  <section class="hero" id="hero">
    <div class="hero-grid" aria-hidden="true"></div>
    <div class="hi">
      <div class="ht">
        <div class="hero-brandline">SysAdminDoc <span>/</span> Open Source Portfolio</div>
        <img class="hero-avatar" id="heroAvatar" src="data:image/gif;base64,R0lGODlhAQABAAAAACw=" alt="Matt Parker" width="56" height="56" decoding="async">
        <div class="htag" id="heroTag"><span class="dot"></span> Open for thoughtful collaboration</div>
        <h1 class="hn">Matt <span class="a">Parker</span></h1>
        <p class="hr">Senior Technical Support Manager &amp; systems administrator with 15+ years in the trenches &mdash; medical imaging (DICOM/PACS), enterprise infrastructure, and the open-source tools that grew out of that work.</p>
        <p class="hd">By day I architect PACS migrations, DR panel deployments, and cloud transitions for healthcare facilities. By night (and most weekends) I ship the utilities that should have existed already: fast starts, calm UX, offline resilience, and direct access to the source.</p>
        <div class="hs">
          <div class="hs-item"><div class="hsn" id="statRepos" data-live>{stats.totalRepos}</div><div class="hsl">Projects</div></div>
          <div class="hs-item"><div class="hsn" id="statStars" data-live>{stats.totalStars}</div><div class="hsl">Stars</div></div>
          <div class="hs-item"><div class="hsn" id="statLive">{liveApps.length}</div><div class="hsl">Live Apps</div></div>
        </div>
        <div class="hero-pulse">
          <span class="pulse-dot"></span>
          {stats.streak > 0 && (
            <a href="/now/" class="pulse-item" title="90-day commit streak">
              <span class="pulse-k">streak</span>
              <span class="pulse-v">{stats.streak}d</span>
            </a>
          )}
          {latestRelease && (
            <a href={latestRelease.url} target="_blank" rel="noopener" class="pulse-item" title={`Released ${heroReleaseDate.format(new Date(latestRelease.publishedAt))}`}>
              <span class="pulse-k">latest</span>
              <span class="pulse-v">{latestReleaseName} {latestRelease.tag && <span class="pulse-sub">{latestRelease.tag}</span>}</span>
            </a>
          )}
          {stats.lastPushedRepo && stats.lastPushedAt && (
            <a href={`https://github.com/SysAdminDoc/${stats.lastPushedRepo}`} target="_blank" rel="noopener" class="pulse-item" title={lastPushedProjectName ? `Last push to ${lastPushedProjectName}` : `Last push ${stats.lastPushedAt}`}>
              <span class="pulse-k">pushed</span>
              <span class="pulse-v"><time datetime={stats.lastPushedAt} data-rel={stats.lastPushedAt}>{compactUtcDate.format(new Date(stats.lastPushedAt))}</time>{lastPushedProjectName && <span class="pulse-sub">{lastPushedProjectName}</span>}</span>
            </a>
          )}
        </div>
        <div class="ha">
          <a href="#greatest-hits" class="btn bp"><svg viewBox="0 0 16 16" fill="currentColor"><path d="M2 2.5A2.5 2.5 0 014.5 0h8.75a.75.75 0 01.75.75v12.5a.75.75 0 01-.75.75h-2.5a.75.75 0 110-1.5h1.75v-2h-8a1 1 0 00-.714 1.7.75.75 0 01-1.072 1.05A2.495 2.495 0 012 11.5v-9zm10.5-1h-8a1 1 0 00-1 1v6.708A2.486 2.486 0 014.5 9h8V1.5z"/></svg>Start with the strongest work</a>
          <a href="https://github.com/SysAdminDoc" target="_blank" rel="noopener" class="btn bg2"><svg viewBox="0 0 16 16" fill="currentColor"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>View the GitHub archive</a>
        </div>
        <div class="hero-signals" aria-label="Portfolio differentiators">
          {heroSignals.map((signal) => (
            <div class="hero-signal" title={signal.meta}>
              <span class="hero-signal-label">{signal.label}</span>
              <strong class="hero-signal-value">{signal.value}</strong>
