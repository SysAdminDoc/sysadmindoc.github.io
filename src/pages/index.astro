---
import Base from '../layouts/Base.astro';
import Divider from '../components/Divider.astro';
import FeaturedCard from '../components/FeaturedCard.astro';
import LiveCard from '../components/LiveCard.astro';
import CatalogEntry from '../components/CatalogEntry.astro';
import SkillCard from '../components/SkillCard.astro';
import { featured, liveApps, catalog, skills } from '../data/projects';

// Build-time: load cached star counts + aggregate stats (scripts/fetch-stars.mjs).
let stars: Record<string, number> = {};
let stats = {
  totalRepos: 134,
  totalStars: 0,
  lastPushedAt: null as string | null,
  lastPushedRepo: null as string | null,
  fetchedAt: null as string | null,
};
try {
  const mod = await import('../data/_stars.json');
  stars = (mod.default ?? mod) as Record<string, number>;
} catch { /* no cache yet */ }
try {
  const mod = await import('../data/_stats.json');
  stats = { ...stats, ...(mod.default ?? mod) };
} catch { /* no cache yet */ }

// Derive category counts from catalog data (fixes hardcoded-count gotcha)
const catCounts: Record<string, number> = {};
for (const c of catalog) catCounts[c.category] = (catCounts[c.category] ?? 0) + 1;
const catalogTotal = catalog.length;

const filterButtons = [
  { key: 'ps', label: 'PowerShell' },
  { key: 'py', label: 'Python' },
  { key: 'web', label: 'Web Apps' },
  { key: 'ext', label: 'Extensions' },
  { key: 'kt', label: 'Android' },
  { key: 'sec', label: 'Security' },
  { key: 'media', label: 'Media' },
  { key: 'cs', label: 'Desktop' },
  { key: 'guide', label: 'Guides' },
];
---
<Base>
  <a href="#hero" class="skip-link">Skip to content</a>
  <div id="loader"><div class="lp">initializing portfolio<span class="lc"></span></div><div class="lbt"><div class="lb" id="loaderBar"></div></div></div>
  <canvas id="particles"></canvas>
  <script is:inline>if(innerWidth>=768){document.write('<div class="cc-dot" id="ccDot"></div><div class="cc-ring" id="ccRing"></div>')}</script>

  <nav id="nav" aria-label="Main navigation">
    <div class="ni">
      <a href="#hero" class="nl">matt<span>@</span>sysadmin<span>:~$</span></a>
      <div class="nk" id="navLinks">
        <a href="#featured">Projects</a>
        <a href="#live">Live Apps</a>
        <a href="#catalog">Catalog</a>
        <a href="#skills">Stack</a>
        <a href="#about">About</a>
        <a href="#beyond">Beyond Code</a>
        <a href="#connect">Connect</a>
        <div class="nav-indicator" id="navIndicator"></div>
      </div>
      <div style="display:flex;align-items:center;gap:8px">
        <button class="theme-toggle" id="themeToggle" aria-label="Toggle theme" title="Toggle theme"><svg viewBox="0 0 24 24"><path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"/></svg></button>
        <button class="theme-toggle" id="cmdkToggle" aria-label="Open command palette (Ctrl+K)" title="Search (Ctrl+K)"><svg viewBox="0 0 24 24" stroke-width="2" fill="none" stroke="currentColor" stroke-linecap="round"><circle cx="11" cy="11" r="7"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg></button>
        <a href="https://github.com/SysAdminDoc" target="_blank" rel="noopener" class="ng" aria-label="GitHub Profile"><svg viewBox="0 0 16 16"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>GitHub</a>
        <button class="mt" id="mobileToggle" aria-label="Toggle navigation menu"><svg viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg></button>
      </div>
    </div>
  </nav>
  <div class="scroll-progress" id="scrollProgress"></div>

  <section class="hero" id="hero">
    <div class="hi">
      <div class="ht">
        <img class="hero-avatar" id="heroAvatar" src="" alt="Matt Parker">
        <div class="htag" id="heroTag"><span class="dot"></span> Available for collaboration</div>
        <h1 class="hn">Matt <span class="a">Parker</span></h1>
        <p class="hr">Sr. Systems Administrator &amp; Builder</p>
        <p class="hd">I build the tools I wish existed. Zero-config utilities, browser enhancements, desktop and mobile applications, and automation scripts &mdash; all open source, all ready to run.</p>
        <div class="hs">
          <div class="hs-item"><div class="hsn" id="statRepos" data-live>{stats.totalRepos}</div><div class="hsl">Repositories</div></div>
          <div class="hs-item"><div class="hsn" id="statStars" data-live>{stats.totalStars}</div><div class="hsl">Stars</div></div>
          <div class="hs-item"><div class="hsn" id="statLive">{liveApps.length}</div><div class="hsl">Live Apps</div></div>
        </div>
        <div class="last-active" id="lastActive"><span class="la-dot"></span> <span id="lastActiveText">Checking activity...</span><span id="streakBadge"></span></div>
        <div class="ha">
          <a href="#featured" class="btn bp"><svg viewBox="0 0 16 16" fill="currentColor"><path d="M2 2.5A2.5 2.5 0 014.5 0h8.75a.75.75 0 01.75.75v12.5a.75.75 0 01-.75.75h-2.5a.75.75 0 110-1.5h1.75v-2h-8a1 1 0 00-.714 1.7.75.75 0 01-1.072 1.05A2.495 2.495 0 012 11.5v-9zm10.5-1h-8a1 1 0 00-1 1v6.708A2.486 2.486 0 014.5 9h8V1.5z"/></svg>View Projects</a>
          <a href="https://github.com/SysAdminDoc" target="_blank" rel="noopener" class="btn bg2"><svg viewBox="0 0 16 16" fill="currentColor"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>GitHub Profile</a>
        </div>
      </div>
      <div class="term" id="heroTerm" role="region" aria-label="Interactive terminal" tabindex="0"><div class="tb"><span class="td r"></span><span class="td y"></span><span class="td g"></span><span class="tt">matt@sysadmin: ~/portfolio</span></div><div class="tbd" id="termBody"></div><div class="term-hint" id="termHint">click terminal or start typing to interact</div></div>
    </div>
  </section>

  <svg style="position:absolute;width:0;height:0"><defs><linearGradient id="waveGrad" x1="0%" y1="0%" x2="100%" y2="0%"><stop offset="0%" stop-color="var(--blue)" stop-opacity="0"/><stop offset="30%" stop-color="var(--blue)"/><stop offset="50%" stop-color="var(--pur)"/><stop offset="70%" stop-color="var(--teal)"/><stop offset="100%" stop-color="var(--teal)" stop-opacity="0"/></linearGradient></defs></svg>
  <div class="push-ribbon" id="pushRibbon" style="display:none"></div>
  <Divider />

  <section id="featured"><div class="si">
    <div class="sh rv"><div class="sl">// Featured</div><h2 class="st">Top Projects</h2><p class="sd">Handpicked highlights &mdash; star counts live from GitHub.</p></div>
    <div class="fg" id="featuredGrid">
      {featured.map((p) => <FeaturedCard project={p} stars={stars[p.repo]} />)}
    </div>
  </div></section>
  <Divider />

  <section id="live"><div class="si">
    <div class="sh rv"><div class="sl">// Live</div><h2 class="st">Try in Your Browser</h2><p class="sd">No install, no signup &mdash; click and go.</p></div>
    <div class="lg">
      {liveApps.map((a) => <LiveCard app={a} />)}
    </div>
  </div></section>
  <Divider />

  <section id="catalog"><div class="si">
    <div class="sh rv"><div class="sl">// Catalog</div><h2 class="st">All Repositories</h2><p class="sd">The full collection &mdash; search, filter, sort. Star counts pulled live.</p></div>
    <div class="catalog-controls rv">
      <div class="search-wrap">
        <svg viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <input type="text" class="search-input" id="searchInput" placeholder="Search repositories..." autocomplete="off" aria-label="Search repositories">
      </div>
      <select class="sort-select" id="sortSelect" aria-label="Sort repositories">
        <option value="default">Default order</option>
        <option value="stars">Most stars</option>
        <option value="name">A-Z</option>
        <option value="name-desc">Z-A</option>
        <option value="recent">Recently updated</option>
      </select>
    </div>
    <div class="cf rv" id="filterBtns" role="group" aria-label="Filter by category">
      <button class="fb act" data-filter="all">All <span class="fc" id="countAll">{catalogTotal}</span></button>
      {filterButtons.map((f) => (
        <button class="fb" data-filter={f.key}>{f.label} <span class="fc" data-cat={f.key}>{catCounts[f.key] ?? 0}</span></button>
      ))}
    </div>
    <div class="cg" id="catalogGrid">
      {catalog.map((entry) => <CatalogEntry entry={entry} stars={stars[entry.repo]} />)}
    </div>
  </div></section>
  <Divider />

  <section id="skills"><div class="si">
    <div class="sh rv"><div class="sl">// Stack</div><h2 class="st">Languages &amp; Tools</h2></div>
    <div class="skg">
      {skills.map((s) => <SkillCard skill={s} />)}
    </div>
    <div class="lang-donut-wrap rv" id="langDonut"></div>
  </div></section>
  <Divider />

  <section id="about"><div class="si">
    <div class="sh rv"><div class="sl">// About</div><h2 class="st">Who I Am</h2></div>
    <div class="ac">
      <div class="rv">
        <p class="atp">I'm a <strong>Senior Systems Administrator</strong> by day &mdash; provisioning workstations, managing networks, and keeping medical imaging systems running for healthcare facilities.</p>
        <p class="atp">After hours, I build the tools I can't find anywhere else. What starts as a quick fix for a personal annoyance usually turns into a full-featured open source project. That pattern has produced <strong id="aboutReposText">{stats.totalRepos}+</strong> <strong>public repositories</strong> across PowerShell, Python, JavaScript, Kotlin, and C#.</p>
        <p class="atp">Everything I ship follows the same philosophy: <strong>zero configuration, dark theme, works on first launch.</strong> No setup wizards, no dependency hunts. If it takes more than one step to run, I haven't finished building it yet.</p>
      </div>
      <div class="term rv s2">
        <div class="tb"><span class="td r"></span><span class="td y"></span><span class="td g"></span><span class="tt">about.json</span></div>
        <div class="atb">
          <div><span class="tcm">&#123;</span></div>
          <div>&nbsp;&nbsp;<span class="tk">"role"</span><span class="tcm">:</span> <span class="ts">"Sr. Systems Administrator"</span><span class="tcm">,</span></div>
          <div>&nbsp;&nbsp;<span class="tk">"focus"</span><span class="tcm">:</span> <span class="ts">"Automation &amp; Open Source"</span><span class="tcm">,</span></div>
          <div>&nbsp;&nbsp;<span class="tk">"languages"</span><span class="tcm">:</span> <span class="tcm">[</span></div>
          <div>&nbsp;&nbsp;&nbsp;&nbsp;<span class="ts">"PowerShell"</span><span class="tcm">,</span> <span class="ts">"Python"</span><span class="tcm">,</span></div>
          <div>&nbsp;&nbsp;&nbsp;&nbsp;<span class="ts">"JavaScript"</span><span class="tcm">,</span> <span class="ts">"Kotlin"</span><span class="tcm">,</span> <span class="ts">"C#"</span><span class="tcm">,</span> <span class="ts">"C++"</span></div>
          <div>&nbsp;&nbsp;<span class="tcm">],</span></div>
          <div>&nbsp;&nbsp;<span class="tk">"philosophy"</span><span class="tcm">:</span> <span class="ts">"Zero config. Dark theme."</span><span class="tcm">,</span></div>
          <div>&nbsp;&nbsp;<span class="tk">"repos"</span><span class="tcm">:</span> <span class="tv" id="aboutRepos">{stats.totalRepos}</span><span class="tcm">,</span></div>
          <div>&nbsp;&nbsp;<span class="tk">"available"</span><span class="tcm">:</span> <span class="tv">true</span></div>
          <div><span class="tcm">&#125;</span></div>
        </div>
      </div>
    </div>
  </div></section>
  <Divider />

  <section id="philosophy"><div class="si">
    <div class="sh rv"><div class="sl">// Philosophy</div><h2 class="st">What Drives Me</h2><p class="sd">The principles behind every project I ship.</p></div>
    <div class="pg">
      <div class="prc card-enter">
        <div class="pri" style="background:var(--blued)"><svg viewBox="0 0 24 24" stroke="var(--blue)"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg></div>
        <h3 class="prt">Zero Configuration</h3>
        <p class="prd">Download it, launch it, done. Every tool auto-installs its own dependencies, auto-configures prerequisites, and works on first run. No setup wizards, no README scavenger hunts.</p>
      </div>
      <div class="prc card-enter">
        <div class="pri" style="background:var(--grnd)"><svg viewBox="0 0 24 24" stroke="var(--grn)"><path d="M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91a6 6 0 017.94-7.94l-3.76 3.76z"/></svg></div>
        <h3 class="prt">Build What's Missing</h3>
        <p class="prd">When I can't find the right tool, I build it. What starts as a fix for a personal annoyance usually turns into a full-featured project that solves the problem for everyone.</p>
      </div>
      <div class="prc card-enter">
        <div class="pri" style="background:var(--purd)"><svg viewBox="0 0 24 24" stroke="var(--pur)"><path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"/></svg></div>
        <h3 class="prt">Always Dark</h3>
        <p class="prd">Every interface ships with a premium dark theme. Deep palettes, glassmorphism, polished UI. I build tools I want to stare at for hours &mdash; and that means dark mode, always.</p>
      </div>
      <div class="prc card-enter">
        <div class="pri" style="background:var(--orgd)"><svg viewBox="0 0 24 24" stroke="var(--org)"><path d="M16 18l6-6-6-6M8 6l-6 6 6 6"/></svg></div>
        <h3 class="prt">Open by Default</h3>
        <p class="prd">Everything I build is public. <span id="philRepos">{stats.totalRepos}</span>+ repositories and growing. I believe the best tools are free, transparent, and built to work for anyone in any environment.</p>
      </div>
    </div>
  </div></section>
  <Divider />

  <section id="journey"><div class="si">
    <div class="sh rv"><div class="sl">// Journey</div><h2 class="st">How I Got Here</h2><p class="sd">Every project started with a problem nobody else was solving.</p></div>
    <div class="jw">
      <div class="ji rv"><div class="jd"></div><h3 class="jt">Healthcare IT &amp; Systems Administration</h3><p class="jdesc">Started in the deep end &mdash; provisioning workstations, managing networks, and keeping medical imaging systems running across healthcare facilities. Learned that the best way to survive complex environments is to automate everything you can.</p></div>
      <div class="ji rv"><div class="jd"></div><h3 class="jt">PowerShell &amp; Windows Automation</h3><p class="jdesc">Built comprehensive Windows tools to solve real problems &mdash; NVMe driver patchers, network security auditors, Start Menu organizers, bulk installers. WPF interfaces that look and feel like premium software.</p></div>
      <div class="ji rv"><div class="jd"></div><h3 class="jt">Python &amp; Desktop Applications</h3><p class="jdesc">Expanded into PyQt6 desktop apps &mdash; screenshot tools, firewall managers, image editors, PDF tools, and more. Every one bootstraps its own dependencies and launches with zero setup.</p></div>
      <div class="ji rv"><div class="jd"></div><h3 class="jt">Web Apps &amp; Live Deployments</h3><p class="jdesc">Launched {liveApps.length}+ web applications on GitHub Pages &mdash; weather radar, flight tracking, OSINT aggregation, search engines. No backend required, no signup needed. Click a link and it just works.</p></div>
      <div class="ji rv"><div class="jd"></div><h3 class="jt">Full Stack &amp; Beyond</h3><p class="jdesc">Grew to <span id="journeyRepos">{stats.totalRepos}</span>+ open source repos across six languages. Android apps in Kotlin, Chrome extensions, Tampermonkey userscripts, browser themes. If there's a platform, I've probably shipped something on it.</p></div>
    </div>
  </div></section>
  <Divider />

  <section id="beyond"><div class="si">
    <div class="sh rv"><div class="sl">// Beyond Code</div><h2 class="st">When I'm Not Building</h2><p class="sd">Drone footage, original music, and everything outside the terminal.</p></div>

    <h3 class="beyond-subtitle rv">Aerial Footage</h3>
    <div class="video-grid" style="margin-bottom:60px">
      {[
        {id:'waOMwX39NOg', title:'Venice Beach, Florida', desc:'Morning aerial flight — June 2023'},
        {id:'xnpOENxAx-k', title:'Manasota Beach, Florida', desc:'Coastal drone footage over Manasota Key'},
        {id:'PnlsSqa8DtQ', title:'Venice Jetty', desc:'Aerial view of the Venice, Florida jetty'},
        {id:'FVroPKvYgKQ', title:'Nokomis Beach, Florida', desc:'Drone flight over Nokomis Beach'},
      ].map((v) => (
        <div class="video-card card-enter">
          <div class="video-thumb" data-yt={v.id} tabindex="0" role="button" aria-label={`Play ${v.title} video`}>
            <img src={`https://img.youtube.com/vi/${v.id}/maxresdefault.jpg`} onerror="this.src=this.src.replace('maxresdefault','hqdefault')" alt={v.title} loading="lazy">
            <div class="play-btn"><svg viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg></div>
          </div>
          <div class="video-info"><div class="video-title">{v.title}</div><div class="video-desc">{v.desc}</div></div>
        </div>
      ))}
    </div>

    <h3 class="beyond-subtitle rv">Music &mdash; Made with Suno</h3>
    <div class="music-layout">
      <div>
        <div class="music-hero card-enter">
          <div class="music-art">
            <div class="music-art-glow"><img src="https://i.scdn.co/image/ab67616100005174dd857aa31d70bb7f50b4f4f4" alt=""></div>
            <img src="https://i.scdn.co/image/ab67616100005174dd857aa31d70bb7f50b4f4f4" alt="Slunder">
          </div>
          <div class="music-details">
            <h3>Slunder</h3>
            <div class="music-sub">Synthesizing art and intellect into a personal soundtrack.</div>
            <a href="https://open.spotify.com/artist/48Fd3yL6KvxtZO0MOPZYHW" target="_blank" rel="noopener" class="spotify-btn"><svg viewBox="0 0 24 24"><path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.419 1.56-.299.421-1.02.599-1.559.3z"/></svg>Listen on Spotify</a>
          </div>
        </div>
        <div style="margin-top:20px">
          <div class="album-grid">
            {[
              {id:'7xHMgXflIR9qRtjU39Q80t', art:'ab67616d00001e02e042810ddecccc2339656b49', name:'Push The Button', year:2026},
              {id:'7KlKXiga7kHUOgC8LeyKH4', art:'ab67616d00001e027c428d22537bec2ed4af94d8', name:'Game Over', year:2026},
              {id:'3NQ019Wd8fjtSCCQcK1WDH', art:'ab67616d00001e02f8ef4af6c2f7c3c8f592ebcb', name:'Saltwater in My Veins', year:2025},
              {id:'66iCBrYX5vrYn7LvPd2P5d', art:'ab67616d00001e029d375d3a3ad769fda8e2af93', name:'Unmasked', year:2025},
              {id:'39NZL7jH79wznqPBvr7Fwt', art:'ab67616d00001e026ed0117b585d98248228e17c', name:'Apocalypse', year:2025},
              {id:'2FsIqZY3LW1pTCjEb7URJk', art:'ab67616d00001e0234b30d89e374047ef7ecd730', name:'Thanks for Giving Up', year:2025},
            ].map((a) => (
              <a href={`https://open.spotify.com/album/${a.id}`} target="_blank" rel="noopener" class="album-card card-enter">
                <div class="album-art"><img src={`https://i.scdn.co/image/${a.art}`} alt={a.name} loading="lazy"><div class="album-art-overlay"><svg viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg></div></div>
                <div class="album-info"><div class="album-name">{a.name}</div><div class="album-year">{a.year}</div></div>
              </a>
            ))}
          </div>
        </div>
      </div>
      <div>
        <div class="spotify-embed-wrap card-enter" id="spotifyWrap" data-src="https://open.spotify.com/embed/artist/48Fd3yL6KvxtZO0MOPZYHW?utm_source=generator&theme=0" style="min-height:740px"></div>
      </div>
    </div>
  </div></section>
  <Divider />

  <section id="connect"><div class="si">
    <div class="sh rv"><div class="sl">// Connect</div><h2 class="st">Let's Build Something</h2></div>
    <p class="connect-msg rv">I'm always open to collaboration, interesting problems, and new opportunities. The best way to reach me is through GitHub &mdash; open an issue, start a discussion, or just say hello.</p>
    <div class="cng">
