---
import Base from '../layouts/Base.astro';
import Divider from '../components/Divider.astro';
import LiveCard from '../components/LiveCard.astro';
import CatalogEntry from '../components/CatalogEntry.astro';
import SkillCard from '../components/SkillCard.astro';
import GreatestHits from '../components/GreatestHits.astro';
import { featured, liveApps, catalog, skills } from '../data/portfolio';
import { fallbackRepoCount } from '../data/derived';
import {
  computeProjectRankings,
  formatProjectRankingDisplayLabel,
  formatProjectRankingLabel,
  getReleaseDownloadTotals,
  rankCatalogEntries,
} from '../data/project-ranking.mjs';
import { careerRoles } from '../data/career';
import {
  computeCatalogViewState,
  computeViewCounts,
  computeCategoryCounts,
} from '../data/catalog-views.mjs';
import {
  DONUT_R,
  buildDonutLangCount,
  computeDonutArcs,
} from '../data/svg-arc.mjs';

// Build-time: load cached star counts + aggregate stats + per-repo metadata (fetch-stars.mjs).
let stars: Record<string, number> = {};
let meta: Record<string, { stars: number; pushedAt: string; updatedAt: string; language: string | null }> = {};
let stats = {
  totalRepos: fallbackRepoCount,
  totalStars: 0,
  lastPushedAt: null as string | null,
  lastPushedRepo: null as string | null,
  streak: 0,
  latestRelease: null as { repo: string; tag: string | null; at: string } | null,
  avatarUrl: null as string | null,
  pushDays: [] as string[],
  fetchedAt: null as string | null,
};
try {
  const mod = await import('../data/_stars.json');
  stars = (mod.default ?? mod) as Record<string, number>;
} catch {}
try {
  const mod = await import('../data/_stats.json');
  stats = { ...stats, ...(mod.default ?? mod) };
} catch {}
try {
  const mod = await import('../data/_meta.json');
  meta = (mod.default ?? mod) as typeof meta;
} catch {}

let releases: { repo: string; tag: string; name: string; publishedAt: string; url: string; downloads?: number; bodyFirst: string }[] = [];
try {
  const mod = await import('../data/_releases.json');
  releases = (mod.default ?? mod) as typeof releases;
} catch {}
const latestRelease = releases[0];
const releaseDownloadTotals = getReleaseDownloadTotals(releases);
const releaseDownloadRepos = new Set(
  [...releaseDownloadTotals.entries()]
    .filter(([, downloads]) => downloads > 0)
    .map(([repo]) => repo),
);
const freshnessReference = new Date(stats.fetchedAt ?? stats.lastPushedAt ?? Date.now()).getTime();
const projectRankings = computeProjectRankings(catalog, {
  stars,
  meta,
  releaseDownloadTotals,
  referenceDate: stats.fetchedAt ?? stats.lastPushedAt ?? Date.now(),
});
const rankedCatalog = rankCatalogEntries(catalog, projectRankings);
const catalogViewState = computeCatalogViewState(catalog, {
  meta,
  releaseDownloadRepos,
  referenceMs: freshnessReference,
});
const viewCounts = computeViewCounts(catalogViewState);

// Derive category counts from catalog data (fixes hardcoded-count gotcha)
const catCounts = computeCategoryCounts(catalog);
const catalogTotal = catalog.length;
const publicProjectCount = catalogTotal;

// Build-time language mix from cached _meta.json so the Stack donut renders real
// data with no JS / offline / rate-limited. home-github.js refreshes it from the
// live API on capable clients. Mirrors renderLangDonut() in that feature script.
const { langCount: buildLangCount, total: donutTotal } = buildDonutLangCount(catalog, meta);
const donutArcs = computeDonutArcs(buildLangCount, donutTotal);
const donutLead = donutArcs[0];
const donutLeadLang = donutLead ? donutLead.lang : 'Mixed';
const donutLeadPct = donutLead ? donutLead.pct : 0;

const filterButtons = [
  { key: 'ps', label: 'PowerShell' },
  { key: 'py', label: 'Python' },
  { key: 'web', label: 'Web Apps' },
  { key: 'ext', label: 'Extensions' },
  { key: 'kt', label: 'Android' },
  { key: 'sec', label: 'Security' },
  { key: 'media', label: 'Media' },
  { key: 'cs', label: 'Desktop' },
  { key: 'cpp', label: 'C++' },
  { key: 'guide', label: 'Guides' },
];
const filterLabelByKey = Object.fromEntries(filterButtons.map((button) => [button.key, button.label]));
const heroTopCategories = Object.entries(catCounts)
  .sort(([, a], [, b]) => b - a)
  .slice(0, 3)
  .map(([key, count]) => ({
    key,
    label: filterLabelByKey[key] ?? key,
    count,
  }));
const heroDomainText = heroTopCategories.map(({ label, count }) => `${label} ${count}`).join(' / ');
const heroSignalCategories = heroTopCategories.map(({ label }) => label).join(' / ');
const heroSignals = [
  {
    label: 'Current role',
    value: 'Technical Support Manager',
    meta: 'Maven Imaging - healthcare technology support, customer systems, and escalation.',
  },
  {
    label: 'Scope',
    value: 'Healthcare support',
    meta: 'Customer systems, hosted workflows, migrations, documentation, and escalation.',
  },
  {
    label: 'Primary focus',
    value: heroSignalCategories,
    meta: `${heroDomainText}.`,
  },
] as const;
const heroExperienceHighlights = [
  {
    label: 'Healthcare IT',
    value: 'Customer systems',
    copy: 'Support, migrations, documentation, and recovery workflows.',
  },
  {
    label: 'Systems',
    value: 'Windows / AD',
    copy: 'Servers, workstations, identity, monitoring, and networking.',
  },
  {
    label: 'Support',
    value: 'Escalation',
    copy: 'Documentation, vendor coordination, customer recovery, and cutovers.',
  },
] as const;
const heroEvidencePrimary = liveApps.find((app) => app.slug === 'SPECTRE') ?? liveApps[0] ?? null;
const heroEvidenceCards = ['IconForge', 'ImageXpert', 'Text-Filter-Editor']
  .map((slug) => liveApps.find((app) => app.slug === slug))
  .filter(Boolean) as typeof liveApps;
const heroEvidenceMoreCount = Math.max(0, liveApps.length - heroEvidenceCards.length - (heroEvidencePrimary ? 1 : 0));
function plainHeroText(value: string) {
  return value
    .replace(/&mdash;/g, '\u2014')
    .replace(/&ndash;/g, '\u2013')
    .replace(/&rarr;/g, '\u2192')
    .replace(/&amp;/g, '&')
    .replace(/&quot;/g, '"')
    .replace(/&#39;/g, "'")
    .replace(/&lt;/g, '<')
    .replace(/&gt;/g, '>');
}
const compactUtcDate = new Intl.DateTimeFormat('en-US', { month: 'short', day: 'numeric', year: 'numeric', timeZone: 'UTC' });
const heroReleaseDate = compactUtcDate;
const journeyMilestones = [
  {
    title: 'Healthcare IT & Systems Administration',
    eyebrow: 'Origin point',
    desc: 'Started in general systems administration - Windows fleets, Cisco networks, MSP work, and PBS broadcast infrastructure. Moved into healthcare technology support: customer systems, hosted workflows, migrations, and support operations. The practical pattern is steady troubleshooting, documentation, and repeatable fixes.',
    href: '/healthcare-it/',
    cta: 'Open the healthcare track',
    meta: 'Customer systems, uptime, and support workflows.',
  },
  {
    title: 'PowerShell & Windows Automation',
    eyebrow: 'Workflow cleanup',
    desc: 'Built Windows tools to solve real operational friction — NVMe driver patchers, network security auditors, Start Menu organizers, bulk installers. WPF interfaces that feel like finished software instead of internal scripts.',
    href: '/lang/powershell/',
    cta: 'See the PowerShell stack',
    meta: 'Provisioning, repair, compliance, and system management.',
  },
  {
    title: 'Python & Desktop Applications',
    eyebrow: 'Desktop expansion',
    desc: 'Moved into PyQt6 desktop apps for screenshot tooling, firewall management, image editing, PDF work, and more. The same rule held: bootstrap the dependencies, remove setup friction, and ship something people can actually launch right away.',
    href: '/lang/python/',
    cta: 'Browse the Python builds',
    meta: 'Local-first utilities, offline tools, and desktop workflows.',
  },
  {
    title: 'Web Apps & Live Deployments',
    eyebrow: 'Instant access',
    desc: `Launched ${liveApps.length}+ browser-ready apps on GitHub Pages — weather radar, flight tracking, OSINT aggregation, search engines, and utility tools. No backend required, no signup needed, just fast links that open and work.`,
    href: '#live',
    cta: 'Launch the live apps',
    meta: 'Browser tools that start without install, sign-in, or setup.',
  },
  {
    title: 'Full Stack & Beyond',
    eyebrow: 'Portfolio depth',
    desc: `${publicProjectCount}+ public projects across six languages — Android apps in Kotlin, Chrome extensions, Tampermonkey userscripts, browser themes, desktop software, and a broad archive that still stays grounded in practical use cases.`,
    href: '#catalog',
    cta: 'Open the full catalog',
    meta: 'The complete archive, filters included.',
  },
] as const;
const connectPaths = [
  {
    title: 'Full-text search',
    handle: '/search',
    href: '/search/',
    external: false,
    desc: 'Search project pages, README excerpts, release history, and archive decisions.',
    meta: 'Search by feature, keyword, library, or README phrase.',
    cta: 'Open full-text search',
    icon: 'release',
  },
  {
    title: 'GitHub',
    handle: 'github.com/SysAdminDoc',
    href: 'https://github.com/SysAdminDoc',
    external: true,
    desc: 'Open an issue, browse the source, or fork a project.',
    meta: 'All source code and issue tracking.',
    cta: 'Open GitHub',
    icon: 'github',
  },
  {
    title: 'Releases',
    handle: '/releases',
    href: '/releases/',
    external: false,
    desc: 'Recent releases, changelogs, and download links across all projects.',
    meta: 'What shipped recently.',
    cta: 'View releases',
    icon: 'release',
  },
  {
    title: 'Timeline',
    handle: '/timeline',
    href: '/timeline/',
    external: false,
    desc: 'Browse the archive by year, platform, language, and category.',
    meta: 'Full project history.',
    cta: 'Open timeline',
    icon: 'pulse',
  },
  {
    title: 'Now',
    handle: '/now',
    href: '/now/',
    external: false,
    desc: 'What I am currently building and what is most likely to ship next.',
    meta: 'Current focus and priorities.',
    cta: 'See current focus',
    icon: 'pulse',
  },
  {
    title: 'Email',
    handle: 'matt_parker@outlook.com',
    href: 'mailto:matt_parker@outlook.com',
    external: false,
    desc: 'For collaboration, contract work, or hiring conversations.',
    meta: 'I typically respond within a couple of days.',
    cta: 'Send an email',
    icon: 'mail',
  },
  {
    title: 'LinkedIn',
    handle: 'in/matthewryanparker',
    href: 'https://www.linkedin.com/in/matthewryanparker',
    external: true,
    desc: 'Professional background and full work history.',
    meta: 'Career record and professional network.',
    cta: 'Open LinkedIn',
    icon: 'linkedin',
  },
] as const;
const stackRoutes = [
  { href: '/lang/powershell/', label: 'PowerShell', meta: 'Automation & WPF' },
  { href: '/lang/python/', label: 'Python', meta: 'Desktop & AI tools' },
  { href: '/lang/javascript/', label: 'JavaScript', meta: 'Extensions & web' },
  { href: '/lang/kotlin/', label: 'Kotlin', meta: 'Android apps' },
  { href: '/lang/security/', label: 'Security', meta: 'Audits & network hardening' },
] as const;
const careerSignals = [
  { label: 'Tenure', value: '15+ years' },
  { label: 'Industries', value: 'Healthcare IT / Broadcast / MSP' },
  { label: 'Work type', value: 'Support / systems / documentation' },
] as const;
const aerialClips = [
  {id:'waOMwX39NOg', title:'Venice Beach, Florida', desc:'Morning aerial flight — June 2023'},
  {id:'xnpOENxAx-k', title:'Manasota Beach, Florida', desc:'Coastal drone footage over Manasota Key'},
  {id:'PnlsSqa8DtQ', title:'Venice Jetty', desc:'Aerial view of the Venice, Florida jetty'},
  {id:'FVroPKvYgKQ', title:'Nokomis Beach, Florida', desc:'Drone flight over Nokomis Beach'},
] as const;
const projectNameMap = new Map<string, string>();
featured.forEach((project) => projectNameMap.set(project.repo, project.name));
liveApps.forEach((app) => projectNameMap.set(app.slug, app.name));
catalog.forEach((entry) => projectNameMap.set(entry.repo, entry.name));
const latestReleaseName = latestRelease ? latestRelease.name ?? projectNameMap.get(latestRelease.repo) ?? latestRelease.repo : null;
const lastPushedProjectName = stats.lastPushedRepo ? projectNameMap.get(stats.lastPushedRepo) ?? stats.lastPushedRepo : null;
const cmdkSections = [
  { label: 'Highlights', href: '#greatest-hits', desc: 'Featured projects.', badge: 'START' },
  { label: 'Live Apps', href: '#live', desc: 'Browser-ready apps.', badge: 'LIVE' },
  { label: 'Catalog', href: '#catalog', desc: 'All public projects.', badge: 'ARCHIVE' },
  { label: 'Stack', href: '#skills', desc: 'Languages and tools.', badge: 'SECTION' },
  { label: 'Career', href: '#career', desc: 'Work history.', badge: 'SECTION' },
  { label: 'Journey', href: '#journey', desc: 'How the work expanded.', badge: 'SECTION' },
  { label: 'Beyond Code', href: '#beyond', desc: 'Aerial footage and creative projects.', badge: 'SECTION' },
  { label: 'Connect', href: '#connect', desc: 'Contact and links.', badge: 'SECTION' },
  { label: 'Full-Text Search', href: '/search/', desc: 'Search projects and documentation.', badge: 'PAGE' },
  { label: 'Archive', href: '/archive/', desc: 'Retired and superseded projects.', badge: 'PAGE' },
] as const;
---
<Base cmdkSections={cmdkSections}>
  <a href="#main" class="skip-link">Skip to content</a>

  <nav id="nav" aria-label="Main navigation">
    <div class="ni">
      <a href="#hero" class="nl">matt<span>@</span>sysadmin<span>:~$</span></a>
      <div class="nk" id="navLinks">
        <a href="#greatest-hits">Highlights</a>
        <a href="#live">Live Apps</a>
        <a href="#catalog">Catalog</a>
        <a href="#skills">Stack</a>
        <a href="#career">Career</a>
        <a href="#journey">Journey</a>
        <a href="#beyond">Beyond Code</a>
        <a href="#connect">Connect</a>
        <div class="nav-indicator" id="navIndicator"></div>
      </div>
      <div class="nav-actions">
        <button type="button" class="theme-toggle" id="themeToggle" aria-label="Switch to light theme" title="Switch to light theme"><svg viewBox="0 0 24 24"><path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"/></svg></button>
        <button type="button" class="nav-search" id="cmdkToggle" aria-label="Open command search" aria-controls="cmdk" aria-expanded="false" aria-haspopup="dialog" title="Open command search">
          <svg viewBox="0 0 24 24" stroke-width="2" fill="none" stroke="currentColor" stroke-linecap="round"><circle cx="11" cy="11" r="7"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          <span class="nav-search-label">Search</span>
        </button>
        <a href="https://github.com/SysAdminDoc" target="_blank" rel="noopener" class="ng" aria-label="GitHub Profile"><svg viewBox="0 0 16 16"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>GitHub</a>
        <button type="button" class="mt" id="mobileToggle" aria-label="Open navigation menu" aria-controls="navLinks" aria-expanded="false" title="Open navigation menu"><svg viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg></button>
      </div>
    </div>
  </nav>
  <div class="nav-backdrop" id="navBackdrop" aria-hidden="true"></div>
  <div class="scroll-progress" id="scrollProgress"></div>

  <main id="main" data-pagefind-body data-pagefind-filter="Scope:Home">
    <span aria-hidden="true" data-pagefind-ignore data-pagefind-meta="route_type:Home"></span>
    <span aria-hidden="true" data-pagefind-ignore data-pagefind-meta="type:Home"></span>
    <span aria-hidden="true" data-pagefind-ignore data-pagefind-meta="category:Portfolio"></span>
  <section class="hero" id="hero">
    <div class="hero-grid" aria-hidden="true"></div>
    <div class="hi">
      <div class="ht">
        <div class="hero-identity">
          <img class="hero-avatar loaded" id="heroAvatar" src={stats.avatarUrl || 'https://avatars.githubusercontent.com/u/55504284'} alt="Matt Parker" width="72" height="72" decoding="async" fetchpriority="high">
          <h1 class="hn">Matt <span class="a">Parker</span></h1>
        </div>
        <a class="htag" id="heroTag" href="#connect"><span class="dot"></span> Available for work</a>
        <div class="hero-proof-strip" aria-label="Experience focus areas">
          {heroExperienceHighlights.map((item) => (
            <div class="hero-proof" title={item.copy} aria-label={`${item.label}. ${item.value}. ${item.copy}`}>
              <span class="hero-proof-label">{item.label}</span>
              <strong class="hero-proof-value">{item.value}</strong>
              <span class="hero-proof-copy">{item.copy}</span>
            </div>
          ))}
        </div>
        <p class="hr">Senior Technical Support Manager &amp; systems administrator</p>
        <p class="hero-summary">15+ years across enterprise IT and healthcare support: customer systems, migrations, documentation, and high-stakes troubleshooting.</p>
        <div class="hs" role="group" aria-label="Portfolio statistics" aria-live="polite">
          <div class="hs-item"><div class="hsn" id="statRepos" data-live>{publicProjectCount}</div><div class="hsl">Projects</div></div>
          <div class="hs-item"><div class="hsn" id="statStars" data-live>{stats.totalStars}</div><div class="hsl">Stars</div></div>
          <div class="hs-item"><div class="hsn" id="statLive">{liveApps.length}</div><div class="hsl">Live Apps</div></div>
        </div>
        <div class="hero-pulse">
          <span class="pulse-dot"></span>
          {stats.streak > 0 && (
            <a href="/now/" class="pulse-item" title="Current consecutive-day commit streak">
              <span class="pulse-k">streak</span>
              <span class="pulse-v">{stats.streak}d</span>
            </a>
          )}
          {latestRelease && (
            <a href={latestRelease.url} target="_blank" rel="noopener" class="pulse-item" title={`Released ${heroReleaseDate.format(new Date(latestRelease.publishedAt))}`}>
              <span class="pulse-k">latest</span>
              <span class="pulse-v">{latestReleaseName} {latestRelease.tag && <span class="pulse-sub">{latestRelease.tag}</span>}</span>
            </a>
          )}
          {stats.lastPushedRepo && stats.lastPushedAt && (
            <a href={`https://github.com/SysAdminDoc/${stats.lastPushedRepo}`} target="_blank" rel="noopener" class="pulse-item" title={lastPushedProjectName ? `Last push to ${lastPushedProjectName}` : `Last push ${stats.lastPushedAt}`}>
              <span class="pulse-k">pushed</span>
              <span class="pulse-v"><time datetime={stats.lastPushedAt} data-rel={stats.lastPushedAt}>{compactUtcDate.format(new Date(stats.lastPushedAt))}</time>{lastPushedProjectName && <span class="pulse-sub">{lastPushedProjectName}</span>}</span>
            </a>
          )}
        </div>
        <div class="ha">
          <a href="#greatest-hits" class="btn bp"><svg viewBox="0 0 16 16" fill="currentColor"><path d="M2 2.5A2.5 2.5 0 014.5 0h8.75a.75.75 0 01.75.75v12.5a.75.75 0 01-.75.75h-2.5a.75.75 0 110-1.5h1.75v-2h-8a1 1 0 00-.714 1.7.75.75 0 01-1.072 1.05A2.495 2.495 0 012 11.5v-9zm10.5-1h-8a1 1 0 00-1 1v6.708A2.486 2.486 0 014.5 9h8V1.5z"/></svg>Selected work</a>
          <a href="https://github.com/SysAdminDoc" target="_blank" rel="noopener" class="btn bg2"><svg viewBox="0 0 16 16" fill="currentColor"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>GitHub archive</a>
        </div>
        <div class="hero-signals" aria-label="Portfolio differentiators">
          {heroSignals.map((signal) => (
            <div class="hero-signal" title={signal.meta}>
              <span class="hero-signal-label">{signal.label}</span>
              <strong class="hero-signal-value">{signal.value}</strong>
              <span class="sr-only">{signal.meta}</span>
            </div>
          ))}
        </div>
      </div>
      <aside class="hero-evidence" aria-label="Live project evidence">
        <div class="hero-evidence-head">
          <div>
            <span class="hero-evidence-kicker"><span class="dot"></span> Live work</span>
            <strong>Open the work</strong>
            <p>{liveApps.length} browser apps, available without an install.</p>
          </div>
        </div>
        {heroEvidencePrimary && (
          <a href={heroEvidencePrimary.url} target="_blank" rel="noopener" class="hero-showcase" aria-label={`Open ${heroEvidencePrimary.name} live app in a new tab`}>
            <span class="hero-showcase-brand">
              <span class="hero-app-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <circle cx="12" cy="12" r="7"></circle>
                  <circle cx="12" cy="12" r="2.5"></circle>
                  <path d="M12 2v3M12 19v3M2 12h3M19 12h3"></path>
                </svg>
              </span>
              <strong>{heroEvidencePrimary.name}</strong>
              <small>{plainHeroText(heroEvidencePrimary.desc)}</small>
            </span>
            <span class="hero-showcase-shot">
              <img
                src={`/screenshots/thumbs/${heroEvidencePrimary.slug}.jpg`}
                alt={`${heroEvidencePrimary.name} live app screenshot`}
                width="640"
                height="400"
                loading="eager"
                decoding="async"
              >
            </span>
          </a>
        )}
        <div class="hero-app-grid" aria-label="Featured live app shortcuts">
          {heroEvidenceCards.map((app) => (
            <a href={app.url} target="_blank" rel="noopener" class="hero-app-card" aria-label={`Open ${app.name} live app in a new tab`}>
              <span>
                <strong>{app.name}</strong>
                <small>{plainHeroText(app.desc)}</small>
              </span>
            </a>
          ))}
          <a href="#live" class="hero-app-card hero-app-more">
            <span>
              <strong>More Live Apps</strong>
              <small>{heroEvidenceMoreCount} more apps in the catalog</small>
            </span>
          </a>
        </div>
      </aside>
    </div>
  </section>

  <Divider />

  <GreatestHits />
  <Divider />

  <section id="catalog" aria-label="Project catalog"><div class="si">
    <div class="sh rv"><div class="sl">// Catalog</div><h2 class="st">Project catalog</h2><p class="sd">Search and filter {catalogTotal} public projects.</p></div>
    <search aria-label="Filter and search the project catalog">
    <div class="catalog-controls rv">
      <form class="catalog-search-form" id="catalogSearchForm" action="/search/" method="get" role="search" aria-label="Search projects">
      <div class="search-wrap">
        <label class="sr-only" for="searchInput">Search projects</label>
        <svg viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <input type="search" class="search-input" id="searchInput" name="q" placeholder="Search projects…" autocomplete="off" spellcheck="false" inputmode="search" enterkeyhint="search" aria-label="Search projects">
      </div>
      <noscript><button type="submit" class="catalog-submit">Search</button></noscript>
      </form>
      <label class="sr-only" for="sortSelect">Sort projects</label>
      <select class="sort-select" id="sortSelect" aria-label="Sort projects">
        <option value="default">Recommended</option>
        <option value="stars">Most stars</option>
        <option value="name">A-Z</option>
        <option value="name-desc">Z-A</option>
        <option value="recent">Recently updated</option>
      </select>
    </div>
    <div class="cf catalog-views rv" id="viewBtns" role="group" aria-label="Catalog views">
      <button type="button" class="fb catalog-view act" data-view="all" data-label="All views" aria-pressed="true">All <span class="fc">{viewCounts.all}</span></button>
      <button type="button" class="fb catalog-view" data-view="new" data-label="New projects" aria-pressed="false">New <span class="fc">{viewCounts.new}</span></button>
      <button type="button" class="fb catalog-view" data-view="recent" data-label="Recently updated" aria-pressed="false">Updated <span class="fc">{viewCounts.recent}</span></button>
      <button type="button" class="fb catalog-view" data-view="download" data-label="Has download" aria-pressed="false">Downloads <span class="fc">{viewCounts.download}</span></button>
    </div>
    <div class="cf rv" id="filterBtns" role="group" aria-label="Filter by category">
      <button type="button" class="fb act" data-filter="all" data-label="All projects" aria-pressed="true">All <span class="fc" id="countAll">{catalogTotal}</span></button>
      {filterButtons.map((f) => (
        <button type="button" class="fb" data-filter={f.key} data-label={f.label} aria-pressed="false">{f.label} <span class="fc" data-cat={f.key}>{catCounts[f.key] ?? 0}</span></button>
      ))}
    </div>
    </search>
    <div class="catalog-feedback rv">
      <div class="catalog-status" id="catalogStatus" role="status" aria-live="polite">{catalogTotal} projects · recommended order</div>
      <button type="button" class="catalog-reset" id="catalogReset" hidden>Clear filters</button>
    </div>
    <div class="cg" id="catalogGrid" data-sort="default">
      {rankedCatalog.map((entry, index) => {
        const viewState = catalogViewState.get(entry.repo);
        const ranking = projectRankings.get(entry.repo);
        return (
          <CatalogEntry
            entry={entry}
            index={index}
            rank={ranking?.rank}
            rankScore={ranking?.score}
            rankLabel={formatProjectRankingLabel(ranking)}
            rankDisplayLabel={formatProjectRankingDisplayLabel(ranking)}
            stars={stars[entry.repo]}
            pushedAt={meta[entry.repo]?.pushedAt}
            updatedAt={meta[entry.repo]?.updatedAt ?? meta[entry.repo]?.pushedAt}
            isNew={viewState?.isNew}
            isRecent={viewState?.isRecent}
            hasDownload={viewState?.hasDownload}
          />
        );
      })}
    </div>
    <div class="no-results" id="noResults" hidden>
      <svg class="no-results-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="7"/><line x1="21" y1="21" x2="16.65" y2="16.65"/><line x1="8" y1="11" x2="14" y2="11"/></svg>
      <div class="no-results-title">No matches</div>
      <p class="no-results-copy">Try a broader search or clear the filters.</p>
      <button type="button" class="catalog-reset no-results-action" id="catalogResetEmpty">Reset filters</button>
    </div>
  </div></section>
  <Divider />

  <section id="live" aria-label="Live apps"><div class="si">
    <div class="sh rv"><div class="sl">// Live · {liveApps.length}</div><h2 class="st">Live apps</h2><p class="sd">Browser-ready work—no install or account.</p></div>
    <div class="lg">
      {liveApps.map((a) => <LiveCard app={a} />)}
    </div>
  </div></section>
  <Divider />

  <section id="skills" aria-label="Stack and skills"><div class="si">
    <div class="sh rv"><div class="sl">// Stack</div><h2 class="st">Stack</h2><p class="sd">Languages and tools across the archive.</p></div>
    <div class="stack-shell rv">
      <div class="stack-overview">
        <div class="stack-kicker">Browse by language</div>
        <p class="stack-copy">Projects grouped by language and platform.</p>
        <div class="stack-actions" aria-label="Open stack tracks">
          {stackRoutes.map((route) => (
            <a href={route.href} class="stack-action">
              <span class="stack-action-label">{route.label}</span>
              <span class="stack-action-meta">{route.meta}</span>
            </a>
          ))}
        </div>
      </div>
      <div class="lang-donut-wrap rv" id="langDonut">
        {donutTotal > 0 ? (
          <div class="lang-donut-panel">
            <div class="lang-donut-head">
              <div class="lang-donut-kicker">Project Mix</div>
              <p class="lang-donut-copy">{donutLeadLang} leads the public archive at {donutLeadPct}% of projects, with the rest spread across desktop, web, and Android tooling.</p>
            </div>
            <div class="lang-donut-shell">
              <div class="lang-donut">
                <svg viewBox="0 0 180 180">
                  {donutArcs.map((arc) => (
                    <circle cx="90" cy="90" r={DONUT_R} stroke={arc.color} stroke-dasharray={arc.dash} stroke-dashoffset={arc.offset} opacity=".85" />
                  ))}
                </svg>
                <div class="lang-donut-center"><div class="donut-total">{donutTotal}</div><div class="donut-label">projects</div></div>
              </div>
              <div class="lang-legend">
                {donutArcs.map((arc) => (
                  <div class="lang-legend-item"><span class={`lang-legend-dot lang-tone-${arc.tone}`}></span>{arc.lang}<span class="lang-legend-pct">{arc.pct}%</span></div>
                ))}
              </div>
            </div>
          </div>
        ) : (
          <div class="lang-donut-panel">
            <div class="lang-donut-head">
              <div class="lang-donut-kicker">Project Mix</div>
              <p class="lang-donut-copy">Loading the language mix from GitHub so the stack view reflects the live public archive.</p>
            </div>
            <div class="lang-donut-fallback" aria-hidden="true">
              <div class="lang-donut-fallback-ring"></div>
              <div class="lang-donut-fallback-list">
                <span>PowerShell</span>
                <span>Python</span>
                <span>JavaScript</span>
                <span>Kotlin</span>
              </div>
            </div>
          </div>
        )}
      </div>
    </div>
    <div class="skg">
      {skills.map((s) => <SkillCard skill={s} />)}
    </div>
  </div></section>
  <Divider />


  <section id="career" aria-label="Career history"><div class="si">
    <div class="sh rv"><div class="sl">// Career</div><h2 class="st">Career</h2><p class="sd">Healthcare support, broadcast infrastructure, and MSP operations.</p></div>
    <div class="career-signals rv" aria-label="Career signals">
      {careerSignals.map((signal) => (
        <div class="career-signal">
          <span class="career-signal-label">{signal.label}</span>
          <strong class="career-signal-value">{signal.value}</strong>
        </div>
      ))}
    </div>
    <div class="career-timeline">
      {careerRoles.map((role) => (
        <article class={`career-card card-enter career-${role.tone}`}>
          <div class="career-card-head">
            <span class="career-card-tag">{role.tag}</span>
            <span class="career-card-period">{role.period}</span>
          </div>
          <h3 class="career-card-role">{role.role}</h3>
          <div class="career-card-company">
            <span class="career-card-company-name">{role.company}</span>
            <span class="career-card-company-sep">·</span>
            <span class="career-card-location">{role.location}</span>
          </div>
          {role.note && <p class="career-card-note">{role.note}</p>}
          <p class="career-card-summary">{role.summary}</p>
          <ul class="career-card-highlights">
            {role.highlights.map((h) => <li>{h}</li>)}
          </ul>
          <div class="career-card-stack" aria-label="Stack">
            {role.stack.map((s) => <span class="career-stack-chip">{s}</span>)}
          </div>
        </article>
      ))}
    </div>
  </div></section>
  <Divider />


  <section id="journey" aria-label="Journey"><div class="si">
    <div class="sh rv"><div class="sl">// Journey</div><h2 class="st">Practice, expanded</h2><p class="sd">Operational problems became tools, then products.</p></div>
    <div class="jw">
      {journeyMilestones.map((step) => (
        <div class="ji rv">
          <div class="jd"></div>
          <div class="jeyebrow">{step.eyebrow}</div>
          <h3 class="jt"><a href={step.href} class="ji-link">{step.title}</a></h3>
          <p class="jdesc">{step.desc}</p>
          <div class="jfoot">
            <span class="jmeta">{step.meta}</span>
            <span class="jlink" aria-hidden="true">{step.cta}</span>
          </div>
        </div>
      ))}
    </div>
  </div></section>
  <Divider />

  <section id="beyond" aria-label="Beyond code"><div class="si">
    <div class="sh rv"><div class="sl">// Beyond Code</div><h2 class="st">Beyond code</h2><p class="sd">Aerial footage from coastal Florida.</p></div>

    <h3 class="beyond-subtitle rv" id="beyond-video">Aerial Footage</h3>
    <div class="video-grid">
      {aerialClips.map((v) => (
        <div class="video-card card-enter">
          <button type="button" class="video-thumb" data-yt={v.id} aria-label={`Play ${v.title} video`}>
            <img src={`https://img.youtube.com/vi/${v.id}/hqdefault.jpg`} alt={v.title} loading="lazy" decoding="async" width="1280" height="720">
            <div class="play-btn"><svg viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg></div>
          </button>
          <div class="video-info"><div class="video-title">{v.title}</div><div class="video-desc">{v.desc}</div></div>
        </div>
      ))}
    </div>
  </div></section>
  <Divider />

  <section id="connect" aria-label="Connect"><div class="si">
    <div class="sh rv"><div class="sl">// Connect</div><h2 class="st">Contact</h2><p class="sd">GitHub, LinkedIn, email, and release feeds.</p></div>
    <div class="cng">
      {connectPaths.map((path) => (
        <a
          href={path.href}
          class="cnc card-enter"
          target={path.external ? '_blank' : undefined}
          rel={path.external ? 'noopener' : undefined}
        >
          <div class="cnc-top">
            {path.icon === 'github' ? (
              <svg viewBox="0 0 16 16" fill="var(--t1)" aria-hidden="true"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
            ) : path.icon === 'release' ? (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M8 7h8"/><path d="M8 12h8"/><path d="M8 17h5"/><path d="M5 3h14a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2z"/></svg>
            ) : path.icon === 'mail' ? (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3 7 9 6 9-6"/></svg>
            ) : path.icon === 'linkedin' ? (
              <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M4.98 3.5a2.5 2.5 0 1 0 0 5 2.5 2.5 0 0 0 0-5zM3 9h4v12H3zM9 9h3.8v1.7h.05c.53-.95 1.83-1.95 3.77-1.95 4.03 0 4.78 2.5 4.78 5.75V21h-4v-5.1c0-1.22-.02-2.8-1.9-2.8-1.9 0-2.2 1.35-2.2 2.7V21H9z"/></svg>
            ) : (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 6v6l4 2"/><path d="M21 12a9 9 0 1 1-9-9"/></svg>
            )}
            <div class="cnc-info">
              <span class="cnc-name">{path.title}</span>
              <span class="cnc-handle">{path.handle}</span>
            </div>
          </div>
          <p class="cnc-desc">{path.desc}</p>
          <div class="cnc-foot">
            <span class="cnc-meta">{path.meta}</span>
            <span class="cnc-cta">{path.cta}</span>
          </div>
        </a>
      ))}
    </div>
  </div></section>
  <Divider />
  </main>

  <footer>
    <div class="fi">
      <div class="footer-brand">
        <div class="ft" id="footerText">
          <span class="footer-year">© <span id="footerYear">{new Date().getFullYear()}</span> Matt Parker — SysAdminDoc</span>
          {stats.fetchedAt && (
            <span class="footer-freshness" title={`Stats fetched from GitHub API at ${stats.fetchedAt}`}>
              <span class="footer-freshness-dot"></span>
              Stats refreshed <time datetime={stats.fetchedAt} data-rel={stats.fetchedAt}>{compactUtcDate.format(new Date(stats.fetchedAt))}</time>
            </span>
          )}
        </div>
        <p class="footer-summary">Systems administration, healthcare technology support, and practical software work shaped by real operating environments.</p>
      </div>
      <nav class="fl" aria-label="Footer navigation">
        <a href="#catalog">Catalog</a>
        <a href="/search/">Search</a>
        <a href="/releases/">Releases</a>
        <a href="/timeline/">Timeline</a>
        <a href="/archive/">Archive</a>
        <a href="/now/">Now</a>
        <a href="/uses/">Uses</a>
        <a href="/resume/">Resume</a>
        <a href="/rss.xml">RSS</a>
        <a href="https://github.com/SysAdminDoc" target="_blank" rel="noopener">GitHub</a>
      </nav>
    </div>
  </footer>

  <button type="button" class="btt" id="backToTop" aria-label="Back to top"><svg viewBox="0 0 24 24" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="18 15 12 9 6 15"/></svg></button>
</Base>
