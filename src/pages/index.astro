                <div class="album-art"><img src={`https://i.scdn.co/image/${a.art}`} alt={a.name} loading="lazy" decoding="async" width="640" height="640"><div class="album-art-overlay"><svg viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg></div></div>
                <div class="album-info"><div class="album-name">{a.name}</div><div class="album-year">{a.year}</div></div>
              </a>
            ))}
          </div>
        </div>
      </div>
      <div>
        <div class="spotify-embed-wrap card-enter" id="spotifyWrap" data-src="https://open.spotify.com/embed/artist/48Fd3yL6KvxtZO0MOPZYHW?utm_source=generator&theme=0" style="min-height:740px"></div>
      </div>
    </div>
  </div></section>
  <Divider />

  <section id="connect"><div class="si">
    <div class="sh rv"><div class="sl">// Connect</div><h2 class="st">Let's Build Something</h2><p class="sd">Three fast ways to start the right conversation, whether you want to see what is shipping or open a new thread.</p></div>
    <p class="connect-msg rv">If you've got a process worth automating, a workflow that's grown teeth, or a tool you wish existed — open an issue on any repo and let's talk.</p>
    <div class="connect-notes rv" aria-label="Best collaboration fit">
      <div class="connect-note"><span class="connect-note-label">What I do</span> Automation, internal tooling, browser products, and UX cleanup for complex workflows.</div>
      <div class="connect-note"><span class="connect-note-label">Where to start</span> A GitHub issue, a rough idea, or the repetitive process you want gone.</div>
    </div>
    <div class="cng">
      {connectPaths.map((path) => (
        <a
          href={path.href}
          class="cnc card-enter"
          target={path.external ? '_blank' : undefined}
          rel={path.external ? 'noopener' : undefined}
        >
          <div class="cnc-top">
            {path.icon === 'github' ? (
              <svg viewBox="0 0 16 16" fill="var(--t1)" aria-hidden="true"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
            ) : path.icon === 'release' ? (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M8 7h8"/><path d="M8 12h8"/><path d="M8 17h5"/><path d="M5 3h14a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2z"/></svg>
            ) : (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 6v6l4 2"/><path d="M21 12a9 9 0 1 1-9-9"/></svg>
            )}
            <div class="cnc-info">
              <span class="cnc-name">{path.title}</span>
              <span class="cnc-handle">{path.handle}</span>
            </div>
          </div>
          <p class="cnc-desc">{path.desc}</p>
          <div class="cnc-foot">
            <span class="cnc-meta">{path.meta}</span>
            <span class="cnc-cta">{path.cta}</span>
          </div>
        </a>
      ))}
    </div>
  </div></section>
  <Divider />
  </main>

  <footer>
