---
import Base from '../layouts/Base.astro';
import Divider from '../components/Divider.astro';
import InteriorNav from '../components/InteriorNav.astro';
import SectionJumpNav from '../components/SectionJumpNav.astro';
import { now } from '../data/curated';
import { fallbackRepoCount } from '../data/derived';
import { featured, liveApps, catalog } from '../data/projects';

let stats = {
  totalRepos: fallbackRepoCount,
  totalStars: 0,
  lastPushedAt: null as string | null,
  lastPushedRepo: null as string | null,
  streak: 0,
  latestRelease: null as { repo: string; tag: string | null; at: string } | null,
  fetchedAt: null as string | null,
};
try { const mod = await import('../data/_stats.json'); stats = { ...stats, ...(mod.default ?? mod) }; } catch {}
const projectNameMap = new Map<string, string>();
featured.forEach((project) => projectNameMap.set(project.repo, project.name));
liveApps.forEach((app) => projectNameMap.set(app.slug, app.name));
catalog.forEach((entry) => projectNameMap.set(entry.repo, entry.name));
const lastPushedProjectName = stats.lastPushedRepo ? projectNameMap.get(stats.lastPushedRepo) ?? stats.lastPushedRepo : null;
const utcDate = new Intl.DateTimeFormat('en-US', { year: 'numeric', month: 'long', day: 'numeric', timeZone: 'UTC' });
const compactUtcDate = new Intl.DateTimeFormat('en-US', { month: 'short', day: 'numeric', year: 'numeric', timeZone: 'UTC' });
const nowSections = [
  {
    id: 'now-building',
    title: 'Building',
    note: 'The work getting active engineering time right now.',
    kind: 'list',
    items: now.building,
  },
  {
    id: 'now-thinking',
    title: 'Thinking About',
    note: 'Ideas, tradeoffs, and product questions still being shaped.',
    kind: 'list',
    items: now.thinking,
  },
  {
    id: 'now-listening',
    title: 'Listening',
    note: 'What is setting the mood for the work outside the code editor.',
    kind: 'text',
    text: now.listening,
  },
  {
    id: 'now-not-working-on',
    title: 'Deliberately Not Working On',
    note: 'The constraints I am keeping in place to protect focus.',
    kind: 'text',
    text: now.notWorkingOn,
  },
] as const;
const cmdkSections = [
  { label: 'Overview', href: '#now-overview', desc: 'Current-focus snapshot, live pulse, and the fastest route into adjacent pages.', badge: 'NOW' },
  ...nowSections.map((section) => ({
    label: section.title,
    href: `#${section.id}`,
    desc: section.note,
    badge: 'SECTION',
  })),
];
---
<Base title="Now — Matt Parker" description="What I'm currently building, thinking about, and deliberately not working on." cmdkSections={cmdkSections}>
  <a href="#main" class="skip-link">Skip to content</a>
  <InteriorNav active="now" contextLabel="Current focus" contextTone="green" />

  <main id="main" class="now-page">
    <div class="si page-shell" id="now-overview">
      <div class="sh rv">
        <div class="sl">// Now</div>
        <h1 class="st now-title">Current focus</h1>
        <p class="sd">
          A working snapshot inspired by <a href="https://nownownow.com/about" target="_blank" rel="noopener" class="now-inline-link page-inline-link">Derek Sivers' /now page</a>.
          Updated <time datetime={now.updated}>{utcDate.format(new Date(`${now.updated}T00:00:00Z`))}</time> so the signals stay current.
        </p>
      </div>

      {/* Live activity snapshot */}
      <div class="now-pulse page-panel rv">
        <div class="now-pulse-item">
          <span class="now-pulse-dot"></span>
          <span class="now-pulse-label">Location</span>
          <span class="now-pulse-value">{now.location}</span>
        </div>
        {stats.lastPushedAt && (
          <div class="now-pulse-item">
            <span class="now-pulse-dot"></span>
            <span class="now-pulse-label">Last push</span>
            <span class="now-pulse-value"><time datetime={stats.lastPushedAt} data-rel={stats.lastPushedAt}>{compactUtcDate.format(new Date(stats.lastPushedAt))}</time>{lastPushedProjectName && <span class="now-pulse-sub">to {lastPushedProjectName}</span>}</span>
          </div>
        )}
        {stats.streak > 0 && (
          <div class="now-pulse-item">
            <span class="now-pulse-dot"></span>
            <span class="now-pulse-label">Streak</span>
            <span class="now-pulse-value">{stats.streak}d</span>
          </div>
        )}
        <div class="now-pulse-item">
          <span class="now-pulse-dot"></span>
          <span class="now-pulse-label">Projects · Stars</span>
          <span class="now-pulse-value">{stats.totalRepos} · {stats.totalStars}</span>
        </div>
      </div>
      <div class="now-actions page-actions rv">
        <a href="/releases/" class="btn bp">Open release stream</a>
        <a href="/#catalog" class="btn bg2">Open full archive</a>
        <a href="/healthcare-it/" class="now-action-link page-action-link">Open healthcare track</a>
      </div>
      <SectionJumpNav items={cmdkSections} />
    </div>
    <Divider />

    <div class="si">
      <div class="now-grid">
        {nowSections.map((section) => (
          <section class="now-section rv" id={section.id}>
            <div class="now-section-head">
              <h2 class="now-h2">{section.title}</h2>
              <p class="now-section-copy">{section.note}</p>
            </div>
            {section.kind === 'list' ? (
              <ul class="now-list">
                {section.items.map((line) => <li class="now-li">{line}</li>)}
              </ul>
            ) : (
              <p class="now-p">{section.text}</p>
            )}
          </section>
        ))}
      </div>
    </div>
  </main>

  <footer>
    <div class="fi page-footer-shell">
      <div class="footer-brand">
        <div class="ft"><a href="/" class="footer-backlink">← Back to portfolio</a></div>
        <p class="footer-summary">The /now page is the short-range signal. The release stream and full archive show what is already shipped, maintained, and still earning attention.</p>
      </div>
      <div class="fl"><a href="/rss.xml">RSS</a><a href="https://github.com/SysAdminDoc" target="_blank" rel="noopener">GitHub</a></div>
    </div>
  </footer>
</Base>

<style is:global>
  .now-page{min-height:calc(100vh - 200px)}
  .now-title{font-size:clamp(36px,5vw,56px)!important}
  .now-inline-link{color:var(--grn);text-decoration:none;border-bottom:1px dashed var(--glass-border)}
  .now-inline-link:hover{border-bottom-color:var(--grn)}
  .now-pulse{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:12px;margin-top:28px;padding:22px}
  .now-pulse-item{display:grid;grid-template-columns:auto minmax(0,1fr);align-items:center;gap:6px 10px;min-width:0;padding:16px 18px;border:1px solid var(--border-soft);border-radius:20px;background:var(--surface-2);box-shadow:0 16px 34px rgba(0,0,0,.12)}
  .now-pulse-dot{width:8px;height:8px;border-radius:50%;background:var(--grn);box-shadow:0 0 10px var(--grn-glow);animation:freshPulse 2s ease-in-out infinite}
  .now-pulse-label{font-family:var(--mono);font-size:10px;letter-spacing:.12em;color:var(--t3);text-transform:uppercase;white-space:nowrap}
  .now-pulse-value{grid-column:2;font-family:var(--mono);font-size:14px;color:var(--t1);line-height:1.45;min-width:0}
  .now-pulse-sub{display:block;color:var(--t3);font-size:12px;line-height:1.5}
  .now-actions{margin-top:22px}
  .now-action-link{padding:0}
  .now-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:18px;margin-top:56px}
  .now-section{margin-top:0;padding:30px;border:1px solid var(--border-soft);border-radius:28px;background:var(--surface-1);box-shadow:var(--shadow-soft);overflow:visible}
  .now-section::before{display:none}
  .now-section-head{display:flex;flex-direction:column;gap:8px;margin-bottom:18px;padding-bottom:16px;border-bottom:1px solid var(--border-soft)}
  .now-h2{font-family:var(--mono);font-size:12px;text-transform:uppercase;letter-spacing:.15em;color:var(--t3);margin:0}
  .now-section-copy{color:var(--t3);font-size:14px;line-height:1.65;max-width:36ch}
  .now-list{list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:14px}
  .now-li{padding-left:24px;position:relative;color:var(--t1);line-height:1.65;font-size:17px}
  .now-li::before{content:'▸';position:absolute;left:0;top:0;color:var(--grn)}
  .now-p{color:var(--t2);font-size:17px;line-height:1.7;margin:0}
  @media(max-width:760px){
    .now-grid{grid-template-columns:1fr}
    .now-pulse{grid-template-columns:1fr;padding:18px}
  }
  @media(min-width:761px) and (max-width:1040px){
    .now-pulse{grid-template-columns:repeat(2,minmax(0,1fr))}
  }
</style>
