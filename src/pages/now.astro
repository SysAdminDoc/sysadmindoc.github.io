---
import Base from '../layouts/Base.astro';
import Divider from '../components/Divider.astro';
import { now } from '../data/curated';
import { fallbackRepoCount } from '../data/derived';

let stats = {
  totalRepos: fallbackRepoCount,
  totalStars: 0,
  lastPushedAt: null as string | null,
  lastPushedRepo: null as string | null,
  streak: 0,
  latestRelease: null as { repo: string; tag: string | null; at: string } | null,
  fetchedAt: null as string | null,
};
try { const mod = await import('../data/_stats.json'); stats = { ...stats, ...(mod.default ?? mod) }; } catch {}
const utcDate = new Intl.DateTimeFormat('en-US', { year: 'numeric', month: 'long', day: 'numeric', timeZone: 'UTC' });
const compactUtcDate = new Intl.DateTimeFormat('en-US', { month: 'short', day: 'numeric', year: 'numeric', timeZone: 'UTC' });
const nowSections = [
  {
    title: 'Building',
    note: 'The work getting active engineering time right now.',
    kind: 'list',
    items: now.building,
  },
  {
    title: 'Thinking About',
    note: 'Ideas, tradeoffs, and product questions still being shaped.',
    kind: 'list',
    items: now.thinking,
  },
  {
    title: 'Listening',
    note: 'What is setting the mood for the work outside the code editor.',
    kind: 'text',
    text: now.listening,
  },
  {
    title: 'Deliberately Not Working On',
    note: 'The constraints I am keeping in place to protect focus.',
    kind: 'text',
    text: now.notWorkingOn,
  },
] as const;
---
<Base title="Now — Matt Parker" description="What I'm currently building, thinking about, and deliberately not working on.">
  <a href="#main" class="skip-link">Skip to content</a>
  <nav id="nav" aria-label="Main navigation">
    <div class="ni">
      <a href="/" class="nl">matt<span>@</span>sysadmin<span>:~$</span></a>
      <div class="nk" id="navLinks">
        <a href="/#greatest-hits">Hits</a>
        <a href="/#featured">Projects</a>
        <a href="/#live">Live</a>
        <a href="/#catalog">Catalog</a>
        <a href="/releases/">Releases</a>
        <a href="/now/" class="active" aria-current="page">Now</a>
      </div>
      <div style="display:flex;align-items:center;gap:8px">
        <button type="button" class="theme-toggle" id="themeToggle" aria-label="Switch to light theme" title="Switch to light theme"><svg viewBox="0 0 24 24"><path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"/></svg></button>
        <a href="/" class="ng">← Home</a>
        <button type="button" class="mt" id="mobileToggle" aria-label="Toggle navigation menu" aria-controls="navLinks" aria-expanded="false"><svg viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg></button>
      </div>
    </div>
  </nav>

  <main id="main" class="now-page">
    <div class="si" style="padding-top:100px">
      <div class="sh rv">
        <div class="sl">// Now</div>
        <h1 class="st now-title">What I'm doing right now</h1>
        <p class="sd">
          Inspired by <a href="https://nownownow.com/about" target="_blank" rel="noopener" class="now-inline-link">Derek Sivers' /now page</a>.
          Updated <time datetime={now.updated}>{utcDate.format(new Date(`${now.updated}T00:00:00Z`))}</time>.
        </p>
      </div>

      {/* Live activity snapshot */}
      <div class="now-pulse rv">
        <div class="now-pulse-item">
          <span class="now-pulse-dot"></span>
          <span class="now-pulse-label">Location</span>
          <span class="now-pulse-value">{now.location}</span>
        </div>
        {stats.lastPushedAt && (
          <div class="now-pulse-item">
            <span class="now-pulse-dot"></span>
            <span class="now-pulse-label">Last push</span>
            <span class="now-pulse-value"><time datetime={stats.lastPushedAt} data-rel={stats.lastPushedAt}>{compactUtcDate.format(new Date(stats.lastPushedAt))}</time> <span class="now-pulse-sub">to {stats.lastPushedRepo}</span></span>
          </div>
        )}
        {stats.streak > 0 && (
          <div class="now-pulse-item">
            <span class="now-pulse-dot"></span>
            <span class="now-pulse-label">Streak</span>
            <span class="now-pulse-value">{stats.streak}d</span>
          </div>
        )}
        <div class="now-pulse-item">
          <span class="now-pulse-dot"></span>
          <span class="now-pulse-label">Repos · Stars</span>
          <span class="now-pulse-value">{stats.totalRepos} · {stats.totalStars}</span>
        </div>
      </div>
      <div class="now-actions rv">
        <a href="/releases/" class="btn bp">Browse Releases</a>
        <a href="/#catalog" class="btn bg2">Open Full Catalog</a>
        <a href="/healthcare-it/" class="now-action-link">Healthcare IT Track</a>
      </div>
    </div>
    <Divider />

    <div class="si">
      <div class="now-grid">
        {nowSections.map((section) => (
          <section class="now-section rv">
            <div class="now-section-head">
              <h2 class="now-h2">{section.title}</h2>
              <p class="now-section-copy">{section.note}</p>
            </div>
            {section.kind === 'list' ? (
              <ul class="now-list">
                {section.items.map((line) => <li class="now-li">{line}</li>)}
              </ul>
            ) : (
              <p class="now-p">{section.text}</p>
            )}
          </section>
        ))}
      </div>
    </div>
  </main>

  <footer>
    <div class="fi">
      <div class="ft"><a href="/" style="color:var(--t2)">← Back to portfolio</a></div>
      <div class="fl"><a href="/rss.xml">RSS</a><a href="https://github.com/SysAdminDoc" target="_blank" rel="noopener">GitHub</a></div>
    </div>
  </footer>
</Base>

<style is:global>
  .now-page{min-height:calc(100vh - 200px);max-width:980px;margin:0 auto}
  .now-title{font-size:clamp(36px,5vw,56px)!important}
  .now-inline-link{color:var(--grn);text-decoration:none;border-bottom:1px dashed var(--glass-border)}
  .now-inline-link:hover{border-bottom-color:var(--grn)}
  .now-pulse{display:flex;flex-wrap:wrap;gap:18px;margin-top:32px;padding:22px 24px;border:1px solid rgba(255,255,255,.08);border-radius:22px;background:linear-gradient(180deg,rgba(255,255,255,.04),rgba(255,255,255,.02));box-shadow:0 20px 48px rgba(0,0,0,.16)}
  .now-pulse-item{display:flex;align-items:center;gap:10px}
  .now-pulse-dot{width:8px;height:8px;border-radius:50%;background:var(--grn);box-shadow:0 0 10px var(--grn-glow);animation:freshPulse 2s ease-in-out infinite}
  .now-pulse-label{font-family:var(--mono);font-size:11px;letter-spacing:.05em;color:var(--t3);text-transform:uppercase}
  .now-pulse-value{font-family:var(--mono);font-size:14px;color:var(--t1)}
  .now-pulse-sub{color:var(--t3);font-size:12px}
  .now-actions{display:flex;flex-wrap:wrap;gap:12px;align-items:center;margin-top:22px}
  .now-action-link{font-family:var(--mono);font-size:12px;color:var(--t2);text-decoration:none;padding:10px 0;transition:color .2s ease,transform .2s ease}
  .now-action-link:hover{color:var(--t1);transform:translateX(2px)}
  .now-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:18px;margin-top:56px}
  .now-section{margin-top:0;padding:28px;border:1px solid rgba(255,255,255,.08);border-radius:24px;background:linear-gradient(180deg,rgba(255,255,255,.04),rgba(255,255,255,.02));box-shadow:0 20px 48px rgba(0,0,0,.16);overflow:visible}
  .now-section::before{display:none}
  .now-section-head{display:flex;flex-direction:column;gap:8px;margin-bottom:18px;padding-bottom:16px;border-bottom:1px solid rgba(255,255,255,.08)}
  .now-h2{font-family:var(--mono);font-size:12px;text-transform:uppercase;letter-spacing:.15em;color:var(--t3);margin:0}
  .now-section-copy{color:var(--t3);font-size:14px;line-height:1.65;max-width:36ch}
  .now-list{list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:14px}
  .now-li{padding-left:24px;position:relative;color:var(--t1);line-height:1.65;font-size:17px}
  .now-li::before{content:'▸';position:absolute;left:0;top:0;color:var(--grn)}
  .now-p{color:var(--t2);font-size:17px;line-height:1.7;margin:0}
  @media(max-width:760px){
    .now-grid{grid-template-columns:1fr}
    .now-actions{align-items:stretch}
    .now-action-link{padding:0}
  }
</style>
