---
import Base from '../layouts/Base.astro';
import InteriorNav from '../components/InteriorNav.astro';
---
<Base title="404 - Page Not Found" description="The page you're looking for doesn't exist.">
  <a href="#main" class="skip-link">Skip to content</a>
  <InteriorNav contextLabel="404" contextTone="amber" />

  <main id="main" class="search-page">
    <div class="si page-shell">
      <div class="sh rv">
        <div class="sl">// 404</div>
        <h1 class="st">Page not found</h1>
        <p class="sd">
          The page you're looking for doesn't exist, was renamed, or was moved.
        </p>
      </div>

      <div class="error-recovery rv" style="max-width: 42rem; margin: 2rem auto; display: flex; flex-direction: column; gap: 1rem;">
        <a href="/" class="btn btn-primary" style="text-align: center;">← Back to homepage</a>
        <a href="/#catalog" class="btn btn-secondary" style="text-align: center;">Browse the catalog</a>
        <a href="/search/" class="btn btn-secondary" style="text-align: center;">Search projects</a>
      </div>
    </div>
  </main>
</Base>
