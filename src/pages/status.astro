---
import Base from '../layouts/Base.astro';
import InteriorNav from '../components/InteriorNav.astro';
import { buildGeneratedDataTrust } from '../data/generated-trust';
import type { GeneratedReadmeRefresh, GeneratedRelease, GeneratedStats } from '../data/generated';
import { catalog, liveApps, profileFeedInfo } from '../data/portfolio';
import { interiorOgPageBySlug } from '../data/interior-og-pages';
import { pageFreshnessBySlug, reviewedWebPageJsonLd } from '../data/page-freshness';
import pkg from '../../package.json';

const title = 'Status - Matt Parker';
const pageOg = interiorOgPageBySlug.status;
const pageFreshness = pageFreshnessBySlug.status;
const siteUrl = Astro.site?.toString().replace(/\/$/, '') || 'https://sysadmindoc.github.io';
const pageJsonLd = reviewedWebPageJsonLd({
  siteUrl,
  route: pageFreshness.route,
  title,
  description: pageOg.description,
  lastReviewed: pageFreshness.lastReviewed,
  schemaTypes: pageFreshness.schemaTypes,
});

let stats: Partial<GeneratedStats> = {};
try {
  const mod = await import('../data/_stats.json');
  stats = (mod.default ?? mod) as Partial<GeneratedStats>;
} catch {}

let starEntries = 0;
try {
  const mod = await import('../data/_stars.json');
  starEntries = Object.keys(mod.default ?? mod).length;
} catch {}

let metadataEntries = 0;
try {
  const mod = await import('../data/_meta.json');
  metadataEntries = Object.keys(mod.default ?? mod).length;
} catch {}

let readmeEntries = 0;
try {
  const mod = await import('../data/_readmes.json');
  readmeEntries = Object.keys(mod.default ?? mod).length;
} catch {}

let releases: GeneratedRelease[] = [];
try {
  const mod = await import('../data/_releases.json');
  const rows = mod.default ?? mod;
  releases = Array.isArray(rows) ? (rows as GeneratedRelease[]) : [];
} catch {}

let readmeRefresh: Partial<GeneratedReadmeRefresh> | null = null;
try {
  const mod = await import('../data/_readme-refresh.json');
  readmeRefresh = (mod.default ?? mod) as Partial<GeneratedReadmeRefresh>;
} catch {}

function formatPercent(value: number | null) {
  return value == null ? 'unknown' : `${(value * 100).toFixed(1)}%`;
}

function formatAge(value: number | null) {
  return value == null ? 'unknown' : `${value.toFixed(1)}h`;
}

function labelize(value: string) {
  return value.replace(/-/g, ' ');
}

const version = pkg.version;
const builtAt = new Date().toISOString();
const feedActive = profileFeedInfo.active;
const feedSource = profileFeedInfo.source ?? 'unavailable';
const generatedData = buildGeneratedDataTrust({
  stats,
  starEntries,
  metadataEntries,
  readmeEntries,
  releaseEntries: releases.length,
  releases,
  profileFeedInfo,
  readmeRefresh,
});
const dataTone = generatedData.status === 'fresh' ? 'green' : 'amber';
const readmeTone = generatedData.readmeRefresh.tokenPresent ? 'green' : 'amber';
const releaseProvenance = generatedData.releaseProvenance;
const releaseTrustedPercent =
  releaseProvenance.total > 0 ? `${((releaseProvenance.trusted / releaseProvenance.total) * 100).toFixed(1)}%` : 'unknown';
const releaseProvenanceRows = [
  { label: 'Attested', value: releaseProvenance.attested, tone: 'green' },
  { label: 'Checksum', value: releaseProvenance.checksum, tone: 'blue' },
  { label: 'Unsigned', value: releaseProvenance.unsigned, tone: releaseProvenance.unsigned > 0 ? 'amber' : 'green' },
  { label: 'No assets', value: releaseProvenance['no-assets'], tone: 'blue' },
  { label: 'Unknown', value: releaseProvenance.unknown, tone: releaseProvenance.unknown > 0 ? 'amber' : 'green' },
];

const signals = [
  { label: 'Version', value: `v${version}`, tone: 'green' },
  { label: 'Built', value: builtAt.slice(0, 10), tone: 'blue' },
  { label: 'Catalog', value: `${catalog.length} projects`, tone: 'blue' },
  { label: 'Live apps', value: `${liveApps.length}`, tone: 'green' },
  { label: 'Profile feed', value: feedActive ? 'Active' : 'Fallback', tone: feedActive ? 'green' : 'amber' },
  { label: 'Feed source', value: feedSource.length > 40 ? feedSource.slice(0, 37) + '...' : feedSource, tone: 'blue' },
  { label: 'Feed projects', value: `${profileFeedInfo.projectCount}`, tone: 'blue' },
  { label: 'Data mode', value: labelize(generatedData.mode), tone: dataTone },
  { label: 'Data age', value: formatAge(generatedData.ageHours), tone: generatedData.stale ? 'amber' : 'green' },
  { label: 'Profile cache', value: formatAge(generatedData.profileFeed.cachedAgeHours), tone: generatedData.profileFeed.stale ? 'amber' : 'green' },
  { label: 'Stars coverage', value: `${formatPercent(generatedData.coverage.stars)} (${generatedData.coverage.starEntries})`, tone: generatedData.coverage.stars != null && generatedData.coverage.stars >= generatedData.coverage.threshold ? 'green' : 'amber' },
  { label: 'Metadata coverage', value: `${formatPercent(generatedData.coverage.metadata)} (${generatedData.coverage.metadataEntries})`, tone: generatedData.coverage.metadata != null && generatedData.coverage.metadata >= generatedData.coverage.threshold ? 'green' : 'amber' },
  { label: 'README coverage', value: `${formatPercent(generatedData.coverage.readmes)} (${generatedData.coverage.readmeEntries})`, tone: generatedData.coverage.readmes != null && generatedData.coverage.readmes >= generatedData.coverage.threshold ? 'green' : 'amber' },
  { label: 'Release entries', value: `${generatedData.coverage.releaseEntries} (${formatPercent(generatedData.coverage.releases)})`, tone: 'blue' },
  { label: 'Release trust', value: `${releaseProvenance.trusted}/${releaseProvenance.total} (${releaseTrustedPercent})`, tone: releaseProvenance.unsigned > 0 || releaseProvenance.unknown > 0 ? 'amber' : 'green' },
  { label: 'README telemetry', value: generatedData.readmeRefresh.tokenPresent ? 'Token-backed' : 'Not token-backed', tone: readmeTone },
  { label: 'Total repos', value: generatedData.totalRepos != null ? `${generatedData.totalRepos}` : 'N/A', tone: 'blue' },
  { label: 'Total stars', value: generatedData.totalStars != null ? `${generatedData.totalStars}` : 'N/A', tone: 'blue' },
];

const cmdkSections = [
  { label: 'Health', href: '#status-health', desc: 'Build version, data freshness, and deployment signals.', badge: 'STATUS' },
] as const;
---
<Base title={title} description={pageOg.description} ogImage={pageOg.ogImage} ogImageAlt={pageOg.ogImageAlt} cmdkSections={cmdkSections}>
  <script is:inline type="application/ld+json" set:html={pageJsonLd} />
  <a href="#main" class="skip-link">Skip to content</a>
  <InteriorNav active="status" contextLabel="Health" contextTone="green" />

  <main id="main" class="status-page" data-pagefind-body data-pagefind-filter="Scope:Status">
    <span aria-hidden="true" data-pagefind-ignore data-pagefind-meta="route_type:Status"></span>
    <span aria-hidden="true" data-pagefind-ignore data-pagefind-meta="type:Status"></span>
    <span aria-hidden="true" data-pagefind-ignore data-pagefind-meta="category:Portfolio"></span>
    <span aria-hidden="true" data-pagefind-ignore data-pagefind-meta={`updated:${pageFreshness.lastReviewed}`}></span>
    <span aria-hidden="true" data-pagefind-ignore data-pagefind-meta={`image:${pageOg.ogImage}`}></span>
    <span aria-hidden="true" data-pagefind-ignore data-pagefind-meta={`image_alt:${pageOg.ogImageAlt}`}></span>

    <div class="si page-shell" id="status-health">
      <div class="sh rv">
        <div class="sl">// Status</div>
        <h1 class="st">Portfolio health</h1>
        <p class="sd">
          Build version, data freshness, and deployment signals.
          Machine-readable data at <a href="/status.json" class="project-link">/status.json</a>.
        </p>
      </div>

      <div class="status-grid rv">
        {signals.map((s) => (
          <div class="status-card">
            <div class={`status-dot status-dot-${s.tone}`}></div>
            <div class="status-card-body">
              <div class="status-label">{s.label}</div>
              <div class="status-value">{s.value}</div>
            </div>
          </div>
        ))}
      </div>

      <div class="status-provenance-panel rv" aria-label="Release provenance distribution">
        <div>
          <div class="status-warning-title">Release provenance</div>
          <p class="status-provenance-copy">
            Artifact trust tiers from the cached GitHub release feed. Checksum and attested releases are counted as trusted.
          </p>
        </div>
        <div class="status-provenance-grid">
          {releaseProvenanceRows.map((row) => (
            <div class={`status-provenance-pill status-provenance-pill-${row.tone}`}>
              <span>{row.label}</span>
              <strong>{row.value}</strong>
            </div>
          ))}
        </div>
      </div>

      {generatedData.warnings.length > 0 && (
        <div class="status-warning-panel rv" role="status" aria-label="Generated data warnings">
          <div class="status-warning-title">Generated data needs attention</div>
          <ul>
            {generatedData.warnings.map((warning) => <li>{warning}</li>)}
          </ul>
        </div>
      )}

      <p class="status-note rv">
        This page is regenerated on every deploy. No runtime analytics, no uptime monitoring service.
        The values above reflect the state at build time.
      </p>
    </div>
  </main>
</Base>

<style>
  .status-page{padding-bottom:80px}
  .status-grid{
    display:grid;grid-template-columns:repeat(auto-fill,minmax(240px,1fr));gap:14px;
    margin-top:24px;
  }
  .status-card{
    display:flex;align-items:flex-start;gap:12px;
    padding:14px 16px;border-radius:10px;
    border:1px solid var(--border-soft);background:var(--surface-1);
  }
  .status-dot{width:10px;height:10px;border-radius:4px;margin-top:4px;flex-shrink:0}
  .status-dot-green{background:var(--grn)}
  .status-dot-blue{background:var(--blue)}
  .status-dot-amber{background:var(--yel)}
  .status-label{color:var(--t3);font-family:var(--mono);font-size:12px;text-transform:uppercase;letter-spacing:.04em}
  .status-value{color:var(--t1);font-family:var(--mono);font-size:14px;margin-top:2px;overflow-wrap:anywhere;word-break:normal}
  .status-warning-panel{
    margin-top:20px;padding:16px;border:1px solid color-mix(in srgb,var(--yel) 36%,var(--border-soft));
    background:color-mix(in srgb,var(--yel) 8%,var(--surface-1));border-radius:10px;color:var(--t2);
  }
  .status-warning-title{color:var(--t1);font-family:var(--mono);font-size:13px;text-transform:uppercase;letter-spacing:.04em;margin-bottom:8px}
  .status-warning-panel ul{margin:0;padding-left:18px}
  .status-warning-panel li{margin:4px 0}
  .status-provenance-panel{
    display:grid;grid-template-columns:minmax(220px,.8fr) 1.2fr;gap:18px;align-items:start;
    margin-top:20px;padding:16px;border:1px solid var(--border-soft);border-radius:10px;background:var(--surface-1);
  }
  .status-provenance-copy{margin:0;color:var(--t3);font-size:14px;line-height:1.55}
  .status-provenance-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(118px,1fr));gap:10px}
  .status-provenance-pill{
    min-height:64px;display:flex;flex-direction:column;justify-content:center;gap:4px;
    padding:12px;border-radius:8px;border:1px solid var(--border-soft);background:rgba(255,255,255,.03);
  }
  .status-provenance-pill span{font-family:var(--mono);font-size:11px;text-transform:uppercase;color:var(--t3)}
  .status-provenance-pill strong{font-family:var(--mono);font-size:20px;color:var(--t1)}
  .status-provenance-pill-green{border-color:color-mix(in srgb,var(--grn) 30%,var(--border-soft));background:color-mix(in srgb,var(--grn) 8%,var(--surface-1))}
  .status-provenance-pill-blue{border-color:color-mix(in srgb,var(--blue) 30%,var(--border-soft));background:color-mix(in srgb,var(--blue) 8%,var(--surface-1))}
  .status-provenance-pill-amber{border-color:color-mix(in srgb,var(--yel) 36%,var(--border-soft));background:color-mix(in srgb,var(--yel) 8%,var(--surface-1))}
  .status-note{color:var(--t3);font-size:14px;margin-top:24px}
  @media(max-width:640px){
    .status-grid{grid-template-columns:1fr;gap:10px}
    .status-provenance-panel{grid-template-columns:1fr}
  }
</style>
