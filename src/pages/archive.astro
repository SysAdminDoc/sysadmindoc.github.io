---
import Base from '../layouts/Base.astro';
import Divider from '../components/Divider.astro';
import InteriorNav from '../components/InteriorNav.astro';
import SectionJumpNav from '../components/SectionJumpNav.astro';
import { archiveEntries } from '../data/archive';
import { interiorOgPageBySlug } from '../data/interior-og-pages';
import { pageFreshnessBySlug, reviewedWebPageJsonLd } from '../data/page-freshness';
import type { ArchiveStatus } from '../data/types';

const title = 'Archive - Matt Parker';
const pageOg = interiorOgPageBySlug.archive;
const pageFreshness = pageFreshnessBySlug.archive;
const siteUrl = Astro.site?.toString().replace(/\/$/, '') || 'https://sysadmindoc.github.io';
const pageJsonLd = reviewedWebPageJsonLd({
  siteUrl,
  route: pageFreshness.route,
  title,
  description: pageOg.description,
  lastReviewed: pageFreshness.lastReviewed,
  schemaTypes: pageFreshness.schemaTypes,
});
const publicLinkCount = archiveEntries.reduce((total, entry) => total + entry.links.length, 0);
const sensitiveCount = archiveEntries.filter((entry) => entry.sensitive).length;
const linkedEntryCount = archiveEntries.filter((entry) => entry.links.length > 0).length;
const statusCounts = archiveEntries.reduce<Record<ArchiveStatus, number>>((counts, entry) => {
  counts[entry.status] = (counts[entry.status] ?? 0) + 1;
  return counts;
}, {} as Record<ArchiveStatus, number>);

const statusTone: Record<ArchiveStatus, string> = {
  moved: 'blue',
  held: 'amber',
  removed: 'slate',
  superseded: 'green',
  archived: 'amber',
};

const statusLabels: Record<ArchiveStatus, string> = {
  moved: 'Moved',
  held: 'Held',
  removed: 'Removed',
  superseded: 'Superseded',
  archived: 'Archived',
};

const cmdkSections = [
  { label: 'Overview', href: '#archive-overview', desc: 'What the archive records and why it exists.', badge: 'ARCHIVE' },
  { label: 'Policy', href: '#archive-policy', desc: 'The rules for safe links, sensitive removals, and successor projects.', badge: 'RULES' },
  { label: 'Entries', href: '#archive-entries', desc: 'Retired, moved, held, or superseded project decisions.', badge: `${archiveEntries.length}` },
] as const;
---
<Base title={title} description={pageOg.description} ogImage={pageOg.ogImage} ogImageAlt={pageOg.ogImageAlt} cmdkSections={cmdkSections}>
  <script is:inline type="application/ld+json" set:html={pageJsonLd} />
  <a href="#main" class="skip-link">Skip to content</a>
  <InteriorNav active="archive" contextLabel="Archive decisions" contextTone="amber" />

  <main id="main" class="archive-page" data-pagefind-body>
    <div class="si page-shell" id="archive-overview">
      <div class="sh rv">
        <div class="sl">// Archive</div>
        <h1 class="st archive-title">Retired projects and boundary decisions</h1>
        <p class="sd">
          A public-safe record of work that moved out of the main showcase, was superseded, or is held back for privacy review.
          Safe public projects still get links; sensitive or private work is summarized without becoming a new index.
        </p>
      </div>

      <div class="archive-overview page-stat-grid rv">
        <div class="page-stat">
          <div class="page-stat-value">{archiveEntries.length}</div>
          <div class="page-stat-label">Decisions Logged</div>
          <div class="page-stat-copy">Retired, moved, held, superseded, or archived project decisions.</div>
        </div>
        <div class="page-stat">
          <div class="page-stat-value">{publicLinkCount}</div>
          <div class="page-stat-label">Safe Public Links</div>
          <div class="page-stat-copy">Only reviewed public surfaces are linked from this page.</div>
        </div>
        <div class="page-stat">
          <div class="page-stat-value">{sensitiveCount}</div>
          <div class="page-stat-label">Linkless Holds</div>
          <div class="page-stat-copy">Sensitive or private contexts stay summarized, not re-listed.</div>
        </div>
      </div>

      <div class="archive-actions page-actions rv">
        <a href="/#catalog" class="btn bp">Open active catalog</a>
        <a href="/timeline/" class="btn bg2">Open timeline</a>
        <a href="https://github.com/SysAdminDoc" target="_blank" rel="noopener" class="page-action-link">Open GitHub workspace</a>
      </div>

      <SectionJumpNav items={cmdkSections} />
    </div>
    <Divider />

    <div class="si archive-content">
      <section class="archive-policy rv" id="archive-policy" aria-labelledby="archive-policy-title">
        <div class="archive-section-head">
          <h2 id="archive-policy-title">Archive Rules</h2>
          <p>The archive explains portfolio evolution without reopening private or unsafe surfaces.</p>
        </div>
        <div class="archive-policy-grid">
          <article class="archive-policy-card">
            <span>01</span>
            <h3>Link Only Reviewed Public Work</h3>
            <p>External links are limited to public repositories or active project routes that are still safe to browse.</p>
          </article>
          <article class="archive-policy-card">
            <span>02</span>
            <h3>Summarize Sensitive Removals</h3>
            <p>Private, employer-adjacent, medical-imaging, or internal artifacts are described by decision pattern, not indexed by name.</p>
          </article>
          <article class="archive-policy-card">
            <span>03</span>
            <h3>Prefer Maintained Successors</h3>
            <p>When an older direction has a clearer current replacement, visitors are sent to the maintained public surface.</p>
          </article>
        </div>
      </section>

      <section class="archive-entries-wrap" id="archive-entries" aria-labelledby="archive-entries-title">
        <div class="archive-section-head">
          <h2 id="archive-entries-title">Decision Log</h2>
          <p>{linkedEntryCount} entries include safe public links; {sensitiveCount} entries intentionally do not.</p>
        </div>

        <div class="archive-status-row" aria-label="Archive status counts">
          {(Object.keys(statusLabels) as ArchiveStatus[]).map((status) => (
            (statusCounts[status] ?? 0) > 0 && (
              <span class={`archive-status-badge archive-tone-${statusTone[status]}`}>
                {statusLabels[status]} {statusCounts[status]}
              </span>
            )
          ))}
        </div>

        <div class="archive-grid">
          {archiveEntries.map((entry) => (
            <article class={`archive-entry archive-tone-${statusTone[entry.status]}`}>
              <div class="archive-entry-top">
                <span class="archive-status">{entry.statusLabel}</span>
                {entry.sensitive && <span class="archive-sensitive">No public links</span>}
              </div>
              <h3>{entry.name}</h3>
              <p class="archive-summary">{entry.summary}</p>
              <div class="archive-reason">
                <span>Why</span>
                <p>{entry.reason}</p>
              </div>
              <div class="archive-source">
                <span>Source</span>
                <p>{entry.source}</p>
              </div>
              {entry.links.length > 0 ? (
                <div class="archive-links" aria-label={`${entry.name} links`}>
                  {entry.links.map((link) => (
                    <a href={link.href} target={link.href.startsWith('http') ? '_blank' : undefined} rel={link.href.startsWith('http') ? 'noopener' : undefined}>
                      <span>{link.label}</span>
                      {link.note && <small>{link.note}</small>}
                    </a>
                  ))}
                </div>
              ) : (
                <p class="archive-no-links">No public project link is surfaced for this decision.</p>
              )}
            </article>
          ))}
        </div>
      </section>
    </div>
  </main>

  <footer>
    <div class="fi page-footer-shell">
      <div class="footer-brand">
        <div class="ft"><a href="/" class="footer-backlink">Back to portfolio</a></div>
        <p class="footer-summary">The archive is the boundary layer. The active catalog and timeline show what remains public, current, and safe to promote.</p>
      </div>
      <nav class="fl" aria-label="Footer navigation"><a href="/#catalog">Catalog</a><a href="https://github.com/SysAdminDoc" target="_blank" rel="noopener">GitHub</a></nav>
    </div>
  </footer>
</Base>

<style is:global>
  .archive-page{min-height:calc(100vh - 200px)}
  .archive-title{font-size:clamp(34px,4.8vw,56px)!important}
  .archive-overview{margin-top:32px}
  .archive-actions{margin-top:22px}
  .archive-content{display:grid;gap:58px}
  .archive-policy,.archive-entries-wrap{padding:0;overflow:visible}
  .archive-policy::before,.archive-entries-wrap::before{display:none}
  .archive-section-head{display:flex;align-items:end;justify-content:space-between;gap:24px;margin-bottom:20px;padding-bottom:14px;border-bottom:1px solid var(--border-soft)}
  .archive-section-head h2{font-family:var(--mono);font-size:13px;text-transform:uppercase;letter-spacing:.16em;color:var(--t1);margin:0}
  .archive-section-head p{color:var(--t3);font-size:14px;line-height:1.6;max-width:52ch;margin:0}
  .archive-policy-grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:14px}
  .archive-policy-card{display:grid;align-content:start;gap:12px;padding:22px;border:1px solid var(--border-soft);border-radius:8px;background:var(--surface-1);box-shadow:var(--shadow-soft)}
  .archive-policy-card span{font-family:var(--mono);font-size:11px;letter-spacing:.16em;color:var(--grn)}
  .archive-policy-card h3{font-size:18px;line-height:1.3;margin:0}
  .archive-policy-card p{color:var(--t2);font-size:14px;line-height:1.65;margin:0}
  .archive-status-row{display:flex;flex-wrap:wrap;gap:8px;margin-bottom:18px}
  .archive-status-badge{font-family:var(--mono);font-size:11px;letter-spacing:.1em;text-transform:uppercase;padding:6px 10px;border:1px solid var(--border-soft);border-radius:4px;background:rgba(255,255,255,.03);color:var(--t2)}
  .archive-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:16px}
  .archive-entry{position:relative;display:grid;align-content:start;gap:14px;padding:24px;border:1px solid var(--border-soft);border-radius:8px;background:var(--surface-1);box-shadow:var(--shadow-soft);overflow:hidden}
  .archive-entry::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:var(--archive-accent,var(--blue));opacity:.85}
  .archive-entry-top{display:flex;align-items:center;justify-content:space-between;gap:10px;flex-wrap:wrap}
  .archive-status,.archive-sensitive{font-family:var(--mono);font-size:10px;letter-spacing:.12em;text-transform:uppercase;padding:5px 8px;border:1px solid var(--border-soft);border-radius:6px;background:rgba(255,255,255,.03);color:var(--t2)}
  .archive-sensitive{color:var(--yel);background:var(--yeld);border-color:rgba(250,204,21,.24)}
  .archive-entry h3{font-size:21px;line-height:1.3;margin:0}
  .archive-summary{color:var(--t2);font-size:15px;line-height:1.68;margin:0}
  .archive-reason,.archive-source{display:grid;gap:6px;padding-top:12px;border-top:1px solid var(--border-soft)}
  .archive-reason span,.archive-source span{font-family:var(--mono);font-size:10px;letter-spacing:.13em;text-transform:uppercase;color:var(--t3)}
  .archive-reason p,.archive-source p{color:var(--t2);font-size:13px;line-height:1.62;margin:0}
  .archive-source p{color:var(--t3);font-family:var(--mono);font-size:12px}
  .archive-links{display:grid;gap:8px;margin-top:2px}
  .archive-links a{display:flex;align-items:center;justify-content:space-between;gap:12px;min-height:48px;padding:10px 12px;border:1px solid var(--border-soft);border-radius:8px;background:rgba(255,255,255,.025);color:var(--t1);text-decoration:none;transition:border-color .2s ease,background-color .2s ease,transform .2s ease}
  .archive-links a:hover,.archive-links a:focus-visible{border-color:var(--archive-accent,var(--grn));background:rgba(255,255,255,.05);transform:translateY(-1px)}
  .archive-links span{font-family:var(--mono);font-size:13px;font-weight:600}
  .archive-links small{color:var(--t3);font-size:12px;line-height:1.4;text-align:right}
  .archive-no-links{margin:0;padding:12px;border:1px dashed var(--border-soft);border-radius:8px;color:var(--t3);font-size:13px;line-height:1.55;background:rgba(255,255,255,.02)}
  .archive-tone-blue{--archive-accent:var(--blue)}
  .archive-tone-green{--archive-accent:var(--grn)}
  .archive-tone-amber{--archive-accent:var(--yel)}
  .archive-tone-slate{--archive-accent:var(--t3)}
  .archive-tone-blue.archive-status-badge{color:var(--blue);background:var(--blued);border-color:rgba(88,166,255,.2)}
  .archive-tone-green.archive-status-badge{color:var(--grn);background:var(--grnd);border-color:rgba(74,222,128,.2)}
  .archive-tone-amber.archive-status-badge{color:var(--yel);background:var(--yeld);border-color:rgba(250,204,21,.24)}
  @media(max-width:900px){
    .archive-policy-grid,.archive-grid{grid-template-columns:1fr}
    .archive-section-head{align-items:start;flex-direction:column}
  }
  @media(max-width:640px){
    .archive-page .page-shell,
    .archive-content,
    .archive-policy,
    .archive-entries-wrap,
    .archive-policy-grid,
    .archive-grid,
    .archive-entry,
    .archive-policy-card{
      width:100%;
      max-width:100%;
      min-width:0;
    }
    .archive-title{
      max-width:12ch;
      font-size:clamp(30px,8vw,36px)!important;
      line-height:1.12;
      overflow-wrap:break-word;
    }
    .archive-page .sd,
    .archive-entry h3,
    .archive-summary,
    .archive-reason p,
    .archive-source p{
      max-width:100%;
      overflow-wrap:break-word;
    }
    .archive-page .sd{
      max-width:26ch;
      font-size:15px;
      line-height:1.65;
    }
    .archive-entry{padding:20px}
    .archive-links a{align-items:flex-start;flex-direction:column}
    .archive-links small{text-align:left}
  }
  @media(max-width:420px){
    .archive-page .page-shell > .sh{
      padding:24px 20px 22px;
    }
    .archive-title{
      max-width:12ch;
      font-size:30px!important;
    }
    .archive-page .sd{
      max-width:24ch;
      font-size:15px;
      line-height:1.65;
    }
  }
</style>
