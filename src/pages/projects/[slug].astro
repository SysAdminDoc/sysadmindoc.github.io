---
import Base from '../../layouts/Base.astro';
import Divider from '../../components/Divider.astro';
import StarSvg from '../../components/StarSvg.astro';
import { featured, liveApps, catalog } from '../../data/projects';
import { existsSync } from 'node:fs';
import { fileURLToPath } from 'node:url';
import { dirname, join } from 'node:path';
import { marked } from 'marked';
import sanitizeHtml from 'sanitize-html';

export async function getStaticPaths() {
  // One page per unique repo across featured + liveApps + catalog
  const seen = new Set<string>();
  const paths: { params: { slug: string } }[] = [];

  const add = (slug: string) => {
    if (!slug || seen.has(slug)) return;
    seen.add(slug);
    paths.push({ params: { slug } });
  };

  featured.forEach((p) => add(p.repo));
  liveApps.forEach((a) => add(a.slug));
  catalog.forEach((c) => add(c.repo));

  return paths;
}

const { slug } = Astro.params;

const featuredMatch = featured.find((p) => p.repo === slug);
const liveMatch = liveApps.find((a) => a.slug === slug);
const catalogMatch = catalog.find((c) => c.repo === slug);

const name = featuredMatch?.name ?? liveMatch?.name ?? catalogMatch?.name ?? slug;
const desc = featuredMatch?.desc ?? liveMatch?.desc ?? catalogMatch?.desc ?? '';
const category = featuredMatch?.lang ?? catalogMatch?.category ?? 'web';

const ghUrl = `https://github.com/SysAdminDoc/${slug}`;
const liveUrl = liveMatch?.url;
const tags = featuredMatch?.tags ?? [];
const isLive = !!liveMatch;
const isFeatured = !!featuredMatch;

let stars: Record<string, number> = {};
try {
  const mod = await import('../../data/_stars.json');
  stars = (mod.default ?? mod) as Record<string, number>;
} catch {}
const starCount = stars[slug] ?? 0;

// Check if a captured screenshot exists (committed via `npm run capture-screenshots`)
const publicDir = join(dirname(fileURLToPath(import.meta.url)), '..', '..', '..', 'public');
const screenshotPath = join(publicDir, 'screenshots', `${slug}.jpg`);
const hasScreenshot = existsSync(screenshotPath);

// README: rendered from markdown cached at build time by scripts/fetch-stars.mjs
let readmes: Record<string, string> = {};
try {
  const mod = await import('../../data/_readmes.json');
  readmes = (mod.default ?? mod) as Record<string, string>;
} catch {}
let readmeHtml: string | null = null;
const rawMd = readmes[slug];
if (rawMd && rawMd.trim().length > 0) {
  // Rewrite relative links/images to point at GitHub raw so assets resolve.
  const rawBase = `https://raw.githubusercontent.com/SysAdminDoc/${slug}/HEAD/`;
  const blobBase = `https://github.com/SysAdminDoc/${slug}/blob/HEAD/`;
  const escapeAttr = (value: string) =>
    String(value).replace(/&/g, '&amp;').replace(/"/g, '&quot;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
  marked.use({
    gfm: true,
    breaks: false,
    renderer: {
      image(token: any) {
        const href = /^https?:|^data:|^\/\//.test(token.href) ? token.href : rawBase + token.href.replace(/^\.?\//, '');
        const alt = token.text ?? '';
        return `<img src="${escapeAttr(href)}" alt="${escapeAttr(alt)}" loading="lazy" decoding="async" />`;
      },
      link(token: any) {
        const href = /^https?:|^mailto:|^#/.test(token.href) ? token.href : blobBase + token.href.replace(/^\.?\//, '');
        const safeHref = escapeAttr(href);
        const safeText = token.text ?? safeHref;
        if (href.startsWith('#')) {
          return `<a href="${safeHref}">${safeText}</a>`;
        }
        if (href.startsWith('mailto:')) {
          return `<a href="${safeHref}" rel="nofollow">${safeText}</a>`;
        }
        return `<a href="${safeHref}" rel="noopener nofollow" target="_blank">${safeText}</a>`;
      },
    },
  });
  const rendered = await marked.parse(rawMd);
  readmeHtml = sanitizeHtml(rendered as string, {
    allowedTags: sanitizeHtml.defaults.allowedTags.concat(['img', 'h1', 'h2', 'picture', 'source', 'details', 'summary', 'kbd', 'del', 'input']),
    allowedAttributes: {
      ...sanitizeHtml.defaults.allowedAttributes,
      img: ['src', 'alt', 'title', 'width', 'height', 'loading', 'decoding', 'align'],
      a: ['href', 'name', 'target', 'rel', 'id'],
      code: ['class'],
      span: ['class'],
      div: ['class', 'align'],
      h1: ['id'], h2: ['id'], h3: ['id'], h4: ['id'], h5: ['id'], h6: ['id'],
      input: ['type', 'checked', 'disabled'],
      source: ['srcset', 'media', 'type'],
    },
    allowedSchemes: ['http', 'https', 'mailto', 'data'],
    transformTags: {
      a: (tagName, attribs) => {
        const href = attribs.href ?? '';
        const nextAttribs = { ...attribs };
        if (href.startsWith('#')) {
          delete nextAttribs.rel;
          delete nextAttribs.target;
          return { tagName, attribs: nextAttribs };
        }
        if (href.startsWith('mailto:')) {
          nextAttribs.rel = 'nofollow';
          delete nextAttribs.target;
          return { tagName, attribs: nextAttribs };
        }
        nextAttribs.rel = 'noopener nofollow';
        nextAttribs.target = '_blank';
        return { tagName, attribs: nextAttribs };
      },
      input: (tagName, attribs) => {
        // Only allow GFM task-list checkboxes; force disabled to prevent interaction
        if (attribs.type !== 'checkbox') return { tagName: '', attribs: {} };
        return { tagName, attribs: { type: 'checkbox', disabled: '', ...(attribs.checked != null ? { checked: '' } : {}) } };
      },
    },
  });
}

// Per-project releases (from cached _releases.json)
let allReleases: Array<{ repo: string; tag: string; name: string; publishedAt: string; url: string; bodyFirst: string }> = [];
try {
  const mod = await import('../../data/_releases.json');
  allReleases = (mod.default ?? mod) as any;
} catch {}
const projectReleases = allReleases.filter((r) => r.repo === slug).slice(0, 5);

// Tech-stack chips — derived from repo language (_meta.json) plus catalog category.
let metaMap: Record<string, { stars: number; pushedAt: string; updatedAt: string; language: string | null }> = {};
try {
  const mod = await import('../../data/_meta.json');
  metaMap = (mod.default ?? mod) as any;
} catch {}
const language = metaMap[slug]?.language ?? null;
const categoryLabel: Record<string, string> = {
  ps: 'PowerShell', py: 'Python', web: 'Web', ext: 'Extension', kt: 'Android',
  sec: 'Security', media: 'Media', cs: 'Desktop', guide: 'Guide', fork: 'Fork', other: 'Other',
};
const techChips = Array.from(new Set([
  language,
  categoryLabel[category] ?? null,
  ...tags,
].filter(Boolean))) as string[];
const lastTouchedAt = metaMap[slug]?.updatedAt ?? metaMap[slug]?.pushedAt ?? null;
const latestRelease = projectReleases[0] ?? null;
const compactUtcDate = new Intl.DateTimeFormat('en-US', { month: 'short', day: 'numeric', year: 'numeric', timeZone: 'UTC' });
const projectFacts = [
  {
    label: 'Delivery',
    value: isLive ? 'Runs live' : 'Source-first',
    detail: isLive ? 'Launches in the browser with no install wall.' : 'Browse code, README, and release notes on GitHub.',
  },
  {
    label: 'Primary stack',
    value: language ?? (categoryLabel[category] ?? 'Other'),
    detail: language && categoryLabel[category] && language !== categoryLabel[category]
      ? `${categoryLabel[category]} category`
      : 'Catalog classification',
  },
  {
    label: 'Freshness',
    value: lastTouchedAt ? compactUtcDate.format(new Date(lastTouchedAt)) : 'Unavailable',
    detail: lastTouchedAt ? `Updated ${compactUtcDate.format(new Date(lastTouchedAt))}` : 'GitHub metadata unavailable',
    rel: lastTouchedAt,
  },
  {
    label: 'Latest release',
    value: latestRelease?.tag ?? 'No tag yet',
    detail: latestRelease?.publishedAt
      ? `Published ${compactUtcDate.format(new Date(latestRelease.publishedAt))}`
      : 'README is the clearest project overview right now.',
  },
];

// Related: same category, excluding self + archived. Ranked by stars then freshness.
const related = catalog
  .filter((c) => c.category === category && c.repo !== slug)
  .map((c) => ({
    ...c,
    _stars: stars[c.repo] ?? 0,
    _pushed: metaMap[c.repo]?.pushedAt ?? '0',
  }))
  .sort((a, b) => (b._stars - a._stars) || (new Date(b._pushed).getTime() - new Date(a._pushed).getTime()))
  .slice(0, 4);

const title = `${name} — Matt Parker`;
const ogImage = `/og/${slug}.png`;
---
<Base title={title} description={desc} ogImage={ogImage}>
  <a href="#main" class="skip-link">Skip to content</a>

  <nav id="nav" aria-label="Main navigation">
    <div class="ni">
      <a href="/" class="nl">matt<span>@</span>sysadmin<span>:~$</span></a>
      <div class="nk" id="navLinks">
        <a href="/#featured">Projects</a>
        <a href="/#live">Live Apps</a>
        <a href="/#catalog">Catalog</a>
        <a href="/#about">About</a>
      </div>
      <div style="display:flex;align-items:center;gap:8px">
        <button type="button" class="theme-toggle" id="themeToggle" aria-label="Switch to light theme" title="Switch to light theme"><svg viewBox="0 0 24 24"><path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"/></svg></button>
        <a href="/" class="ng" aria-label="Home">← Home</a>
        <button type="button" class="mt" id="mobileToggle" aria-label="Toggle navigation menu" aria-controls="navLinks" aria-expanded="false"><svg viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg></button>
      </div>
    </div>
  </nav>

  <main id="main" class="project-page">
    <div class="si" style="padding-top:100px">
      <div class="project-header">
        <div class="project-meta">
          <span class={`cdo ${category}`} style="display:inline-block;width:10px;height:10px;border-radius:50%;margin-right:8px"></span>
          <span class="project-category">{category.toUpperCase()}</span>
          {isFeatured && <span class="project-badge-featured">FEATURED</span>}
          {isLive && <span class="project-badge-live">LIVE</span>}
        </div>
        <h1 class="project-title">{name}</h1>
        <p class="project-desc" set:html={desc}></p>
        {techChips.length > 0 && (
          <div class="project-tags">
            {techChips.map((t) => <span class="ctg">{t}</span>)}
          </div>
        )}
        <div class="project-actions">
          <a href={ghUrl} target="_blank" rel="noopener" class="btn bp">
            <svg viewBox="0 0 16 16" fill="currentColor" width="16" height="16"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
            View on GitHub
          </a>
          {liveUrl && (
            <a href={liveUrl} target="_blank" rel="noopener" class="btn bg2">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><path d="M10 13a5 5 0 007.54.54l3-3a5 5 0 00-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 00-7.54-.54l-3 3a5 5 0 007.07 7.07l1.71-1.71"/></svg>
              Open live app
            </a>
          )}
          {starCount > 0 && (
            <span class="project-stars"><StarSvg /> {starCount}</span>
          )}
        </div>
        <div class="project-overview" aria-label="Project snapshot">
          {projectFacts.map((fact) => (
            <div class="project-fact">
              <div class="project-fact-label">{fact.label}</div>
              {fact.rel ? (
                <div class="project-fact-value"><time datetime={fact.rel} data-rel={fact.rel}>{fact.value}</time></div>
              ) : (
                <div class="project-fact-value">{fact.value}</div>
              )}
              <div class="project-fact-detail">{fact.detail}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
    <Divider />

    {/* Preview: live screenshot (if captured) or OG card */}
    <div class="si">
      <div class="project-readme-wrap project-panel">
        <div class="project-section-head">
          <div>
            <h2 class="project-section-title">{hasScreenshot ? 'Live Preview' : 'Preview'}</h2>
            <p class="project-section-copy">{hasScreenshot && isLive ? 'Captured from the deployed app so you can judge the real product surface before opening it.' : 'Using the generated project card until a live capture is available.'}</p>
          </div>
        </div>
        {hasScreenshot && isLive ? (
          <a href={liveUrl} target="_blank" rel="noopener" class="project-shot-link">
            <img src={`/screenshots/${slug}.jpg`} alt={`${name} live screenshot`} class="project-shot" width="1600" height="1000" decoding="async" fetchpriority="high" />
            <span class="project-shot-badge">Open live →</span>
          </a>
        ) : (
          <img src={`/og/${slug}.png`} alt={`${name} card`} class="project-og" width="1200" height="630" decoding="async" fetchpriority="high" />
        )}
        <p class="project-readme-hint">
          Source at <a href={ghUrl} target="_blank" rel="noopener" class="project-link">github.com/SysAdminDoc/{slug}</a>.
        </p>
      </div>
    </div>
    <Divider />

    {readmeHtml && (
      <div class="si">
        <div class="project-readme-wrap project-panel">
          <div class="project-section-head">
            <div>
              <h2 class="project-section-title">README</h2>
              <p class="project-section-copy">Cached at build time, cleaned up for in-site reading, and linked back to the canonical GitHub source.</p>
            </div>
          </div>
          <article class="project-readme" set:html={readmeHtml}></article>
          <p class="project-readme-hint" style="margin-top:24px">
            Read on GitHub → <a href={ghUrl} target="_blank" rel="noopener" class="project-link">github.com/SysAdminDoc/{slug}</a>
          </p>
        </div>
      </div>
    )}
    {readmeHtml && <Divider />}

    {projectReleases.length > 0 && (
      <div class="si">
        <div class="project-readme-wrap project-panel">
          <div class="project-section-head">
            <div>
              <h2 class="project-section-title">Recent Releases</h2>
              <p class="project-section-copy">Latest tagged notes pulled from GitHub release history for this repo.</p>
            </div>
          </div>
          <ul class="project-releases">
            {projectReleases.map((r) => (
              <li class="project-release">
                <a href={r.url} target="_blank" rel="noopener" class="project-release-tag">{r.tag}</a>
                <time class="project-release-date" datetime={r.publishedAt}>
                  {compactUtcDate.format(new Date(r.publishedAt))}
                </time>
                {r.bodyFirst && <p class="project-release-body">{r.bodyFirst}</p>}
              </li>
            ))}
          </ul>
        </div>
      </div>
    )}
    {projectReleases.length > 0 && <Divider />}

    {related.length > 0 && (
      <div class="si">
        <div class="project-readme-wrap project-panel">
          <div class="project-section-head">
            <div>
              <h2 class="project-section-title">Related Projects</h2>
              <p class="project-section-copy">More work from the same lane, ranked by stars first and then by how recently it moved.</p>
            </div>
          </div>
        <div class="cg" style="margin-top:24px">
          {related.map((r) => (
            <a href={`/projects/${r.repo}/`} class="ca">
              <span class={`cdo ${r.category}`}></span>
              <span class="cna">{r.name}</span>
              <span class="cds" set:html={r.desc}></span>
            </a>
          ))}
        </div>
        </div>
      </div>
    )}
  </main>

  <footer>
    <div class="fi">
      <div class="ft">
        <a href="/" style="color:var(--t2)">← Back to portfolio</a>
      </div>
      <div class="fl"><a href="https://github.com/SysAdminDoc" target="_blank" rel="noopener">GitHub</a></div>
    </div>
  </footer>
</Base>

<style is:global>
  .project-page{min-height:calc(100vh - 200px)}
  .project-header{max-width:900px;margin:0 auto;text-align:left}
  .project-meta{display:flex;align-items:center;gap:10px;margin-bottom:20px;font-family:var(--mono);font-size:12px;color:var(--t3);flex-wrap:wrap}
  .project-category{letter-spacing:.1em}
  .project-badge-featured,.project-badge-live{padding:3px 8px;border-radius:4px;font-weight:600;font-size:10px}
  .project-badge-featured{background:var(--yeld);color:var(--yel);border:1px solid rgba(250,204,21,.3)}
  .project-badge-live{background:var(--grnd);color:var(--grn);border:1px solid rgba(74,222,128,.3)}
  .project-title{font-family:var(--mono);font-size:clamp(32px,5vw,56px);font-weight:700;margin-bottom:16px;color:var(--t1);word-break:break-word}
  .project-desc{font-size:clamp(16px,1.5vw,20px);color:var(--t2);line-height:1.6;margin-bottom:24px;max-width:700px}
  .project-tags{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:28px}
  .project-actions{display:flex;gap:12px;flex-wrap:wrap;align-items:center}
  .project-overview{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:14px;margin-top:28px}
  .project-fact{padding:18px 18px 16px;border-radius:18px;border:1px solid rgba(255,255,255,.08);background:linear-gradient(180deg, rgba(255,255,255,.04), rgba(255,255,255,.02));box-shadow:0 18px 42px rgba(0,0,0,.16)}
  .project-fact-label{font-family:var(--mono);font-size:10px;letter-spacing:.16em;text-transform:uppercase;color:var(--t3);margin-bottom:10px}
  .project-fact-value{font-family:var(--mono);font-size:18px;color:var(--t1);line-height:1.2;margin-bottom:8px}
  .project-fact-detail{font-size:13px;color:var(--t2);line-height:1.6}
  .project-stars{display:inline-flex;align-items:center;gap:6px;font-family:var(--mono);font-size:14px;color:var(--yel);padding:8px 14px;border:1px solid rgba(250,204,21,.3);border-radius:8px;background:var(--yeld)}
  .project-stars svg{width:14px;height:14px;fill:currentColor}
  .project-section-head{display:flex;align-items:flex-start;justify-content:space-between;gap:16px;margin-bottom:20px}
  .project-section-title{font-family:var(--mono);font-size:14px;text-transform:uppercase;letter-spacing:.1em;color:var(--t2);margin-bottom:8px}
  .project-section-copy{max-width:58ch;color:var(--t3);font-size:14px;line-height:1.7}
  .project-readme-wrap{max-width:1000px;margin:0 auto}
  .project-panel{padding:30px;border-radius:28px;border:1px solid rgba(255,255,255,.08);background:linear-gradient(180deg, rgba(255,255,255,.04), rgba(255,255,255,.02));box-shadow:0 24px 60px rgba(0,0,0,.22)}
  .project-readme-hint{color:var(--t3);font-size:14px;margin-bottom:20px}
  .project-link{color:var(--grn);text-decoration:none;border-bottom:1px solid transparent;transition:border-color .2s}
  .project-link:hover{border-color:var(--grn)}
  .project-shot-link{display:block;position:relative;max-width:960px;margin:0 auto;border-radius:14px;overflow:hidden;border:1px solid var(--glass-border);background:var(--bg2);box-shadow:0 24px 60px rgba(0,0,0,.4);transition:transform .25s ease-out,box-shadow .25s}
  .project-shot-link:hover{transform:translateY(-4px);box-shadow:0 30px 80px rgba(88,166,255,.15)}
  .project-shot{display:block;width:100%;height:auto;aspect-ratio:16/10}
  .project-shot-badge{position:absolute;bottom:16px;right:16px;padding:8px 14px;border-radius:8px;background:rgba(10,14,23,.85);color:var(--grn);font-family:var(--mono);font-size:13px;border:1px solid rgba(74,222,128,.3);backdrop-filter:blur(8px);opacity:0;transition:opacity .2s}
  .project-shot-link:hover .project-shot-badge{opacity:1}
  .project-og{display:block;max-width:800px;width:100%;height:auto;border-radius:12px;border:1px solid var(--glass-border);margin:0 auto}
  .project-readme{color:var(--t2);line-height:1.7;font-size:16px;max-width:860px;margin:0 auto;word-wrap:break-word}
  .project-readme h1,.project-readme h2,.project-readme h3,.project-readme h4{color:var(--t1);font-family:var(--mono);margin:32px 0 14px;line-height:1.3}
  .project-readme h1[id],.project-readme h2[id],.project-readme h3[id],.project-readme h4[id],.project-readme h5[id],.project-readme h6[id]{scroll-margin-top:96px}
  .project-readme h1{font-size:28px;border-bottom:1px solid var(--glass-border);padding-bottom:10px}
  .project-readme h2{font-size:22px;border-bottom:1px solid var(--glass-border);padding-bottom:8px}
  .project-readme h3{font-size:18px}
  .project-readme h4{font-size:16px;color:var(--t2)}
  .project-readme p{margin:0 0 16px}
  .project-readme a{color:var(--grn);text-decoration:none;border-bottom:1px solid transparent;transition:border-color .2s}
  .project-readme a:hover{border-color:var(--grn)}
  .project-readme ul,.project-readme ol{padding-left:24px;margin:0 0 16px}
  .project-readme li{margin:6px 0}
  .project-readme code{font-family:var(--mono);font-size:13px;background:var(--bg2);padding:2px 6px;border-radius:4px;border:1px solid var(--glass-border)}
  .project-readme pre{background:var(--bg2);border:1px solid var(--glass-border);border-radius:10px;padding:16px;overflow-x:auto;font-size:13px;line-height:1.5;margin:0 0 16px}
  .project-readme pre code{background:transparent;border:0;padding:0;font-size:13px}
  .project-readme blockquote{border-left:3px solid var(--grn);padding:4px 16px;margin:0 0 16px;color:var(--t3);background:var(--bg2);border-radius:0 8px 8px 0}
  .project-readme img{max-width:100%;height:auto;border-radius:8px;margin:8px 0}
  .project-readme table{border-collapse:collapse;margin:0 0 16px;display:block;overflow-x:auto}
  .project-readme th,.project-readme td{border:1px solid var(--glass-border);padding:8px 12px;text-align:left}
